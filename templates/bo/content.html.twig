{% extends 'layouts/bo.html.twig' %}

{% block title %}Contenu - StudySprint BO{% endblock %}
{% block breadcrumb %}Contenu{% endblock %}

{% block content %}
{% if state == 'empty' %}
    <div class="bo-page-header">
        <h1 class="bo-page-title">Contenu</h1>
    </div>
    {{ include('components/_empty_state.html.twig', {
        title: 'Aucun contenu',
        description: 'Commencez par creer une matiere pour structurer votre contenu pedagogique.',
        cta_text: 'Creer une matiere',
        variant: 'bo'
    }) }}
{% else %}
    {# ─── DEFAULT STATE ─── #}
    <div class="bo-page-header">
        <h1 class="bo-page-title">Contenu</h1>
    </div>

    {# Stats Row #}
    <div class="bo-stats-row">
        <div class="bo-stat-item">
            <span class="bo-stat-value">{{ data.stats.subjects }}</span>
            <span class="bo-stat-label">Matieres</span>
        </div>
        <div class="bo-stat-item">
            <span class="bo-stat-value">{{ data.stats.chapters }}</span>
            <span class="bo-stat-label">Chapitres</span>
        </div>
        <div class="bo-stat-item">
            <span class="bo-stat-value">{{ data.stats.quizzes }}</span>
            <span class="bo-stat-label">Quiz</span>
        </div>
        <div class="bo-stat-item">
            <span class="bo-stat-value" style="color: var(--color-success);">{{ data.stats.published_quizzes }}</span>
            <span class="bo-stat-label">Quiz publiés</span>
        </div>
        <div class="bo-stat-item">
            <span class="bo-stat-value">{{ data.stats.decks }}</span>
            <span class="bo-stat-label">Decks flashcards</span>
        </div>
    </div>

    {# Tabs #}
    <div style="border-bottom: 1px solid var(--color-gray-200); margin-bottom: 1.25rem;">
        <nav class="flex gap-4" id="content-tabs">
            <button class="bo-tab active" data-tab="subjects">Matieres</button>
            <button class="bo-tab" data-tab="chapters">Chapitres</button>
            <button class="bo-tab" data-tab="quizzes">Quiz</button>
        </nav>
    </div>

    {# Tab: Subjects #}
    <div class="tab-panel" id="tab-subjects">
        <div class="table-container">
            <table class="bo-table">
                <thead>
                    <tr>
                        <th>Matiere</th>
                        <th>Code</th>
                        <th>Chapitres</th>
                        <th>Cree le</th>
                    </tr>
                </thead>
                <tbody>
                    {% for subject in data.subjects %}
                    <tr>
                        <td class="font-medium">{{ subject.name }}</td>
                        <td><span class="badge badge-neutral">{{ subject.code }}</span></td>
                        <td>{{ subject.chapters }}</td>
                        <td class="text-muted">{{ subject.created_at }}</td>
                    </tr>
                    {% else %}
                    <tr><td colspan="4" class="text-center text-muted" style="padding: 2rem;">Aucune matiere</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# Tab: Chapters #}
    <div class="tab-panel" id="tab-chapters" style="display: none;">
        <div class="table-container">
            <table class="bo-table">
                <thead>
                    <tr>
                        <th>Chapitre</th>
                        <th>Matiere</th>
                        <th>Ordre</th>
                        <th>Cree le</th>
                    </tr>
                </thead>
                <tbody>
                    {% for chapter in data.chapters %}
                    <tr>
                        <td class="font-medium">{{ chapter.title }}</td>
                        <td>{{ chapter.subject }}</td>
                        <td>{{ chapter.order }}</td>
                        <td class="text-muted">{{ chapter.created_at }}</td>
                    </tr>
                    {% else %}
                    <tr><td colspan="4" class="text-center text-muted" style="padding: 2rem;">Aucun chapitre</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# Tab: Quizzes #}
    <div class="tab-panel" id="tab-quizzes" style="display: none;">
        <div class="table-container">
            <table class="bo-table">
                <thead>
                    <tr>
                        <th>Quiz</th>
                        <th>Matiere</th>
                        <th>Difficulte</th>
                        <th>Publie</th>
                        <th>Cree le</th>
                    </tr>
                </thead>
                <tbody>
                    {% for quiz in data.quizzes %}
                    <tr>
                        <td class="font-medium">{{ quiz.title }}</td>
                        <td>{{ quiz.subject }}</td>
                        <td>
                            <span class="badge badge-{{ quiz.difficulty == 'EASY' ? 'success' : (quiz.difficulty == 'HARD' ? 'error' : 'warning') }}">
                                {{ quiz.difficulty|capitalize }}
                            </span>
                        </td>
                        <td>
                            {% if quiz.published %}
                                <span class="bo-status active"><span class="bo-status-dot"></span>Oui</span>
                            {% else %}
                                <span class="bo-status inactive"><span class="bo-status-dot"></span>Non</span>
                            {% endif %}
                        </td>
                        <td class="text-muted">{{ quiz.created_at }}</td>
                    </tr>
                    {% else %}
                    <tr><td colspan="5" class="text-center text-muted" style="padding: 2rem;">Aucun quiz</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endif %}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function () {
    const tabs = document.querySelectorAll('.bo-tab');
    const panels = document.querySelectorAll('.tab-panel');
    tabs.forEach(btn => {
        btn.addEventListener('click', function () {
            tabs.forEach(t => t.classList.remove('active'));
            panels.forEach(p => p.style.display = 'none');
            this.classList.add('active');
            const panel = document.getElementById('tab-' + this.dataset.tab);
            if (panel) panel.style.display = '';
        });
    });
});
</script>
{% endblock %}
