{% extends 'layouts/bo.html.twig' %}

{% block title %}Training - StudySprint BO{% endblock %}
{% block breadcrumb %}Training{% endblock %}

{% block content %}
{% if state == 'empty' %}
    <div class="bo-page-header">
        <h1 class="bo-page-title">Training</h1>
    </div>
    {{ include('components/_empty_state.html.twig', {
        title: 'Aucune donnee de training',
        description: 'Les donnees seront disponibles une fois que des etudiants auront commence des quiz.',
        variant: 'bo'
    }) }}
{% else %}
    <div class="bo-page-header">
        <h1 class="bo-page-title">Training</h1>
    </div>

    {# KPI Stats #}
    <div class="bo-stats-row">
        <div class="bo-stat-item">
            <span class="bo-stat-value">{{ data.stats.total_attempts }}</span>
            <span class="bo-stat-label">Tentatives totales</span>
        </div>
        <div class="bo-stat-item">
            <span class="bo-stat-value" style="color: var(--color-primary);">{{ data.stats.month_attempts }}</span>
            <span class="bo-stat-label">Ce mois</span>
        </div>
        <div class="bo-stat-item">
            <span class="bo-stat-value">{{ data.stats.avg_score }}%</span>
            <span class="bo-stat-label">Score moyen</span>
        </div>
        <div class="bo-stat-item">
            <span class="bo-stat-value" style="color: var(--color-success);">{{ data.stats.pass_rate }}%</span>
            <span class="bo-stat-label">Taux de reussite</span>
        </div>
        <div class="bo-stat-item">
            <span class="bo-stat-value">{{ data.stats.reviews_week }}</span>
            <span class="bo-stat-label">Revisions flashcards (semaine)</span>
        </div>
    </div>

    {# Tabs #}
    <div style="border-bottom: 1px solid var(--color-gray-200); margin-bottom: 1.25rem;">
        <nav class="flex gap-4">
            <button class="bo-tab active" data-tab="top_quizzes">Top Quiz</button>
            <button class="bo-tab" data-tab="recent_attempts">Tentatives recentes</button>
        </nav>
    </div>

    {# Tab: Top Quizzes #}
    <div class="tab-panel" id="tab-top_quizzes">
        <div class="table-container">
            <table class="bo-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Quiz</th>
                        <th>Difficulte</th>
                        <th>Tentatives</th>
                        <th>Score moyen</th>
                    </tr>
                </thead>
                <tbody>
                    {% for quiz in data.top_quizzes %}
                    <tr>
                        <td class="text-muted">{{ loop.index }}</td>
                        <td class="font-medium">{{ quiz.title }}</td>
                        <td>
                            <span class="badge badge-{{ quiz.difficulty == 'EASY' ? 'success' : (quiz.difficulty == 'HARD' ? 'error' : 'warning') }}">
                                {{ quiz.difficulty|capitalize }}
                            </span>
                        </td>
                        <td>{{ quiz.attempts }}</td>
                        <td>
                            <span style="color: {{ quiz.avg_score >= 70 ? 'var(--color-success)' : (quiz.avg_score >= 50 ? 'var(--color-warning)' : 'var(--color-error)') }}; font-weight: 600;">
                                {{ quiz.avg_score }}%
                            </span>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="5" class="text-center text-muted" style="padding: 2rem;">Aucun quiz complete</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# Tab: Recent Attempts #}
    <div class="tab-panel" id="tab-recent_attempts" style="display: none;">
        <div class="table-container">
            <table class="bo-table">
                <thead>
                    <tr>
                        <th>Utilisateur</th>
                        <th>Quiz</th>
                        <th>Score</th>
                        <th>Resultat</th>
                        <th>Duree</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    {% for attempt in data.recent_attempts %}
                    <tr>
                        <td class="font-medium">{{ attempt.user }}</td>
                        <td>{{ attempt.quiz }}</td>
                        <td>{{ attempt.score }}%</td>
                        <td>
                            {% if attempt.passed %}
                                <span class="badge badge-success">Reussi</span>
                            {% else %}
                                <span class="badge badge-error">Echoue</span>
                            {% endif %}
                        </td>
                        <td class="text-muted">{{ attempt.duration }}</td>
                        <td class="text-muted">{{ attempt.date }}</td>
                    </tr>
                    {% else %}
                    <tr><td colspan="6" class="text-center text-muted" style="padding: 2rem;">Aucune tentative</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endif %}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function () {
    const tabs = document.querySelectorAll('.bo-tab');
    const panels = document.querySelectorAll('.tab-panel');
    tabs.forEach(btn => {
        btn.addEventListener('click', function () {
            tabs.forEach(t => t.classList.remove('active'));
            panels.forEach(p => p.style.display = 'none');
            this.classList.add('active');
            const panel = document.getElementById('tab-' + this.dataset.tab);
            if (panel) panel.style.display = '';
        });
    });
});
</script>
{% endblock %}
