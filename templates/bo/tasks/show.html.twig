{% extends 'layouts/bo.html.twig' %}
{% block title %}Tâche #{{ item.id }} - BO{% endblock %}
{% block breadcrumb %}Tâches / {{ item.title }}{% endblock %}
{% block content %}
<div class="bo-page-header">
    <h1 class="bo-page-title">{{ item.title }}</h1>
    <div class="bo-page-actions">
        <a href="{{ path('bo_tasks_edit', {id: item.id}) }}" class="btn btn-secondary">Modifier</a>
        <a href="{{ path('bo_tasks_index') }}" class="btn btn-ghost">Retour</a>
    </div>
</div>
<div class="card"><div class="card-body">
    <dl class="grid grid-2 gap-4">
        <div><dt class="text-muted">ID</dt><dd>{{ item.id }}</dd></div>
        <div><dt class="text-muted">Titre</dt><dd>{{ item.title }}</dd></div>
        <div><dt class="text-muted">Plan</dt><dd>{{ item.plan.title }}</dd></div>
        <div><dt class="text-muted">Type</dt><dd>{{ item.taskType }}</dd></div>
        <div><dt class="text-muted">Statut</dt><dd><span class="badge badge-{{ item.status == 'DONE' ? 'success' : (item.status == 'DOING' ? 'warning' : 'secondary') }}">{{ item.status }}</span></dd></div>
        <div><dt class="text-muted">Priorité</dt><dd>{{ item.priority }}</dd></div>
        <div><dt class="text-muted">Début</dt><dd>{{ item.startAt ? item.startAt|date('d/m/Y H:i') : '-' }}</dd></div>
        <div><dt class="text-muted">Fin</dt><dd>{{ item.endAt ? item.endAt|date('d/m/Y H:i') : '-' }}</dd></div>
        <div class="col-span-2"><dt class="text-muted">Notes</dt><dd>{{ item.notes ?? '-' }}</dd></div>
        <div><dt class="text-muted">Créé le</dt><dd>{{ item.createdAt|date('d/m/Y H:i') }}</dd></div>
    </dl>
</div></div>
{% endblock %}
