{% extends 'layouts/bo.html.twig' %}
{% block title %}Tâches - BO{% endblock %}
{% block breadcrumb %}Tâches{% endblock %}

{% block content %}
<div class="bo-page-header">
    <h1 class="bo-page-title">Tâches</h1>
    <div class="bo-page-actions"><a href="{{ path('bo_tasks_new') }}" class="btn btn-primary">+ Nouvelle</a></div>
</div>
<div class="card mb-4"><div class="card-body">
    <form method="get" class="flex gap-4">
        <input type="text" name="q" value="{{ q }}" placeholder="Rechercher..." class="form-input" style="max-width:300px;">
        <button type="submit" class="btn btn-secondary">Rechercher</button>
    </form>
</div></div>
{% for message in app.flashes('success') %}<div class="alert alert-success mb-4">{{ message }}</div>{% endfor %}
<div class="card"><table class="bo-table">
    <thead><tr>
        <th><a href="?q={{ q }}&sort=id&dir={{ sort == 'id' and dir == 'ASC' ? 'desc' : 'asc' }}">ID</a></th>
        <th><a href="?q={{ q }}&sort=title&dir={{ sort == 'title' and dir == 'ASC' ? 'desc' : 'asc' }}">Titre</a></th>
        <th>Plan</th>
        <th><a href="?q={{ q }}&sort=taskType&dir={{ sort == 'taskType' and dir == 'ASC' ? 'desc' : 'asc' }}">Type</a></th>
        <th><a href="?q={{ q }}&sort=status&dir={{ sort == 'status' and dir == 'ASC' ? 'desc' : 'asc' }}">Statut</a></th>
        <th><a href="?q={{ q }}&sort=priority&dir={{ sort == 'priority' and dir == 'ASC' ? 'desc' : 'asc' }}">Priorité</a></th>
        <th><a href="?q={{ q }}&sort=startAt&dir={{ sort == 'startAt' and dir == 'ASC' ? 'desc' : 'asc' }}">Début</a></th>
        <th>Actions</th>
    </tr></thead>
    <tbody>
        {% for item in items %}<tr>
            <td>{{ item.id }}</td>
            <td>{{ item.title }}</td>
            <td>{{ item.plan.title }}</td>
            <td>{{ item.taskType }}</td>
            <td><span class="badge badge-{{ item.status == 'DONE' ? 'success' : (item.status == 'DOING' ? 'warning' : 'secondary') }}">{{ item.status }}</span></td>
            <td>{{ item.priority }}</td>
            <td>{{ item.startAt ? item.startAt|date('d/m/Y H:i') : '-' }}</td>
            <td>
                <a href="{{ path('bo_tasks_show', {id: item.id}) }}" class="btn btn-ghost btn-sm">Voir</a>
                <a href="{{ path('bo_tasks_edit', {id: item.id}) }}" class="btn btn-ghost btn-sm">Modifier</a>
                <form method="post" action="{{ path('bo_tasks_delete', {id: item.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
                    <button type="submit" class="btn btn-ghost btn-sm text-error">Suppr.</button>
                </form>
            </td>
        </tr>{% else %}<tr><td colspan="8" class="text-center text-muted">Aucune tâche</td></tr>{% endfor %}
    </tbody>
</table>
{% include 'bo/_pagination.html.twig' with {page: page, totalPages: totalPages, total: total, q: q, sort: sort, dir: dir} %}
</div>
{% endblock %}
