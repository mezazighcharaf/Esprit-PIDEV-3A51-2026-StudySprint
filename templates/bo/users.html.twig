{% extends 'layouts/bo.html.twig' %}

{% block title %}Utilisateurs - StudySprint BO{% endblock %}
{% block breadcrumb %}Utilisateurs{% endblock %}

{% block topbar_actions %}
<button class="btn btn-primary btn-sm" data-drawer-open="add-user-drawer">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="8.5" cy="7" r="4"/>
        <line x1="20" y1="8" x2="20" y2="14"/>
        <line x1="23" y1="11" x2="17" y2="11"/>
    </svg>
    Ajouter un utilisateur
</button>
{% endblock %}

{% block content %}
{% if state == 'loading' %}
    {# ─── LOADING STATE ─── #}
    <div class="bo-page-header">
        <h1 class="bo-page-title">Utilisateurs</h1>
    </div>
    <div class="filterbar mb-4">
        <div class="skeleton" style="height: 32px; width: 120px;"></div>
        <div class="skeleton" style="height: 32px; width: 120px;"></div>
    </div>
    {{ include('components/_skeleton.html.twig', { type: 'table', count: 1 }) }}

{% elseif state == 'empty' %}
    {# ─── EMPTY STATE ─── #}
    <div class="bo-page-header">
        <h1 class="bo-page-title">Utilisateurs</h1>
    </div>
    {{ include('components/_empty_state.html.twig', {
        title: 'Aucun utilisateur trouve',
        description: 'Aucun utilisateur ne correspond a vos criteres de recherche.',
        cta_text: 'Reinitialiser les filtres',
        variant: 'bo'
    }) }}

{% else %}
    {# ─── DEFAULT STATE ─── #}
    <div class="bo-page-header">
        <h1 class="bo-page-title">Utilisateurs</h1>
    </div>

    {# Stats Row #}
    <div class="bo-stats-row">
        <div class="bo-stat-item">
            <span class="bo-stat-value">{{ data.stats.total }}</span>
            <span class="bo-stat-label">Total</span>
        </div>
        <div class="bo-stat-item">
            <span class="bo-stat-value" style="color: var(--color-success);">{{ data.stats.active }}</span>
            <span class="bo-stat-label">Actifs</span>
        </div>
        <div class="bo-stat-item">
            <span class="bo-stat-value" style="color: var(--color-gray-400);">{{ data.stats.inactive }}</span>
            <span class="bo-stat-label">Inactifs</span>
        </div>
        <div class="bo-stat-item">
            <span class="bo-stat-value" style="color: var(--color-warning);">{{ data.stats.pending }}</span>
            <span class="bo-stat-label">En attente</span>
        </div>
    </div>

    {# Filterbar #}
    {{ include('components/_filterbar.html.twig', {
        filters: data.filters,
        show_clear: true
    }) }}

    {# Users Table #}
    <div class="table-container">
        <table class="bo-table">
            <thead>
                <tr>
                    <th style="width: 40px;">
                        <input type="checkbox" aria-label="Tout selectionner">
                    </th>
                    <th>Utilisateur</th>
                    <th>Role</th>
                    <th>Statut</th>
                    <th>Groupe</th>
                    <th>Sessions</th>
                    <th>Derniere activite</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for user in data.users %}
                <tr>
                    <td>
                        <input type="checkbox" aria-label="Selectionner {{ user.name }}">
                    </td>
                    <td>
                        <div class="cell-user">
                            <div class="cell-user-avatar">{{ user.initials }}</div>
                            <div class="cell-user-info">
                                <div class="cell-user-name">{{ user.name }}</div>
                                <div class="cell-user-email">{{ user.email }}</div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <span class="badge badge-{{ user.role == 'Admin' ? 'primary' : (user.role == 'Encadrant' ? 'info' : 'neutral') }}">
                            {{ user.role }}
                        </span>
                    </td>
                    <td>
                        {% set status_class = user.status|lower %}
                        {% if status_class == 'actif' %}{% set status_class = 'active' %}{% endif %}
                        {% if status_class == 'inactif' %}{% set status_class = 'inactive' %}{% endif %}
                        {% if status_class == 'en attente' %}{% set status_class = 'pending' %}{% endif %}
                        <span class="bo-status {{ status_class }}">
                            <span class="bo-status-dot"></span>
                            {{ user.status }}
                        </span>
                    </td>
                    <td>{{ user.group }}</td>
                    <td>{{ user.sessions }}</td>
                    <td>{{ user.last_activity }}</td>
                    <td>
                        <div class="dropdown">
                            <button class="bo-actions-btn" data-dropdown-toggle aria-label="Actions">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="1"/>
                                    <circle cx="12" cy="5" r="1"/>
                                    <circle cx="12" cy="19" r="1"/>
                                </svg>
                            </button>
                            <div class="dropdown-menu">
                                <button class="dropdown-item">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                        <circle cx="12" cy="12" r="3"/>
                                    </svg>
                                    Voir le profil
                                </button>
                                <button class="dropdown-item">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                    </svg>
                                    Modifier
                                </button>
                                <button class="dropdown-item">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                        <polyline points="22,6 12,13 2,6"/>
                                    </svg>
                                    Envoyer un email
                                </button>
                                <div class="dropdown-divider"></div>
                                <button class="dropdown-item danger">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10"/>
                                        <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
                                    </svg>
                                    Desactiver
                                </button>
                            </div>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# Pagination #}
    <div class="pagination">
        <button class="pagination-btn" disabled>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
        </button>
        <button class="pagination-btn active">1</button>
        <button class="pagination-btn">2</button>
        <button class="pagination-btn">3</button>
        <button class="pagination-btn">...</button>
        <button class="pagination-btn">12</button>
        <button class="pagination-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </button>
    </div>
{% endif %}
{% endblock %}

{% block drawers %}
{# Drawer: Add User #}
<div class="drawer" id="add-user-drawer">
    <div class="drawer-header">
        <h2 class="drawer-title">Ajouter un utilisateur</h2>
        <button class="drawer-close" data-drawer-close aria-label="Fermer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
    </div>
    <div class="drawer-body">
        <div class="form-group">
            <label class="form-label required">Prenom</label>
            <input type="text" class="form-input" placeholder="Prenom">
        </div>
        <div class="form-group">
            <label class="form-label required">Nom</label>
            <input type="text" class="form-input" placeholder="Nom">
        </div>
        <div class="form-group">
            <label class="form-label required">Email</label>
            <input type="email" class="form-input" placeholder="email@exemple.com">
        </div>
        <div class="form-group">
            <label class="form-label required">Role</label>
            <select class="form-select">
                <option value="">Selectionner un role</option>
                <option value="student">Etudiant</option>
                <option value="mentor">Encadrant</option>
                <option value="admin">Administrateur</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Groupe</label>
            <select class="form-select">
                <option value="">Aucun groupe</option>
                <option value="1">Prepa MPSI</option>
                <option value="2">Terminale S</option>
                <option value="3">Licence 1</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-check">
                <input type="checkbox" checked>
                <span class="form-check-label">Envoyer un email d'invitation</span>
            </label>
        </div>
    </div>
    <div class="drawer-footer">
        <button class="btn btn-secondary" data-drawer-close>Annuler</button>
        <button class="btn btn-primary">Ajouter</button>
    </div>
</div>
{% endblock %}
