{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const roleSelect = document.querySelector('.role-selector-field');
    const studentFields = document.getElementById('student-only-fields');
    const professorFields = document.getElementById('professor-only-fields');
    const commonProfileFields = document.getElementById('common-profile-fields');

    function toggleFields() {
        const role = roleSelect.value;
        
        if (role === 'ROLE_STUDENT') {
            commonProfileFields.style.display = 'block';
            studentFields.style.display = 'block';
            professorFields.style.display = 'none';
        } else if (role === 'ROLE_PROFESSOR') {
            commonProfileFields.style.display = 'block';
            studentFields.style.display = 'none';
            professorFields.style.display = 'block';
        } else if (role === 'ROLE_ADMIN') {
            commonProfileFields.style.display = 'block'; // Admin might also need country
            studentFields.style.display = 'none';
            professorFields.style.display = 'none';
        } else {
            commonProfileFields.style.display = 'none';
            studentFields.style.display = 'none';
            professorFields.style.display = 'none';
        }
    }

    if (roleSelect) {
        roleSelect.addEventListener('change', toggleFields);
        toggleFields(); // Initial state
    }

    // Auto-open drawer if there are form errors
    {% if not form.vars.valid %}
        const addUserDrawer = document.getElementById('add-user-drawer');
        const backdrop = document.querySelector('.drawer-backdrop');
        if (addUserDrawer) {
            addUserDrawer.classList.add('open');
            if (backdrop) backdrop.classList.add('open');
            document.body.style.overflow = 'hidden';
            // Also ensure the correct fields are shown based on the current role in the form
            toggleFields();
        }
    {% endif %}

    // Dynamic Country -> School/Level Logic
    const countrySelect = document.querySelector('select[name*="[pays]"]');
    const schoolSelects = document.querySelectorAll('.school-selector-field');
    const levelSelects = document.querySelectorAll('.level-selector-field');

    if (countrySelect && schoolSelects.length > 0) {
        countrySelect.addEventListener('change', function() {
            const countryCode = this.value;
            
            if (!countryCode) {
                schoolSelects.forEach(resetSelect);
                levelSelects.forEach(resetSelect);
                return;
            }

            // Fetch Schools
            fetch(`/api/location/schools/${countryCode}`)
                .then(response => response.json())
                .then(data => {
                    schoolSelects.forEach(select => updateSelect(select, data));
                });

            // Fetch Levels
            fetch(`/api/location/levels/${countryCode}`)
                .then(response => response.json())
                .then(data => {
                    levelSelects.forEach(select => updateSelect(select, data));
                });
        });

        // Trigger on load for existing selection
        if (countrySelect.value) {
            countrySelect.dispatchEvent(new Event('change'));
        }
    }

    function updateSelect(selectElement, items) {
        selectElement.innerHTML = '';
        selectElement.disabled = false;
        
        const placeholder = document.createElement('option');
        placeholder.value = '';
        placeholder.text = 'Choisir...';
        selectElement.appendChild(placeholder);

        items.forEach(item => {
            const option = document.createElement('option');
            option.value = item;
            option.text = item;
            selectElement.appendChild(option);
        });
    }

    function resetSelect(selectElement) {
        selectElement.innerHTML = '<option value="">Choisir un pays d\'abord</option>';
        selectElement.disabled = true;
    }
});
    // Modern Confirmation Modal
    function showConfirmModal(form, action, userName, isDanger = false) {
        const modal = document.getElementById('confirmModal');
        const title = document.getElementById('modalTitle');
        const message = document.getElementById('modalMessage');
        const confirmBtn = document.getElementById('modalConfirmBtn');
        
        // Set content
        if (action === 'supprimer') {
            title.textContent = 'Confirmer la suppression';
            message.innerHTML = `Êtes-vous sûr de vouloir supprimer l'utilisateur <strong>${userName}</strong> ?<br><span style="color: #dc2626; font-size: 0.9rem; margin-top: 0.5rem; display: inline-block;">⚠️ Cette action est irréversible.</span>`;
            confirmBtn.textContent = 'Supprimer';
            confirmBtn.className = 'modal-btn modal-btn-danger';
        } else {
            title.textContent = `Confirmer ${action === 'activer' ? 'l\'activation' : 'la désactivation'}`;
            message.innerHTML = `Voulez-vous ${action} l'utilisateur <strong>${userName}</strong> ?`;
            confirmBtn.textContent = action === 'activer' ? 'Activer' : 'Désactiver';
            confirmBtn.className = 'modal-btn modal-btn-primary';
        }
        
        // Show modal
        modal.style.display = 'flex';
        setTimeout(() => modal.classList.add('show'), 10);
        
        // Handle confirm
        confirmBtn.onclick = () => {
            closeConfirmModal();
            form.submit();
        };
    }
    
    function closeConfirmModal() {
        const modal = document.getElementById('confirmModal');
        modal.classList.remove('show');
        setTimeout(() => modal.style.display = 'none', 300);
    }
    
    // Close on outside click
    document.addEventListener('click', (e) => {
        if (e.target.id === 'confirmModal') {
            closeConfirmModal();
        }
    });

    /** Re-initialize dropdown menus using event delegation (more robust for AJAX content) */
    function initializeDropdowns() {
        // We use delegation on the document or tableBody to avoid re-attaching listeners
        // But since we want to handle the specific behavior of closing others, 
        // a central listener is best.
    }

    // Single click listener for all dropdown toggles (Event Delegation)
    document.addEventListener('click', (e) => {
        const toggleBtn = e.target.closest('[data-dropdown-toggle]');
        if (toggleBtn) {
            e.preventDefault();
            e.stopPropagation();
            
            const menu = toggleBtn.nextElementSibling;
            const isActive = menu.classList.contains('active');
            
            // Close all other menus
            document.querySelectorAll('.dropdown-menu.active').forEach(m => {
                if (m !== menu) m.classList.remove('active');
            });
            
            menu.classList.toggle('active');
            return;
        }

        // Close dropdowns when clicking outside
        if (!e.target.closest('.dropdown-menu')) {
            document.querySelectorAll('.dropdown-menu.active').forEach(menu => {
                menu.classList.remove('active');
            });
        }
    });

    // Initial call
    initializeDropdowns();

    // Real-Time Search with Debouncing
    let searchTimeout;
    let currentPage    = {{ pagination.page }};
    let currentPerPage = {{ pagination.perPage }};

    const searchInput     = document.getElementById('search-input');
    const roleFilter      = document.getElementById('filter-role');
    const statusFilter    = document.getElementById('filter-status');
    const sortFilter      = document.getElementById('filter-sort');
    const directionFilter = document.getElementById('filter-direction');
    const tableBody       = document.getElementById('users-table-body');
    const loadingIndicator = document.getElementById('search-loading');
    const perPageSelect   = document.getElementById('per-page-select');
    const paginationBar   = document.getElementById('pagination-bar');
    const paginationInfo  = document.getElementById('pagination-info');

    function performSearch(page = 1) {
        currentPage = page;
        const query     = searchInput?.value.trim() ?? '';
        const role      = roleFilter?.value ?? '';
        const status    = statusFilter?.value ?? '';
        const sort      = sortFilter?.value ?? '';
        const direction = directionFilter?.value ?? '';

        // Show loading indicator
        loadingIndicator.style.display = 'block';
        tableBody.style.opacity = '0.5';

        // Build query string
        const params = new URLSearchParams();
        if (query)     params.append('q', query);
        if (role)      params.append('role', role);
        if (status)    params.append('status', status);
        if (sort)      params.append('sort', sort);
        if (direction) params.append('direction', direction);
        params.append('page',    currentPage);
        params.append('perPage', currentPerPage);

        // Fetch results
        fetch(`/admin/utilisateurs/search?${params.toString()}`)
            .then(response => {
                if (!response.ok) throw new Error('Erreur réseau');
                return response.json();
            })
            .then(data => {
                // Update table
                tableBody.innerHTML = data.html;

                // Hide loading
                loadingIndicator.style.display = 'none';
                tableBody.style.opacity = '1';

                // Update state
                currentPage    = data.page;
                currentPerPage = data.perPage;

                // Update pagination UI
                updatePaginationUI(data);

                // Re-initialize dropdowns for new rows
                initializeDropdowns();
            })
            .catch(error => {
                console.error('Search error:', error);
                loadingIndicator.style.display = 'none';
                tableBody.style.opacity = '1';

                // Show error message
                tableBody.innerHTML = `
                    <tr>
                        <td colspan="9" class="text-center p-4" style="color: #dc2626;">
                            ⚠️ Erreur lors de la recherche. Veuillez réessayer.
                        </td>
                    </tr>
                `;
            });
    }

    /** Rebuild the pagination bar + info text from AJAX response data */
    function updatePaginationUI(data) {
        const { total, pages, page, perPage } = data;

        // Info text
        if (paginationInfo) {
            if (total === 0) {
                paginationInfo.innerHTML = 'Aucun utilisateur trouvé';
            } else {
                const from = (page - 1) * perPage + 1;
                const to   = Math.min(page * perPage, total);
                paginationInfo.innerHTML = `Affichage de <strong>${from}–${to}</strong> sur <strong>${total}</strong> utilisateur(s)`;
            }
        }

        // Rebuild pagination buttons
        if (!paginationBar) return;
        paginationBar.innerHTML = '';

        const mkBtn = (label, targetPage, isActive = false, isDisabled = false, isSvg = false) => {
            const btn = document.createElement('button');
            btn.className = 'pagination-btn' + (isActive ? ' active' : '');
            btn.disabled  = isDisabled;
            btn.dataset.page = targetPage;
            btn.setAttribute('aria-label', isSvg ? label : `Page ${targetPage}`);
            btn.innerHTML = isSvg ? label : label;
            if (!isDisabled) {
                btn.addEventListener('click', () => performSearch(targetPage));
            }
            return btn;
        };

        const prevSvg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>';
        const nextSvg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>';

        // Previous
        paginationBar.appendChild(mkBtn(prevSvg, page - 1, false, page <= 1, true));

        // Page numbers with ellipsis
        const addEllipsis = () => {
            const span = document.createElement('span');
            span.className = 'pagination-ellipsis';
            span.textContent = '…';
            paginationBar.appendChild(span);
        };

        if (pages <= 7) {
            for (let i = 1; i <= pages; i++) {
                paginationBar.appendChild(mkBtn(i, i, i === page));
            }
        } else {
            paginationBar.appendChild(mkBtn(1, 1, page === 1));
            if (page > 3) addEllipsis();
            const start = Math.max(2, page - 1);
            const end   = Math.min(pages - 1, page + 1);
            for (let i = start; i <= end; i++) {
                paginationBar.appendChild(mkBtn(i, i, i === page));
            }
            if (page < pages - 2) addEllipsis();
            paginationBar.appendChild(mkBtn(pages, pages, page === pages));
        }

        // Next
        paginationBar.appendChild(mkBtn(nextSvg, page + 1, false, page >= pages, true));
    }


    // Debounced search on input
    searchInput?.addEventListener('input', () => {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(performSearch, 400);
    });

    directionFilter?.addEventListener('change', performSearch);

    // Per-page selector
    perPageSelect?.addEventListener('change', (e) => {
        currentPerPage = parseInt(e.target.value);
        performSearch(1); // Reset to page 1 on per-page change
    });

    // Initial pagination buttons (rendered via Twig)
    document.querySelectorAll('#pagination-bar .pagination-btn:not([disabled])').forEach(btn => {
        btn.addEventListener('click', () => {
            performSearch(parseInt(btn.dataset.page));
        });
    });

    // Keyboard Navigation (← / →)
    document.addEventListener('keydown', (e) => {
        // Ignore if focus is in an input/textarea
        const tag = e.target.tagName.toLowerCase();
        if (tag === 'input' || tag === 'textarea' || e.target.isContentEditable) return;

        if (e.key === 'ArrowLeft') {
            if (currentPage > 1) {
                performSearch(currentPage - 1);
            }
        } else if (e.key === 'ArrowRight') {
            // Check against data-pages attribute or similar if needed, 
            // but we can just let performSearch handle the limit via API
            // Or better: find the Next button and click it if not disabled
            const nextBtn = document.querySelector('.pagination-next:not([disabled])');
            if (nextBtn) {
                performSearch(currentPage + 1);
            }
        }
    });

    // ─────────────────────────────────────────────────────────────
    // BULK ACTIONS
    // ─────────────────────────────────────────────────────────────
    const bulkToolbar      = document.getElementById('bulk-toolbar');
    const bulkCountBadge   = document.getElementById('bulk-count-badge');
    const selectAllCb      = document.getElementById('select-all-checkbox');
    const btnActivate      = document.getElementById('bulk-btn-activate');
    const btnDeactivate    = document.getElementById('bulk-btn-deactivate');
    const btnDelete        = document.getElementById('bulk-btn-delete');
    const btnCsv           = document.getElementById('bulk-btn-csv');
    const btnPdf           = document.getElementById('bulk-btn-pdf');
    const btnDeselect      = document.getElementById('bulk-btn-deselect');
    const bulkCsrfToken    = '{{ csrf_token("bulk_action") }}';

    /** Return all currently checked row checkboxes */
    function getChecked() {
        return [...document.querySelectorAll('.user-row-checkbox:checked')];
    }

    /** Return all row checkboxes */
    function getAllRowCbs() {
        return [...document.querySelectorAll('.user-row-checkbox')];
    }

    /** Update toolbar visibility and count badge */
    function updateBulkToolbar() {
        const checked = getChecked();
        const count   = checked.length;

        if (count > 0) {
            bulkToolbar.classList.add('visible');
            bulkCountBadge.textContent = `${count} sélectionné(s)`;
        } else {
            bulkToolbar.classList.remove('visible');
        }

        // Sync select-all checkbox state
        const all = getAllRowCbs();
        if (selectAllCb) {
            selectAllCb.indeterminate = count > 0 && count < all.length;
            selectAllCb.checked       = all.length > 0 && count === all.length;
        }

        // Highlight selected rows
        document.querySelectorAll('.user-row-checkbox').forEach(cb => {
            cb.closest('tr')?.classList.toggle('row-selected', cb.checked);
        });
    }

    /** Attach change listeners to all row checkboxes */
    function attachRowCheckboxListeners() {
        getAllRowCbs().forEach(cb => {
            cb.removeEventListener('change', updateBulkToolbar);
            cb.addEventListener('change', updateBulkToolbar);
        });
    }

    // Select-all toggle
    selectAllCb?.addEventListener('change', function () {
        getAllRowCbs().forEach(cb => { cb.checked = this.checked; });
        updateBulkToolbar();
    });

    // Deselect all button
    btnDeselect?.addEventListener('click', function () {
        if (selectAllCb) selectAllCb.checked = false;
        getAllRowCbs().forEach(cb => { cb.checked = false; });
        updateBulkToolbar();
    });

    // Initial attachment
    attachRowCheckboxListeners();

    // Re-attach after AJAX search updates the table
    const _origPerformSearch = performSearch;
    // Patch: after tableBody is updated, re-attach listeners
    const _observer = new MutationObserver(() => {
        attachRowCheckboxListeners();
        updateBulkToolbar();
    });
    if (tableBody) {
        _observer.observe(tableBody, { childList: true });
    }

    /** Perform bulk activate or deactivate */
    function doBulkStatusChange(action) {
        const ids = getChecked().map(cb => cb.value);
        if (ids.length === 0) return;

        let label = 'agir';
        let isDanger = false;

        if (action === 'activate') {
            label = 'activer';
        } else if (action === 'deactivate') {
            label = 'désactiver';
            isDanger = true;
        } else if (action === 'delete') {
            label = 'supprimer';
            isDanger = true;
        }

        const count = ids.length;

        showConfirmModal(
            null,
            label,
            `${count} utilisateur(s)`,
            isDanger
        );

        // Override the confirm button to do the AJAX call
        const confirmBtn = document.getElementById('modalConfirmBtn');
        confirmBtn.onclick = () => {
            closeConfirmModal();

            const formData = new FormData();
            formData.append('_token', bulkCsrfToken);
            formData.append('action', action);
            ids.forEach(id => formData.append('ids[]', id));

            fetch('/admin/utilisateurs/bulk-action', {
                method: 'POST',
                body: formData,
            })
            .then(async r => {
                const contentType = r.headers.get('content-type');
                if (!r.ok) {
                    if (contentType && contentType.includes('application/json')) {
                        const data = await r.json();
                        throw new Error(data.message || `Erreur serveur (${r.status})`);
                    }
                    const text = await r.text();
                    throw new Error(text.substring(0, 100) || `Erreur serveur (${r.status})`);
                }
                return r.json();
            })
            .then(data => {
                if (data.success) {
                    showBulkFlash('success', data.message);
                    performSearch();
                    if (selectAllCb) selectAllCb.checked = false;
                    updateBulkToolbar();
                } else {
                    showBulkFlash('error', data.message || 'Une erreur est survenue.');
                }
            })
            .catch(err => {
                console.error('Bulk action error:', err);
                // Display the specific error message if it's not too technical/long
                const msg = err.message.length < 200 ? err.message : 'Une erreur est survenue lors de l\'opération.';
                showBulkFlash('error', msg);
            });
        };
    }

    btnActivate?.addEventListener('click',   () => doBulkStatusChange('activate'));
    btnDeactivate?.addEventListener('click', () => doBulkStatusChange('deactivate'));
    btnDelete?.addEventListener('click',     () => doBulkStatusChange('delete'));

    /** Build export URL with selected IDs */
    function buildExportUrl(base) {
        const ids = getChecked().map(cb => cb.value);
        if (ids.length === 0) return base;
        const params = new URLSearchParams();
        ids.forEach(id => params.append('ids[]', id));
        return `${base}?${params.toString()}`;
    }

    btnCsv?.addEventListener('click', () => {
        window.location.href = buildExportUrl('/admin/utilisateurs/export/csv');
    });

    btnPdf?.addEventListener('click', () => {
        window.location.href = buildExportUrl('/admin/utilisateurs/export/pdf');
    });

    /** Temporary flash notification for bulk actions */
    function showBulkFlash(type, message) {
        const existing = document.getElementById('bulk-flash');
        if (existing) existing.remove();

        const el = document.createElement('div');
        el.id = 'bulk-flash';
        el.style.cssText = `
            position: fixed; top: 24px; right: 24px; z-index: 99999;
            padding: 14px 24px; border-radius: 14px; font-weight: 700;
            font-size: 0.9rem; box-shadow: 0 8px 30px rgba(0,0,0,0.15);
            animation: slideDown 0.3s ease; max-width: 400px;
            ${type === 'success'
                ? 'background: #f0fdf4; color: #166534; border: 1.5px solid #bbf7d0;'
                : 'background: #fff1f2; color: #be123c; border: 1.5px solid #fecdd3;'}
        `;
        el.textContent = (type === 'success' ? '✅ ' : '❌ ') + message;
        document.body.appendChild(el);
        setTimeout(() => el.remove(), 4000);
    }

</script>
{% endblock %}
