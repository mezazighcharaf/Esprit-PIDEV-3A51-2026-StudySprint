{% extends 'layouts/bo.html.twig' %}

{% block title %}Utilisateurs - StudySprint BO{% endblock %}
{% block breadcrumb %}Utilisateurs{% endblock %}

{% block topbar_actions %}
<a href="{{ path('bo_users_new') }}" class="btn btn-primary btn-sm">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="8.5" cy="7" r="4"/>
        <line x1="20" y1="8" x2="20" y2="14"/>
        <line x1="23" y1="11" x2="17" y2="11"/>
    </svg>
    Ajouter un utilisateur
</a>
<a href="{{ path('bo_users_export') }}" class="btn btn-secondary btn-sm">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="7 10 12 15 17 10"/>
        <line x1="12" y1="15" x2="12" y2="3"/>
    </svg>
    Exporter CSV
</a>
{% endblock %}

{% block content %}
{% if state == 'empty' %}
    <div class="bo-page-header">
        <h1 class="bo-page-title">Utilisateurs</h1>
    </div>
    {{ include('components/_empty_state.html.twig', {
        title: 'Aucun utilisateur trouve',
        description: 'Aucun utilisateur ne correspond a vos criteres de recherche.',
        cta_text: 'Reinitialiser les filtres',
        variant: 'bo'
    }) }}
{% else %}
    {# ─── DEFAULT STATE ─── #}
    <div class="bo-page-header">
        <h1 class="bo-page-title">Utilisateurs</h1>
    </div>

    {# Stats Row #}
    <div class="bo-stats-row">
        <div class="bo-stat-item">
            <span class="bo-stat-value">{{ data.stats.total }}</span>
            <span class="bo-stat-label">Total</span>
        </div>
        <div class="bo-stat-item">
            <span class="bo-stat-value" style="color: var(--color-primary);">{{ data.stats.students }}</span>
            <span class="bo-stat-label">Etudiants</span>
        </div>
        <div class="bo-stat-item">
            <span class="bo-stat-value" style="color: var(--color-info);">{{ data.stats.teachers }}</span>
            <span class="bo-stat-label">Enseignants</span>
        </div>
        <div class="bo-stat-item">
            <span class="bo-stat-value" style="color: var(--color-warning);">{{ data.stats.admins }}</span>
            <span class="bo-stat-label">Admins</span>
        </div>
        <div class="bo-stat-item">
            <span class="bo-stat-value" style="color: var(--color-success);">{{ data.stats.new_month }}</span>
            <span class="bo-stat-label">Nouveaux ce mois</span>
        </div>
    </div>

    {# Search bar #}
    <form method="get" class="filterbar mb-4">
        <input type="text" name="q" value="{{ data.q }}" class="form-input" placeholder="Rechercher par nom ou email..." style="flex: 1; max-width: 320px;">
        <input type="hidden" name="sort" value="{{ data.sort }}">
        <input type="hidden" name="dir" value="{{ data.dir }}">
        <button type="submit" class="btn btn-secondary btn-sm">Rechercher</button>
        {% if data.q %}
            <a href="{{ path('admin_users') }}" class="btn btn-ghost btn-sm">Reinitialiser</a>
        {% endif %}
    </form>

    {# Users Table #}
    <div class="table-container">
        <table class="bo-table">
            <thead>
                <tr>
                    <th>
                        <a href="{{ path('admin_users', {q: data.q, sort: 'fullName', dir: data.sort == 'fullName' and data.dir == 'ASC' ? 'DESC' : 'ASC', page: 1}) }}" style="text-decoration: none; color: inherit;">
                            Utilisateur {% if data.sort == 'fullName' %}{{ data.dir == 'ASC' ? '↑' : '↓' }}{% endif %}
                        </a>
                    </th>
                    <th>
                        <a href="{{ path('admin_users', {q: data.q, sort: 'userType', dir: data.sort == 'userType' and data.dir == 'ASC' ? 'DESC' : 'ASC', page: 1}) }}" style="text-decoration: none; color: inherit;">
                            Type {% if data.sort == 'userType' %}{{ data.dir == 'ASC' ? '↑' : '↓' }}{% endif %}
                        </a>
                    </th>
                    <th>Role</th>
                    <th>
                        <a href="{{ path('admin_users', {q: data.q, sort: 'createdAt', dir: data.sort == 'createdAt' and data.dir == 'ASC' ? 'DESC' : 'ASC', page: 1}) }}" style="text-decoration: none; color: inherit;">
                            Inscrit le {% if data.sort == 'createdAt' %}{{ data.dir == 'ASC' ? '↑' : '↓' }}{% endif %}
                        </a>
                    </th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for user in data.users %}
                <tr>
                    <td>
                        <div class="cell-user">
                            <div class="cell-user-avatar">{{ user.initials }}</div>
                            <div class="cell-user-info">
                                <div class="cell-user-name">{{ user.name }}</div>
                                <div class="cell-user-email">{{ user.email }}</div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <span class="badge badge-{{ user.type == 'STUDENT' ? 'neutral' : (user.type == 'TEACHER' ? 'info' : 'warning') }}">
                            {{ user.type|capitalize }}
                        </span>
                    </td>
                    <td>
                        {% if user.is_admin %}
                            <span class="badge badge-primary">Admin</span>
                        {% else %}
                            <span class="text-muted text-sm">—</span>
                        {% endif %}
                    </td>
                    <td class="text-muted">{{ user.created_at }}</td>
                    <td>
                        <div class="flex gap-2">
                            <a href="{{ path('bo_users_show', {id: user.id}) }}" class="btn btn-ghost btn-sm">Voir</a>
                            <a href="{{ path('bo_users_edit', {id: user.id}) }}" class="btn btn-ghost btn-sm">Modifier</a>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# Pagination #}
    {% if data.total_pages > 1 %}
    <div class="pagination">
        {% if data.page > 1 %}
        <a href="{{ path('admin_users', {q: data.q, sort: data.sort, dir: data.dir, page: data.page - 1}) }}" class="pagination-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        </a>
        {% else %}
        <button class="pagination-btn" disabled>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        {% endif %}

        {% for p in 1..data.total_pages %}
            {% if p == data.page %}
                <button class="pagination-btn active">{{ p }}</button>
            {% elseif p == 1 or p == data.total_pages or (p >= data.page - 2 and p <= data.page + 2) %}
                <a href="{{ path('admin_users', {q: data.q, sort: data.sort, dir: data.dir, page: p}) }}" class="pagination-btn">{{ p }}</a>
            {% elseif p == data.page - 3 or p == data.page + 3 %}
                <span class="pagination-btn" style="cursor: default;">…</span>
            {% endif %}
        {% endfor %}

        {% if data.page < data.total_pages %}
        <a href="{{ path('admin_users', {q: data.q, sort: data.sort, dir: data.dir, page: data.page + 1}) }}" class="pagination-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
        {% else %}
        <button class="pagination-btn" disabled>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
        {% endif %}
    </div>
    {% endif %}
{% endif %}
{% endblock %}
