{% extends 'layouts/bo.html.twig' %}
{% block title %}Chapitres - BO{% endblock %}
{% block breadcrumb %}Chapitres{% endblock %}

{% block content %}
<div class="bo-page-header">
    <h1 class="bo-page-title">Chapitres</h1>
    <div class="bo-page-actions"><a href="{{ path('bo_chapters_new') }}" class="btn btn-primary">+ Nouveau</a></div>
</div>
<div class="card mb-4"><div class="card-body">
    <form method="get" class="flex gap-4">
        <input type="text" name="q" value="{{ q }}" placeholder="Rechercher..." class="form-input" style="max-width:300px;">
        <button type="submit" class="btn btn-secondary">Rechercher</button>
    </form>
</div></div>
{% for message in app.flashes('success') %}<div class="alert alert-success mb-4">{{ message }}</div>{% endfor %}
<div class="card"><table class="bo-table">
    <thead><tr>
        <th><a href="?q={{ q }}&sort=id&dir={{ sort == 'id' and dir == 'ASC' ? 'desc' : 'asc' }}">ID</a></th>
        <th><a href="?q={{ q }}&sort=title&dir={{ sort == 'title' and dir == 'ASC' ? 'desc' : 'asc' }}">Titre</a></th>
        <th>Matière</th>
        <th><a href="?q={{ q }}&sort=orderNo&dir={{ sort == 'orderNo' and dir == 'ASC' ? 'desc' : 'asc' }}">Ordre</a></th>
        <th><a href="?q={{ q }}&sort=createdAt&dir={{ sort == 'createdAt' and dir == 'ASC' ? 'desc' : 'asc' }}">Créé le</a></th>
        <th>Actions</th>
    </tr></thead>
    <tbody>
        {% for item in items %}<tr>
            <td>{{ item.id }}</td>
            <td>{{ item.title }}</td>
            <td>{{ item.subject.name }}</td>
            <td>{{ item.orderNo }}</td>
            <td>{{ item.createdAt|date('d/m/Y') }}</td>
            <td class="flex items-center gap-1 flex-wrap">
                <form method="post" action="{{ path('bo_chapters_up', {id: item.id}) }}" style="display:inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('move' ~ item.id) }}">
                    <button type="submit" class="btn btn-ghost btn-sm" title="Monter">↑</button>
                </form>
                <form method="post" action="{{ path('bo_chapters_down', {id: item.id}) }}" style="display:inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('move' ~ item.id) }}">
                    <button type="submit" class="btn btn-ghost btn-sm" title="Descendre">↓</button>
                </form>
                <a href="{{ path('bo_chapters_show', {id: item.id}) }}" class="btn btn-ghost btn-sm">Voir</a>
                <a href="{{ path('bo_chapters_edit', {id: item.id}) }}" class="btn btn-ghost btn-sm">Modifier</a>
                <form method="post" action="{{ path('bo_chapters_delete', {id: item.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
                    <button type="submit" class="btn btn-ghost btn-sm text-error">Suppr.</button>
                </form>
            </td>
        </tr>{% else %}<tr><td colspan="6" class="text-center text-muted">Aucun chapitre</td></tr>{% endfor %}
    </tbody>
</table>
{% include 'bo/_pagination.html.twig' with {page: page, totalPages: totalPages, total: total, q: q, sort: sort, dir: dir} %}
</div>
{% endblock %}
