{% extends 'layouts/bo.html.twig' %}
{% block title %}Chapitre #{{ item.id }} - BO{% endblock %}
{% block breadcrumb %}Chapitres / {{ item.title }}{% endblock %}
{% block content %}
<div class="bo-page-header">
    <h1 class="bo-page-title">{{ item.title }}</h1>
    <div class="bo-page-actions">
        <form method="post" action="{{ path('bo_chapters_ai_summarize', {id: item.id}) }}" style="display: inline;">
            <input type="hidden" name="_token" value="{{ csrf_token('ai_summarize' ~ item.id) }}">
            <button type="submit" class="btn" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none;">
                <svg style="width: 16px; height: 16px; margin-right: 0.375rem; display: inline-block; vertical-align: middle;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
                Générer résumé & tags (IA)
            </button>
        </form>
        <a href="{{ path('bo_chapters_edit', {id: item.id}) }}" class="btn btn-secondary">Modifier</a>
        <a href="{{ path('bo_chapters_index') }}" class="btn btn-ghost">Retour</a>
    </div>
</div>
<div class="card"><div class="card-body">
    <dl class="grid grid-2 gap-4">
        <div><dt class="text-muted">ID</dt><dd>{{ item.id }}</dd></div>
        <div><dt class="text-muted">Titre</dt><dd>{{ item.title }}</dd></div>
        <div><dt class="text-muted">Matière</dt><dd>{{ item.subject.name }}</dd></div>
        <div><dt class="text-muted">Ordre</dt><dd>{{ item.orderNo }}</dd></div>
        <div><dt class="text-muted">Résumé</dt><dd>{{ item.summary ?? '-' }}</dd></div>
        <div><dt class="text-muted">Créé le</dt><dd>{{ item.createdAt|date('d/m/Y H:i') }}</dd></div>
    </dl>
</div></div>

{% if item.aiSummary or item.aiKeyPoints or item.aiTags %}
<div class="card" style="margin-top: 1.5rem; border-left: 4px solid #667eea;">
    <div class="card-body">
        <h3 style="font-size: 16px; font-weight: 600; margin: 0 0 1rem 0; display: flex; align-items: center; gap: 0.5rem;">
            <svg style="width: 20px; height: 20px; color: #667eea;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
            Analyse IA
        </h3>
        
        {% if item.aiSummary %}
        <div style="margin-bottom: 1.5rem;">
            <dt class="text-muted" style="font-weight: 600; margin-bottom: 0.5rem;">Résumé IA</dt>
            <dd style="background: #f9fafb; padding: 1rem; border-radius: 8px; line-height: 1.6;">{{ item.aiSummary }}</dd>
        </div>
        {% endif %}

        {% if item.aiKeyPoints %}
        <div style="margin-bottom: 1.5rem;">
            <dt class="text-muted" style="font-weight: 600; margin-bottom: 0.5rem;">Points clés</dt>
            <dd>
                <ul style="list-style: none; padding: 0; margin: 0;">
                    {% for point in item.aiKeyPoints %}
                    <li style="padding: 0.5rem 0; border-bottom: 1px solid #e5e7eb; display: flex; align-items: start; gap: 0.5rem;">
                        <svg style="width: 16px; height: 16px; color: #10b981; flex-shrink: 0; margin-top: 2px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <span>{{ point }}</span>
                    </li>
                    {% endfor %}
                </ul>
            </dd>
        </div>
        {% endif %}

        {% if item.aiTags %}
        <div>
            <dt class="text-muted" style="font-weight: 600; margin-bottom: 0.5rem;">Tags</dt>
            <dd style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
                {% for tag in item.aiTags %}
                <span class="badge badge-primary" style="font-size: 12px; padding: 0.375rem 0.75rem;">{{ tag }}</span>
                {% endfor %}
            </dd>
        </div>
        {% endif %}
    </div>
</div>
{% endif %}
{% endblock %}
