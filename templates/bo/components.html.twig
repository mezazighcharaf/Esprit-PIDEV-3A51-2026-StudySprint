{% extends 'layouts/bo.html.twig' %}

{% block title %}BO Components - StudySprint{% endblock %}
{% block breadcrumb %}BO Components{% endblock %}

{% block content %}
<div class="bo-page-header">
    <h1 class="bo-page-title">BO Components</h1>
    <p class="text-muted">Reference des composants UI du Back-Office</p>
</div>

<div class="bo-components-grid">
    {# Buttons #}
    <div class="bo-component-section">
        <h3 class="bo-component-title">Boutons</h3>
        <div class="bo-component-label">Variantes</div>
        <div class="bo-component-row">
            <button class="btn btn-primary">Primary</button>
            <button class="btn btn-secondary">Secondary</button>
            <button class="btn btn-ghost">Ghost</button>
            <button class="btn btn-danger">Danger</button>
        </div>
        <div class="bo-component-label mt-4">Tailles</div>
        <div class="bo-component-row">
            <button class="btn btn-primary btn-sm">Small</button>
            <button class="btn btn-primary">Default</button>
            <button class="btn btn-primary btn-lg">Large</button>
        </div>
        <div class="bo-component-label mt-4">Avec icone</div>
        <div class="bo-component-row">
            <button class="btn btn-primary">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <line x1="12" y1="5" x2="12" y2="19"/>
                    <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
                Ajouter
            </button>
            <button class="btn btn-secondary">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                    <polyline points="7 10 12 15 17 10"/>
                    <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                Exporter
            </button>
            <button class="btn btn-icon btn-ghost">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="1"/>
                    <circle cx="12" cy="5" r="1"/>
                    <circle cx="12" cy="19" r="1"/>
                </svg>
            </button>
        </div>
    </div>

    {# Badges #}
    <div class="bo-component-section">
        <h3 class="bo-component-title">Badges</h3>
        <div class="bo-component-label">Variantes</div>
        <div class="bo-component-row">
            <span class="badge badge-neutral">Neutral</span>
            <span class="badge badge-primary">Primary</span>
            <span class="badge badge-success">Success</span>
            <span class="badge badge-warning">Warning</span>
            <span class="badge badge-error">Error</span>
            <span class="badge badge-info">Info</span>
        </div>
        <div class="bo-component-label mt-4">Status dots</div>
        <div class="bo-component-row">
            <span class="bo-status active"><span class="bo-status-dot"></span> Actif</span>
            <span class="bo-status inactive"><span class="bo-status-dot"></span> Inactif</span>
            <span class="bo-status pending"><span class="bo-status-dot"></span> En attente</span>
            <span class="bo-status blocked"><span class="bo-status-dot"></span> Bloque</span>
        </div>
    </div>

    {# Drawer #}
    <div class="bo-component-section">
        <h3 class="bo-component-title">Drawer</h3>
        <p class="text-sm text-muted mb-3">Panneau lateral pour formulaires et details</p>
        <button class="btn btn-secondary" data-drawer-open="demo-drawer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <line x1="9" y1="3" x2="9" y2="21"/>
            </svg>
            Ouvrir le drawer
        </button>
    </div>

    {# Typeset #}
    <div class="bo-component-section">
        <h3 class="bo-component-title">Typeset</h3>
        <div class="bo-component-row" style="flex-direction: column; align-items: flex-start; gap: 8px;">
            <span style="font-size: var(--text-xs);">Text XS (11px)</span>
            <span style="font-size: var(--text-sm);">Text SM (13px)</span>
            <span style="font-size: var(--text-base);">Text Base (14px)</span>
            <span style="font-size: var(--text-lg);">Text LG (16px)</span>
            <span style="font-size: var(--text-xl);">Text XL (18px)</span>
            <span style="font-size: var(--text-2xl); font-weight: 600;">Text 2XL (20px)</span>
        </div>
    </div>

    {# Table #}
    <div class="bo-component-section" style="grid-column: span 2;">
        <h3 class="bo-component-title">Table (mode insertion de contenu via une)</h3>
        <div class="table-container">
            <table class="bo-table">
                <thead>
                    <tr>
                        <th>Colonne</th>
                        <th>Type</th>
                        <th>Statut</th>
                        <th>Valeur</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="font-medium">Element 1</td>
                        <td><span class="badge badge-neutral">Type A</span></td>
                        <td><span class="bo-status active"><span class="bo-status-dot"></span> Actif</span></td>
                        <td>1 234</td>
                        <td>
                            <button class="bo-actions-btn">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="1"/>
                                    <circle cx="12" cy="5" r="1"/>
                                    <circle cx="12" cy="19" r="1"/>
                                </svg>
                            </button>
                        </td>
                    </tr>
                    <tr>
                        <td class="font-medium">Element 2</td>
                        <td><span class="badge badge-info">Type B</span></td>
                        <td><span class="bo-status pending"><span class="bo-status-dot"></span> En attente</span></td>
                        <td>567</td>
                        <td>
                            <button class="bo-actions-btn">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="1"/>
                                    <circle cx="12" cy="5" r="1"/>
                                    <circle cx="12" cy="19" r="1"/>
                                </svg>
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    {# Toast #}
    <div class="bo-component-section">
        <h3 class="bo-component-title">Toast</h3>
        <p class="text-sm text-muted mb-3">Notifications temporaires</p>
        <div class="bo-component-row">
            <button class="btn btn-secondary btn-sm" onclick="StudySprint.Toast.success('Succes', 'Operation effectuee avec succes.')">Success</button>
            <button class="btn btn-secondary btn-sm" onclick="StudySprint.Toast.error('Erreur', 'Une erreur est survenue.')">Error</button>
            <button class="btn btn-secondary btn-sm" onclick="StudySprint.Toast.warning('Attention', 'Verifiez les informations.')">Warning</button>
            <button class="btn btn-secondary btn-sm" onclick="StudySprint.Toast.info('Information', 'Nouvelle mise a jour disponible.')">Info</button>
        </div>
    </div>

    {# Section leader #}
    <div class="bo-component-section">
        <h3 class="bo-component-title">Section leader</h3>
        <div class="bo-section-leader">
            <div class="bo-section-leader-title">Titre de section</div>
            <div class="bo-section-leader-value">Description ou valeur principale de la section.</div>
            <a href="#" class="bo-section-leader-link">Voir plus de details</a>
        </div>
    </div>
</div>
{% endblock %}

{% block drawers %}
{# Demo Drawer #}
<div class="drawer" id="demo-drawer">
    <div class="drawer-header">
        <h2 class="drawer-title">Drawer de demonstration</h2>
        <button class="drawer-close" data-drawer-close aria-label="Fermer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
    </div>
    <div class="drawer-body">
        <div class="form-group">
            <label class="form-label required">Champ texte</label>
            <input type="text" class="form-input" placeholder="Entrez une valeur">
        </div>
        <div class="form-group">
            <label class="form-label">Select</label>
            <select class="form-select">
                <option>Option 1</option>
                <option>Option 2</option>
                <option>Option 3</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Textarea</label>
            <textarea class="form-textarea" placeholder="Entrez du texte..."></textarea>
        </div>
        <div class="form-group">
            <label class="form-check">
                <input type="checkbox">
                <span class="form-check-label">Option checkbox</span>
            </label>
        </div>
    </div>
    <div class="drawer-footer">
        <button class="btn btn-secondary" data-drawer-close>Annuler</button>
        <button class="btn btn-primary">Enregistrer</button>
    </div>
</div>
{% endblock %}
