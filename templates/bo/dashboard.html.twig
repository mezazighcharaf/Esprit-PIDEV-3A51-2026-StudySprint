{% extends 'layouts/bo.html.twig' %}

{% block title %}Dashboard - StudySprint BO{% endblock %}
{% block breadcrumb %}Dashboard{% endblock %}

{% block content %}
{% if state == 'loading' %}
    {# ─── LOADING STATE ─── #}
    <div class="bo-page-header">
        <h1 class="bo-page-title">Dashboard</h1>
    </div>
    <div class="bo-kpi-row">
        {% for i in 1..5 %}
        <div class="bo-kpi-card">
            <div class="skeleton" style="height: 14px; width: 80px; margin-bottom: 8px;"></div>
            <div class="skeleton" style="height: 28px; width: 60px; margin-bottom: 8px;"></div>
            <div class="skeleton" style="height: 12px; width: 100px;"></div>
        </div>
        {% endfor %}
    </div>
    <div class="grid grid-2 gap-6 mt-6">
        {{ include('components/_skeleton.html.twig', { type: 'table', count: 1 }) }}
        {{ include('components/_skeleton.html.twig', { type: 'card', count: 1 }) }}
    </div>

{% else %}
    {# ─── DEFAULT STATE ─── #}
    <div class="bo-page-header">
        <h1 class="bo-page-title">Dashboard</h1>
        <div class="bo-page-actions">
        </div>
    </div>

    {# KPIs Row #}
    <div class="bo-kpi-row">
        <div class="bo-kpi-card">
            <div class="bo-kpi-header">
                <span class="bo-kpi-label">Utilisateurs</span>
            </div>
            <div class="bo-kpi-value">{{ user_kpis.total_non_admins }}</div>
            <div class="bo-kpi-subtitle">Communauté totale</div>
        </div>

        <div class="bo-kpi-card">
            <div class="bo-kpi-header">
                <span class="bo-kpi-label">Etudiants</span>
            </div>
            <div class="bo-kpi-value text-primary">{{ user_kpis.students }}</div>
            <div class="bo-kpi-subtitle">Apprenants inscrits</div>
        </div>

        <div class="bo-kpi-card">
            <div class="bo-kpi-header">
                <span class="bo-kpi-label">Professeurs</span>
            </div>
            <div class="bo-kpi-value" style="color: var(--color-secondary);">{{ user_kpis.professors }}</div>
            <div class="bo-kpi-subtitle">Enseignants actifs</div>
        </div>

        <div class="bo-kpi-card">
            <div class="bo-kpi-header">
                <span class="bo-kpi-label">Actifs</span>
            </div>
            <div class="bo-kpi-value text-success">{{ user_kpis.active }}</div>
            <div class="bo-kpi-subtitle">En ligne / Actifs</div>
        </div>

        <div class="bo-kpi-card">
            <div class="bo-kpi-header">
                <span class="bo-kpi-label">Inactifs</span>
            </div>
            <div class="bo-kpi-value text-muted">{{ user_kpis.inactive }}</div>
            <div class="bo-kpi-subtitle">Comptes désactivés</div>
        </div>
    </div>

    {# Alerts #}
    {% if data.alerts|length > 0 %}
    <div class="mb-6">
        {% for alert in data.alerts %}
        <div class="card mb-2" style="border-left: 3px solid var(--color-{{ alert.type }});">
            <div class="card-body py-3">
                <div class="flex items-center gap-3">
                    {% if alert.type == 'warning' %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="var(--color-warning)" stroke-width="2" width="18" height="18">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                        <line x1="12" y1="9" x2="12" y2="13"/>
                        <line x1="12" y1="17" x2="12.01" y2="17"/>
                    </svg>
                    {% else %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="var(--color-info)" stroke-width="2" width="18" height="18">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="16" x2="12" y2="12"/>
                        <line x1="12" y1="8" x2="12.01" y2="8"/>
                    </svg>
                    {% endif %}
                    <span class="text-sm">{{ alert.message }}</span>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}

    {# Content Grid #}
    <div class="grid grid-2 gap-6">
        {# Recent Users #}
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Utilisateurs recents</h3>
                <a href="{{ path('admin_users') }}" class="btn btn-ghost btn-sm">Voir tous</a>
            </div>
            <table class="bo-table">
                <thead>
                    <tr>
                        <th>Utilisateur</th>
                        <th>Role</th>
                        <th>Statut</th>
                        <th>Activite</th>
                    </tr>
                </thead>
                <tbody>
                <tbody>
                    {% for user in recent_users %}
                    <tr>
                        <td>
                            <div class="cell-user">
                                <div class="cell-user-avatar" style="background-color: var(--color-primary); color: white; display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 50%; font-size: 0.8rem; font-weight: 600;">
                                    {{ user.prenom|first|upper }}{{ user.nom|first|upper }}
                                </div>
                                <div class="cell-user-info">
                                    <div class="cell-user-name">{{ user.prenom }} {{ user.nom }}</div>
                                    <div class="cell-user-email">{{ user.email }}</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            {% if user.role == 'student' or 'ROLE_STUDENT' in user.roles %}
                                <span class="badge" style="background:#dbeafe; color:#1e40af; padding:2px 8px; border-radius:12px; font-size:0.75rem;">Étudiant</span>
                            {% elseif user.role == 'professor' or 'ROLE_PROFESSOR' in user.roles %}
                                <span class="badge" style="background:#d1fae5; color:#065f46; padding:2px 8px; border-radius:12px; font-size:0.75rem;">Professeur</span>
                            {% elseif 'ROLE_ADMIN' in user.roles %}
                                <span class="badge" style="background:#fce7f3; color:#9d174d; padding:2px 8px; border-radius:12px; font-size:0.75rem;">Admin</span>
                            {% else %}
                                {{ user.role }}
                            {% endif %}
                        </td>
                        <td>
                            <span class="bo-status {{ user.statut|default('actif')|lower == 'actif' ? 'active' : 'inactive' }}">
                                <span class="bo-status-dot"></span>
                                {{ user.statut|default('actif') }}
                            </span>
                        </td>
                        <td class="text-muted">{{ user.dateInscription|date('d/m/Y') }}</td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="4" class="text-center p-4">Aucun utilisateur trouvé.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {# Quick Actions #}
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Actions rapides</h3>
            </div>
            <div class="card-body">
                <div class="flex flex-col gap-3">
                    <a href="{{ path('admin_users') }}" class="btn btn-secondary" style="width: 100%; justify-content: flex-start;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                            <circle cx="8.5" cy="7" r="4"/>
                            <line x1="20" y1="8" x2="20" y2="14"/>
                            <line x1="23" y1="11" x2="17" y2="11"/>
                        </svg>
                        Ajouter un utilisateur
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endif %}
{% endblock %}
