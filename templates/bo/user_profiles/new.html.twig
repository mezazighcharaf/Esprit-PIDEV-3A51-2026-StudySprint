{% extends 'layouts/bo.html.twig' %}
{% block title %}Nouveau Profil - BO{% endblock %}
{% block breadcrumb %}Profils / Nouveau{% endblock %}
{% block content %}
<div class="bo-page-header"><h1 class="bo-page-title">Nouveau Profil Utilisateur</h1></div>
<div class="card"><div class="card-body">
    {{ form_start(form) }}
    {% for field in form %}{% if field.vars.name != '_token' %}<div class="form-group">{{ form_label(field) }}{{ form_widget(field, {'attr': {'class': field.vars.block_prefixes[1] == 'textarea' ? 'form-textarea' : (field.vars.block_prefixes[1] == 'choice' or field.vars.block_prefixes[1] == 'entity' ? 'form-select' : 'form-input')}}) }}{{ form_errors(field) }}</div>{% endif %}{% endfor %}
    <div class="flex gap-4 mt-6"><button type="submit" class="btn btn-primary">Créer</button><a href="{{ path('bo_user_profiles_index') }}" class="btn btn-secondary">Annuler</a></div>
    {{ form_end(form) }}
</div></div>
{% endblock %}
