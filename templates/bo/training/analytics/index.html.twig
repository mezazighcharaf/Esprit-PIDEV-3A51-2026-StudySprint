{% extends 'layouts/bo.html.twig' %}

{% block title %}Analytics Training - Administration{% endblock %}
{% block breadcrumb %}Training > Analytics{% endblock %}

{% block content %}
<div class="page-header">
    <h1>Analytics Training</h1>
    <p class="text-muted">Statistiques d'utilisation des quiz et flashcards</p>
</div>

<div class="card mb-4">
    <div class="card-body">
        {{ form_start(form, {'attr': {'class': 'form-inline'}}) }}
            <div class="form-row align-items-end">
                <div class="form-group col-md-3">
                    {{ form_label(form.period) }}
                    {{ form_widget(form.period, {'attr': {'class': 'form-control'}}) }}
                </div>
                <div class="form-group col-md-3">
                    {{ form_label(form.startDate) }}
                    {{ form_widget(form.startDate, {'attr': {'class': 'form-control'}}) }}
                </div>
                <div class="form-group col-md-3">
                    {{ form_label(form.endDate) }}
                    {{ form_widget(form.endDate, {'attr': {'class': 'form-control'}}) }}
                </div>
                <div class="form-group col-md-3">
                    <button type="submit" class="btn btn-primary">Filtrer</button>
                </div>
            </div>
        {{ form_end(form) }}
    </div>
</div>

<div class="kpi-grid">
    {{ include('components/_kpi_card.html.twig', {
        label: 'Temps total etudie',
        value: analytics.totals.hours ~ 'h',
        subtitle: analytics.period.start ~ ' - ' ~ analytics.period.end
    }) }}
    {{ include('components/_kpi_card.html.twig', {
        label: 'Quiz completes',
        value: analytics.totals.quizzes,
        subtitle: 'sur la periode'
    }) }}
    {{ include('components/_kpi_card.html.twig', {
        label: 'Cartes revisees',
        value: analytics.totals.cards,
        subtitle: 'flashcards'
    }) }}
    {{ include('components/_kpi_card.html.twig', {
        label: 'Score moyen',
        value: analytics.totals.avg_score ? analytics.totals.avg_score ~ '%' : '-',
        subtitle: 'moyenne des quiz'
    }) }}
    {{ include('components/_kpi_card.html.twig', {
        label: 'Utilisateurs actifs',
        value: analytics.totals.active_users,
        subtitle: 'sur la periode'
    }) }}
</div>

{% if analytics.daily %}
<div class="card mt-4">
    <div class="card-header">
        <h3>Activite quotidienne</h3>
    </div>
    <div class="card-body">
        <table class="table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Minutes</th>
                    <th>Quiz</th>
                    <th>Cartes</th>
                    <th>Utilisateurs</th>
                </tr>
            </thead>
            <tbody>
                {% for date, data in analytics.daily %}
                <tr>
                    <td>{{ date }}</td>
                    <td>{{ data.minutes }}</td>
                    <td>{{ data.quizzes }}</td>
                    <td>{{ data.cards }}</td>
                    <td>{{ data.users }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

<style>
.kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
}
.form-inline .form-row { width: 100%; }
</style>
{% endblock %}
