{% extends 'layouts/bo.html.twig' %}

{% block title %}Nouveau Quiz - Administration{% endblock %}
{% block breadcrumb %}Training > Quiz > Nouveau{% endblock %}

{% block content %}
<div class="page-header">
    <h1>Creer un nouveau Quiz</h1>
    <p class="text-muted">Definissez les parametres de base du quiz</p>
</div>

<div class="card">
    <div class="card-body">
        {{ form_start(form, {'attr': {'class': 'form'}}) }}
            <div class="form-group">
                {{ form_label(form.title) }}
                {{ form_widget(form.title, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.title) }}
            </div>

            <div class="form-group">
                {{ form_label(form.difficulty) }}
                {{ form_widget(form.difficulty, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.difficulty) }}
            </div>

            <div class="form-actions">
                <a href="{{ path('admin_training_quiz_index') }}" class="btn btn-secondary">Annuler</a>
                <button type="submit" class="btn btn-primary">Creer le Quiz</button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
