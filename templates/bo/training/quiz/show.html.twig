{% extends 'layouts/bo.html.twig' %}

{% block title %}{{ quiz.title }} - Administration{% endblock %}
{% block breadcrumb %}Training > Quiz > {{ quiz.title }}{% endblock %}

{% block topbar_actions %}
<a href="{{ path('admin_training_quiz_edit', {id: quiz.id}) }}" class="btn btn-secondary btn-sm">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
    </svg>
    Modifier
</a>
<a href="{{ path('admin_training_question_new', {quizId: quiz.id}) }}" class="btn btn-primary btn-sm">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
        <line x1="12" y1="5" x2="12" y2="19"/>
        <line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    Ajouter une Question
</a>
{% endblock %}

{% block content %}
<div class="page-header">
    <h1>{{ quiz.title }}</h1>
    <div class="page-meta">
        {% if quiz.difficulty == 'easy' %}
            <span class="badge badge-success">Facile</span>
        {% elseif quiz.difficulty == 'med' %}
            <span class="badge badge-warning">Moyen</span>
        {% else %}
            <span class="badge badge-danger">Difficile</span>
        {% endif %}
        <span class="text-muted">{{ quiz.questions|length }} questions | {{ quiz.totalPoints }} points</span>
    </div>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success">{{ message }}</div>
{% endfor %}

<div class="card">
    <div class="card-header">
        <h3>Questions</h3>
    </div>
    <div class="card-body">
        {% if quiz.questions is empty %}
            {{ include('components/_empty_state.html.twig', {
                icon: 'question',
                title: 'Aucune question',
                description: 'Ajoutez des questions a ce quiz.',
                action_label: 'Ajouter une question',
                action_url: path('admin_training_question_new', {quizId: quiz.id})
            }) }}
        {% else %}
            <div class="questions-list">
                {% for question in quiz.questions %}
                <div class="question-item card mb-3">
                    <div class="card-header">
                        <div class="question-header">
                            <span class="question-number">#{{ question.position }}</span>
                            <span class="question-type badge badge-secondary">
                                {% if question.questionType == 'mcq' %}QCM{% elseif question.questionType == 'tf' %}V/F{% else %}Courte{% endif %}
                            </span>
                            <span class="question-points">{{ question.points }} pt{% if question.points > 1 %}s{% endif %}</span>
                        </div>
                        <div class="question-actions">
                            <a href="{{ path('admin_training_choice_new', {questionId: question.id}) }}" class="btn btn-sm btn-secondary" title="Ajouter un choix">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                                    <line x1="12" y1="5" x2="12" y2="19"/>
                                    <line x1="5" y1="12" x2="19" y2="12"/>
                                </svg>
                            </a>
                            <a href="{{ path('admin_training_question_edit', {id: question.id}) }}" class="btn btn-sm btn-secondary" title="Modifier">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                </svg>
                            </a>
                            <form action="{{ path('admin_training_question_delete', {id: question.id}) }}" method="post" style="display:inline;" onsubmit="return confirm('Supprimer cette question ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ question.id) }}">
                                <button type="submit" class="btn btn-sm btn-danger" title="Supprimer">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                                        <polyline points="3 6 5 6 21 6"/>
                                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    </div>
                    <div class="card-body">
                        <p class="question-text">{{ question.questionText }}</p>

                        {% if question.choices is not empty %}
                        <ul class="choices-list">
                            {% for choice in question.choices %}
                            <li class="choice-item {% if choice.isCorrect %}choice-correct{% endif %}">
                                <span class="choice-label">{{ choice.label }}</span>
                                {% if choice.isCorrect %}
                                    <span class="badge badge-success">Correct</span>
                                {% endif %}
                                <div class="choice-actions">
                                    <a href="{{ path('admin_training_choice_edit', {id: choice.id}) }}" class="btn btn-xs btn-secondary">Modifier</a>
                                    <form action="{{ path('admin_training_choice_delete', {id: choice.id}) }}" method="post" style="display:inline;" onsubmit="return confirm('Supprimer ce choix ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ choice.id) }}">
                                        <button type="submit" class="btn btn-xs btn-danger">Supprimer</button>
                                    </form>
                                </div>
                            </li>
                            {% endfor %}
                        </ul>
                        {% else %}
                        <p class="text-muted">Aucun choix de reponse</p>
                        {% endif %}
                    </div>
                </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>

<style>
.question-item { border: 1px solid var(--border-color); }
.question-header { display: flex; align-items: center; gap: 0.5rem; }
.question-actions { display: flex; gap: 0.25rem; margin-left: auto; }
.question-number { font-weight: 600; color: var(--primary); }
.question-text { font-size: 1rem; margin-bottom: 1rem; }
.choices-list { list-style: none; padding: 0; margin: 0; }
.choice-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem;
    border-radius: 4px;
    margin-bottom: 0.25rem;
    background: var(--bg-secondary);
}
.choice-item.choice-correct { background: rgba(34, 197, 94, 0.1); }
.choice-actions { margin-left: auto; display: flex; gap: 0.25rem; }
.btn-xs { padding: 0.125rem 0.5rem; font-size: 0.75rem; }
</style>
{% endblock %}
