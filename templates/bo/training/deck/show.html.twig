{% extends 'layouts/bo.html.twig' %}

{% block title %}{{ deck.title }} - Administration{% endblock %}
{% block breadcrumb %}Training > Decks > {{ deck.title }}{% endblock %}

{% block topbar_actions %}
<a href="{{ path('bo_decks_edit', {id: deck.id}) }}" class="btn btn-secondary btn-sm">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
    </svg>
    Modifier
</a>
{% endblock %}

{% block content %}
<div class="page-header">
    <h1>{{ deck.title }}</h1>
    <div class="page-meta">
        <span class="text-muted">{{ deck.flashcards|length }} flashcards</span>
    </div>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success">{{ message }}</div>
{% endfor %}

<div class="card">
    <div class="card-header">
        <h3>Flashcards</h3>
    </div>
    <div class="card-body">
        {% if deck.flashcards is empty %}
            <div style="text-align: center; padding: 3rem;">
                <p style="color: #6b7280; margin-bottom: 1rem;">Aucune flashcard dans ce deck.</p>
                <p style="color: #9ca3af; font-size: 14px;">Gérez les flashcards depuis le Front Office.</p>
            </div>
        {% else %}
            <div class="flashcards-grid">
                {% for flashcard in deck.flashcards %}
                <div class="flashcard-item card">
                    <div class="card-header">
                        <span class="flashcard-position">#{{ flashcard.position + 1 }}</span>
                    </div>
                    <div class="card-body">
                        <div class="flashcard-front">
                            <strong>Recto:</strong>
                            <p>{{ flashcard.front }}</p>
                        </div>
                        <hr>
                        <div class="flashcard-back">
                            <strong>Verso:</strong>
                            <p>{{ flashcard.back }}</p>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>

<style>
.flashcards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
}
.flashcard-item { border: 1px solid var(--border-color); }
.flashcard-position { font-weight: 600; color: var(--primary); }
.flashcard-actions { display: flex; gap: 0.25rem; margin-left: auto; }
.flashcard-front, .flashcard-back { margin-bottom: 0.5rem; }
.flashcard-front p, .flashcard-back p { margin: 0.25rem 0 0 0; color: var(--text-secondary); }
</style>
{% endblock %}
