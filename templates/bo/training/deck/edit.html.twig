{% extends 'layouts/bo.html.twig' %}

{% block title %}Modifier Deck - Administration{% endblock %}
{% block breadcrumb %}Training > Decks > Modifier{% endblock %}

{% block content %}
<div class="page-header">
    <h1>Modifier le Deck</h1>
    <p class="text-muted">{{ deck.title }}</p>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success">{{ message }}</div>
{% endfor %}

<div class="card">
    <div class="card-body">
        {{ form_start(form, {'attr': {'class': 'form'}}) }}
            <div class="form-group">
                {{ form_label(form.title) }}
                {{ form_widget(form.title, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.title) }}
            </div>

            <div class="form-actions">
                <a href="{{ path('bo_decks_show', {id: deck.id}) }}" class="btn btn-secondary">Annuler</a>
                <button type="submit" class="btn btn-primary">Enregistrer</button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
