{% extends 'layouts/bo.html.twig' %}

{% block title %}Decks - Administration{% endblock %}
{% block breadcrumb %}Training > Decks{% endblock %}

{% block topbar_actions %}
<a href="{{ path('bo_decks_new') }}" class="btn btn-primary btn-sm">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
        <line x1="12" y1="5" x2="12" y2="19"/>
        <line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    Nouveau Deck
</a>
{% endblock %}

{% block content %}
<div class="page-header">
    <h1>Gestion des Decks de Flashcards</h1>
    <p class="text-muted">Creer et gerer les decks de revision</p>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="alert alert-danger">{{ message }}</div>
{% endfor %}

<div class="card">
    <div class="card-header">
        <h3>Liste des Decks ({{ decks|length }})</h3>
    </div>
    <div class="card-body">
        {% if decks is empty %}
            {{ include('components/_empty_state.html.twig', {
                icon: 'cards',
                title: 'Aucun deck',
                description: 'Commencez par creer votre premier deck de flashcards.',
                action_label: 'Creer un deck',
                action_url: path('bo_decks_new')
            }) }}
        {% else %}
            <table class="table">
                <thead>
                    <tr>
                        <th>Titre</th>
                        <th>Flashcards</th>
                        <th>Proprietaire</th>
                        <th>Cree le</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for deck in decks %}
                    <tr>
                        <td>
                            <a href="{{ path('bo_decks_show', {id: deck.id}) }}" class="link-primary">
                                {{ deck.title }}
                            </a>
                        </td>
                        <td>{{ deck.flashcards|length }}</td>
                        <td>{{ deck.owner.email }}</td>
                        <td>{{ deck.createdAt|date('d/m/Y') }}</td>
                        <td>
                            <div class="btn-group">
                                <a href="{{ path('bo_decks_show', {id: deck.id}) }}" class="btn btn-sm btn-secondary" title="Voir">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                        <circle cx="12" cy="12" r="3"/>
                                    </svg>
                                </a>
                                <a href="{{ path('bo_decks_edit', {id: deck.id}) }}" class="btn btn-sm btn-secondary" title="Modifier">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                    </svg>
                                </a>
                                <form action="{{ path('bo_decks_delete', {id: deck.id}) }}" method="post" style="display:inline;" onsubmit="return confirm('Supprimer ce deck ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ deck.id) }}">
                                    <button type="submit" class="btn btn-sm btn-danger" title="Supprimer">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                                            <polyline points="3 6 5 6 21 6"/>
                                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            {% include 'bo/_pagination.html.twig' with {page: page, totalPages: totalPages, total: total, q: q, sort: sort, dir: dir} %}
        {% endif %}
    </div>
</div>
{% endblock %}
