{% extends 'layouts/bo.html.twig' %}
{% block title %}Plan #{{ item.id }} - BO{% endblock %}
{% block breadcrumb %}Plans / {{ item.title }}{% endblock %}

{% block content %}
{% set totalTasks = item.tasks|length %}
{% set doneTasks = item.tasks|filter(t => t.status == 'DONE')|length %}
{% set completionRate = totalTasks > 0 ? ((doneTasks / totalTasks) * 100)|round : 0 %}

<div class="bo-page-header">
    <h1 class="bo-page-title">{{ item.title }}</h1>
    <div class="bo-page-actions" style="display: flex; gap: 0.5rem;">
        <form method="post" action="{{ path('bo_planning_generate_tasks', {id: item.id}) }}" style="display: inline;" onsubmit="return confirm('Generer des taches automatiquement pour ce plan ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('bo_generate_tasks_' ~ item.id) }}">
            <button type="submit" class="btn btn-secondary">Magic Breakdown</button>
        </form>
        <a href="{{ path('bo_plans_edit', {id: item.id}) }}" class="btn btn-secondary">Modifier</a>
        <a href="{{ path('bo_plans_index') }}" class="btn btn-ghost">Retour</a>
    </div>
</div>

{% for message in app.flashes('success') %}<div class="alert alert-success mb-4">{{ message }}</div>{% endfor %}
{% for message in app.flashes('warning') %}<div class="alert mb-4" style="background: #fffbeb; border: 1px solid #fde68a; color: #92400e;">{{ message }}</div>{% endfor %}
{% for message in app.flashes('error') %}<div class="alert mb-4" style="background: #fef2f2; border: 1px solid #fecaca; color: #991b1b;">{{ message }}</div>{% endfor %}

<div class="card mb-4"><div class="card-body">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
        <span class="text-muted">Avancement des taches</span>
        <strong>{{ doneTasks }} / {{ totalTasks }} ({{ completionRate }}%)</strong>
    </div>
    <div style="height: 10px; background: #f3f4f6; border-radius: 999px; overflow: hidden;">
        <div style="height: 100%; width: {{ completionRate }}%; background: linear-gradient(90deg, #6366f1, #8b5cf6);"></div>
    </div>
</div></div>

<div class="card"><div class="card-body">
    <dl class="grid grid-2 gap-4">
        <div><dt class="text-muted">ID</dt><dd>{{ item.id }}</dd></div>
        <div><dt class="text-muted">Titre</dt><dd>{{ item.title }}</dd></div>
        <div><dt class="text-muted">Utilisateur</dt><dd>{{ item.user.email }}</dd></div>
        <div><dt class="text-muted">Matiere</dt><dd>{{ item.subject ? item.subject.name : '-' }}</dd></div>
        <div><dt class="text-muted">Chapitre</dt><dd>{{ item.chapter ? item.chapter.title : '-' }}</dd></div>
        <div><dt class="text-muted">Statut</dt><dd><span class="badge badge-{{ item.status == 'ACTIVE' ? 'success' : (item.status == 'DONE' ? 'info' : 'secondary') }}">{{ item.status }}</span></dd></div>
        <div><dt class="text-muted">Date debut</dt><dd>{{ item.startDate ? item.startDate|date('d/m/Y') : '-' }}</dd></div>
        <div><dt class="text-muted">Date fin</dt><dd>{{ item.endDate ? item.endDate|date('d/m/Y') : '-' }}</dd></div>
        <div><dt class="text-muted">Genere par IA</dt><dd>{{ item.generatedByAi ? 'Oui' : 'Non' }}</dd></div>
        <div><dt class="text-muted">Cree le</dt><dd>{{ item.createdAt|date('d/m/Y H:i') }}</dd></div>
    </dl>
</div></div>
{% endblock %}

