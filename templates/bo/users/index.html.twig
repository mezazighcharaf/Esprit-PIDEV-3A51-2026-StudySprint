{% extends 'layouts/bo.html.twig' %}

{% block title %}Utilisateurs - BO{% endblock %}
{% block breadcrumb %}Utilisateurs{% endblock %}

{% block content %}
<div class="bo-page-header">
    <h1 class="bo-page-title">Utilisateurs</h1>
    <div class="bo-page-actions">
        <a href="{{ path('bo_users_new') }}" class="btn btn-primary">+ Nouveau</a>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="flex gap-4">
            <input type="text" name="q" value="{{ q }}" placeholder="Rechercher..." class="form-input" style="max-width:300px;">
            <button type="submit" class="btn btn-secondary">Rechercher</button>
        </form>
    </div>
</div>

{% for message in app.flashes('success') %}
<div class="alert alert-success mb-4">{{ message }}</div>
{% endfor %}

<div class="card">
    <table class="bo-table">
        <thead>
            <tr>
                <th><a href="?q={{ q }}&sort=id&dir={{ sort == 'id' and dir == 'ASC' ? 'desc' : 'asc' }}">ID</a></th>
                <th><a href="?q={{ q }}&sort=email&dir={{ sort == 'email' and dir == 'ASC' ? 'desc' : 'asc' }}">Email</a></th>
                <th><a href="?q={{ q }}&sort=fullName&dir={{ sort == 'fullName' and dir == 'ASC' ? 'desc' : 'asc' }}">Nom</a></th>
                <th><a href="?q={{ q }}&sort=userType&dir={{ sort == 'userType' and dir == 'ASC' ? 'desc' : 'asc' }}">Type</a></th>
                <th><a href="?q={{ q }}&sort=createdAt&dir={{ sort == 'createdAt' and dir == 'ASC' ? 'desc' : 'asc' }}">Créé le</a></th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for user in users %}
            <tr>
                <td>{{ user.id }}</td>
                <td>{{ user.email }}</td>
                <td>{{ user.fullName }}</td>
                <td><span class="badge">{{ user.userType }}</span></td>
                <td>{{ user.createdAt|date('d/m/Y H:i') }}</td>
                <td>
                    <a href="{{ path('bo_users_show', {id: user.id}) }}" class="btn btn-ghost btn-sm">Voir</a>
                    <a href="{{ path('bo_users_edit', {id: user.id}) }}" class="btn btn-ghost btn-sm">Modifier</a>
                    <form method="post" action="{{ path('bo_users_delete', {id: user.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                        <button type="submit" class="btn btn-ghost btn-sm text-error">Suppr.</button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="6" class="text-center text-muted">Aucun utilisateur</td></tr>
            {% endfor %}
        </tbody>
    </table>
    {% include 'bo/_pagination.html.twig' with {page: page, totalPages: totalPages, total: total, q: q, sort: sort, dir: dir} %}
</div>
{% endblock %}
