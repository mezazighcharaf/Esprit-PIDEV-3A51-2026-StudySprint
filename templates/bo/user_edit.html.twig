{% extends 'layouts/bo.html.twig' %}

{% block title %}Modifier l'utilisateur - StudySprint{% endblock %}

{% block content %}
    <div class="bo-page-header">
        <div style="display: flex; align-items: center; gap: 1rem;">
            <a href="{{ path('admin_users') }}" class="bo-back-btn" title="Retour">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 12H5M12 19l-7-7 7-7"/>
                </svg>
            </a>
            <div>
                <h1 class="bo-page-title">Modifier l'utilisateur</h1>
                <p class="bo-page-subtitle">{{ user.prenom }} {{ user.nom }} ({{ user.email }})</p>
            </div>
        </div>
    </div>

    <div class="bo-content">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('danger') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        <div class="bo-card">
            <div class="bo-card-header">
                <h2 class="bo-card-title">Informations de l'utilisateur</h2>
            </div>
            <div class="bo-card-body">
                {{ form_start(form, {'attr': {'class': 'bo-form'}}) }}
                    
                    <div class="form-row">
                        <div class="form-group">
                            {{ form_label(form.prenom) }}
                            {{ form_widget(form.prenom) }}
                            {{ form_errors(form.prenom) }}
                        </div>

                        <div class="form-group">
                            {{ form_label(form.nom) }}
                            {{ form_widget(form.nom) }}
                            {{ form_errors(form.nom) }}
                        </div>
                    </div>

                    <div class="form-group">
                        {{ form_label(form.email) }}
                        {{ form_widget(form.email) }}
                        {{ form_errors(form.email) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(form.telephone) }}
                        {{ form_widget(form.telephone) }}
                        {{ form_errors(form.telephone) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(form.role) }}
                        {{ form_widget(form.role) }}
                        {{ form_errors(form.role) }}
                    </div>

                    <div id="common-profile-fields" class="drawer-subsection" style="display: none;">
                        <h4 class="drawer-subsection-title">👤 Profil & Origine</h4>
                        <div class="form-group">
                            {{ form_label(form.pays) }}
                            {{ form_widget(form.pays) }}
                            {{ form_errors(form.pays) }}
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                {{ form_label(form.age) }}
                                {{ form_widget(form.age) }}
                                {{ form_errors(form.age) }}
                            </div>
                            <div class="form-group">
                                {{ form_label(form.sexe) }}
                                {{ form_widget(form.sexe) }}
                                {{ form_errors(form.sexe) }}
                            </div>
                        </div>
                    </div>

                    <div id="student-only-fields" class="drawer-subsection" style="display: none; border-left: 4px solid var(--color-primary);">
                        <h4 class="drawer-subsection-title" style="color: var(--color-primary);">📚 Informations Étudiant</h4>
                        <div class="form-group">
                            {{ form_label(form.etablissement) }}
                            {{ form_widget(form.etablissement) }}
                        </div>
                        <div class="form-group">
                            {{ form_label(form.niveau) }}
                            {{ form_widget(form.niveau) }}
                        </div>
                    </div>

                    <div id="professor-only-fields" class="drawer-subsection" style="display: none; border-left: 4px solid var(--color-secondary);">
                        <h4 class="drawer-subsection-title" style="color: var(--color-secondary);">🎓 Informations Professeur</h4>
                        <div class="form-group">
                            {{ form_label(form.specialite) }}
                            {{ form_widget(form.specialite) }}
                        </div>
                        <div class="form-group">
                            {{ form_label(form.niveauEnseignement) }}
                            {{ form_widget(form.niveauEnseignement) }}
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                {{ form_label(form.anneesExperience) }}
                                {{ form_widget(form.anneesExperience) }}
                            </div>
                            <div class="form-group">
                                {{ form_label(form.etablissementProfesseur) }}
                                {{ form_widget(form.etablissementProfesseur) }}
                            </div>
                        </div>
                    </div>

                    <div class="drawer-subsection" style="background: #fffbeb; border-color: #fde68a;">
                        <h4 class="drawer-subsection-title" style="color: #92400e;">🔐 Sécurité</h4>
                        <div class="form-group">
                            {{ form_label(form.motDePasse) }}
                            {{ form_widget(form.motDePasse) }}
                            {{ form_errors(form.motDePasse) }}
                            <small style="color: #64748b; font-size: 0.875rem; margin-top: 0.25rem; display: block;">
                                💡 Laissez vide pour conserver le mot de passe actuel
                            </small>
                        </div>
                    </div>

                    <div style="display: flex; gap: 1rem; justify-content: flex-end; margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid #e2e8f0;">
                        <a href="{{ path('admin_users') }}" class="btn btn-secondary">
                            Annuler
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 18px; height: 18px;">
                                <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/>
                                <polyline points="17 21 17 13 7 13 7 21"/>
                                <polyline points="7 3 7 8 15 8"/>
                            </svg>
                            Enregistrer les modifications
                        </button>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>

    <style>
        .bo-back-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            color: #64748b;
            text-decoration: none;
            transition: all 0.2s;
        }
        .bo-back-btn:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
            color: #1e293b;
        }
        .bo-back-btn svg {
            width: 20px;
            height: 20px;
        }
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }
        @media (max-width: 768px) {
            .form-row {
                grid-template-columns: 1fr;
            }
        }
        .alert {
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 1.5rem;
        }
        .alert-success {
            background: #d1fae5;
            color: #065f46;
            border: 1px solid #6ee7b7;
        }
        .alert-danger {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
        }
    </style>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const roleSelect = document.querySelector('.role-selector-field');
    const studentFields = document.getElementById('student-only-fields');
    const professorFields = document.getElementById('professor-only-fields');
    const commonProfileFields = document.getElementById('common-profile-fields');

    function toggleFields() {
        if (!roleSelect) return;
        const role = roleSelect.value;
        
        if (role === 'ROLE_STUDENT') {
            commonProfileFields.style.display = 'block';
            studentFields.style.display = 'block';
            professorFields.style.display = 'none';
        } else if (role === 'ROLE_PROFESSOR') {
            commonProfileFields.style.display = 'block';
            studentFields.style.display = 'none';
            professorFields.style.display = 'block';
        } else if (role === 'ROLE_ADMIN') {
            commonProfileFields.style.display = 'block';
            studentFields.style.display = 'none';
            professorFields.style.display = 'none';
        } else {
            commonProfileFields.style.display = 'none';
            studentFields.style.display = 'none';
            professorFields.style.display = 'none';
        }
    }

    if (roleSelect) {
        roleSelect.addEventListener('change', toggleFields);
        toggleFields(); // Initial state
    }

    // Dynamic Country -> School/Level Logic
    const countrySelect = document.querySelector('select[name*="[pays]"]');
    const schoolSelects = document.querySelectorAll('.school-selector-field');
    const levelSelects = document.querySelectorAll('.level-selector-field');

    if (countrySelect && schoolSelects.length > 0) {
        countrySelect.addEventListener('change', function() {
            const countryCode = this.value;
            
            if (!countryCode) {
                schoolSelects.forEach(resetSelect);
                levelSelects.forEach(resetSelect);
                return;
            }

            // Fetch Schools
            fetch(`/api/location/schools/${countryCode}`)
                .then(response => response.json())
                .then(data => {
                    schoolSelects.forEach(select => updateSelect(select, data));
                });

            // Fetch Levels
            fetch(`/api/location/levels/${countryCode}`)
                .then(response => response.json())
                .then(data => {
                    levelSelects.forEach(select => updateSelect(select, data));
                });
        });

        // Trigger on load for existing selection
        if (countrySelect.value) {
            countrySelect.dispatchEvent(new Event('change'));
        }
    }

    function updateSelect(selectElement, items) {
        const currentValue = selectElement.value;
        selectElement.innerHTML = '';
        selectElement.disabled = false;
        
        const placeholder = document.createElement('option');
        placeholder.value = '';
        placeholder.text = 'Choisir...';
        selectElement.appendChild(placeholder);

        items.forEach(item => {
            const option = document.createElement('option');
            option.value = item;
            option.text = item;
            if (item === currentValue) {
                option.selected = true;
            }
            selectElement.appendChild(option);
        });
    }

    function resetSelect(selectElement) {
        selectElement.innerHTML = '<option value="">Choisir un pays d\'abord</option>';
        selectElement.disabled = true;
    }
});
</script>
{% endblock %}
