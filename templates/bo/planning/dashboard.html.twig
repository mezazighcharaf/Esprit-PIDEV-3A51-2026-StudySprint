{% extends 'layouts/bo.html.twig' %}
{% block title %}Planning Dashboard - BO{% endblock %}
{% block breadcrumb %}Planning Dashboard{% endblock %}

{% block content %}
<div class="bo-page-header">
    <h1 class="bo-page-title">Planning Dashboard</h1>
    <div class="bo-page-actions" style="display: flex; gap: 0.5rem;">
        <a href="{{ path('bo_plans_index') }}" class="btn btn-secondary">Voir les plans</a>
        <a href="{{ path('bo_tasks_index') }}" class="btn btn-secondary">Voir les taches</a>
    </div>
</div>

{% for message in app.flashes('success') %}<div class="alert alert-success mb-4">{{ message }}</div>{% endfor %}
{% for message in app.flashes('warning') %}<div class="alert mb-4" style="background: #fffbeb; border: 1px solid #fde68a; color: #92400e;">{{ message }}</div>{% endfor %}
{% for message in app.flashes('error') %}<div class="alert mb-4" style="background: #fef2f2; border: 1px solid #fecaca; color: #991b1b;">{{ message }}</div>{% endfor %}

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; margin-bottom: 1.5rem;">
    <div class="card">
        <div class="card-body" style="text-align: center;">
            <div style="font-size: 30px; font-weight: 700; color: #6366f1;">{{ activePlans }}</div>
            <div class="text-muted" style="font-size: 13px;">Plans actifs</div>
        </div>
    </div>
    <div class="card">
        <div class="card-body" style="text-align: center;">
            <div style="font-size: 30px; font-weight: 700; color: #0ea5e9;">{{ totalPlans }}</div>
            <div class="text-muted" style="font-size: 13px;">Plans total</div>
        </div>
    </div>
    <div class="card">
        <div class="card-body" style="text-align: center;">
            <div style="font-size: 30px; font-weight: 700; color: #10b981;">{{ doneTasks }} / {{ totalTasks }}</div>
            <div class="text-muted" style="font-size: 13px;">Taches terminees</div>
        </div>
    </div>
    <div class="card">
        <div class="card-body" style="text-align: center;">
            <div style="font-size: 30px; font-weight: 700; color: #f59e0b;">{{ totalMinutes }} min</div>
            <div class="text-muted" style="font-size: 13px;">Temps cumule execute</div>
        </div>
    </div>
    <div class="card">
        <div class="card-body" style="text-align: center;">
            <div style="font-size: 30px; font-weight: 700; color: #8b5cf6;">{{ completionRate }}%</div>
            <div class="text-muted" style="font-size: 13px;">Taux d avancement global</div>
        </div>
    </div>
</div>

<div style="display: grid; grid-template-columns: 1.15fr 1fr; gap: 1rem;">
    <div class="card">
        <div class="card-header">
            <h3>Plans prioritaires</h3>
        </div>
        <div class="card-body">
            {% if urgentPlans is empty %}
                <p class="text-muted">Aucun plan prioritaire.</p>
            {% else %}
                <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                    {% for plan in urgentPlans %}
                        {% set progress = planProgress[plan.id] ?? {done: 0, total: 0} %}
                        {% set rate = progress.total > 0 ? ((progress.done / progress.total) * 100)|round : 0 %}
                        <div style="border: 1px solid #e5e7eb; border-radius: 10px; padding: 0.9rem;">
                            <div style="display: flex; justify-content: space-between; gap: 0.5rem; margin-bottom: 0.5rem; align-items: center;">
                                <div>
                                    <div style="font-weight: 600; font-size: 14px;">{{ plan.title }}</div>
                                    <div class="text-muted" style="font-size: 12px;">{{ plan.user.email }} · Echeance {{ plan.endDate|date('d/m/Y') }}</div>
                                </div>
                                <span class="badge badge-{{ plan.status == 'ACTIVE' ? 'success' : 'secondary' }}">{{ plan.status }}</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.4rem; font-size: 12px;">
                                <span>{{ progress.done }} / {{ progress.total }} terminees</span>
                                <span>{{ rate }}%</span>
                            </div>
                            <div style="height: 8px; background: #f3f4f6; border-radius: 999px; overflow: hidden; margin-bottom: 0.65rem;">
                                <div style="height: 100%; width: {{ rate }}%; background: linear-gradient(90deg, #6366f1, #8b5cf6);"></div>
                            </div>
                            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                                <a href="{{ path('bo_plans_show', {id: plan.id}) }}" class="btn btn-ghost btn-sm">Voir</a>
                                <form method="post" action="{{ path('bo_planning_generate_tasks', {id: plan.id}) }}" onsubmit="return confirm('Generer des taches automatiquement pour ce plan ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('bo_generate_tasks_' ~ plan.id) }}">
                                    <button type="submit" class="btn btn-secondary btn-sm">Magic Breakdown</button>
                                </form>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3>Taches urgentes</h3>
        </div>
        <div class="card-body">
            {% set statusMap = {'TODO': 'A_FAIRE', 'DOING': 'EN_COURS', 'DONE': 'TERMINE'} %}
            {% if urgentTasks is empty %}
                <p class="text-muted">Aucune tache urgente.</p>
            {% else %}
                <table class="bo-table">
                    <thead>
                        <tr>
                            <th>Tache</th>
                            <th>Plan</th>
                            <th>Priorite</th>
                            <th>Statut</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for task in urgentTasks %}
                            <tr>
                                <td>
                                    <div style="font-weight: 600;">{{ task.title }}</div>
                                    <div class="text-muted" style="font-size: 12px;">{{ task.startAt|date('d/m H:i') }}</div>
                                </td>
                                <td>{{ task.plan.title }}</td>
                                <td>{{ task.priority }}</td>
                                <td>
                                    <span class="badge badge-{{ task.status == 'DONE' ? 'success' : (task.status == 'DOING' ? 'warning' : 'secondary') }}">
                                        {{ statusMap[task.status] ?? task.status }}
                                    </span>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

