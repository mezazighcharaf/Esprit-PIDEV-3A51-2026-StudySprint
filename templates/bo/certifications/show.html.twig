{% extends 'layouts/bo.html.twig' %}

{% block title %}Demande #{{ certRequest.id }} - Certification Prof - BO{% endblock %}
{% block breadcrumb %}<a href="{{ path('bo_certifications_index') }}">Certifications Prof</a> / Demande #{{ certRequest.id }}{% endblock %}

{% block content %}
<div class="bo-page-header">
    <h1 class="bo-page-title">Demande de certification #{{ certRequest.id }}</h1>
    <div class="bo-page-actions">
        <a href="{{ path('bo_certifications_index') }}" class="btn btn-secondary">← Retour à la liste</a>
    </div>
</div>

{% for message in app.flashes('success') %}
<div class="alert alert-success mb-4">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
<div class="alert alert-danger mb-4">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('info') %}
<div class="alert alert-info mb-4">{{ message }}</div>
{% endfor %}

{# ── ACTIONS ADMIN (en haut, bien visible) ── #}
{% if certRequest.pending %}
<div style="background: #fff; border: 2px solid #e5e7eb; border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.5rem; display: flex; gap: 1rem; align-items: flex-end; flex-wrap: wrap;">
    <div style="font-weight: 700; color: #111827; font-size: 15px; width: 100%; margin-bottom: 0.5rem;">
        ⚡ Action requise — cette demande est en attente de décision
    </div>

    {# Approuver #}
    <form method="post" action="{{ path('bo_certifications_approve', {id: certRequest.id}) }}"
          onsubmit="return confirm('Approuver cette demande ? L\'utilisateur deviendra professeur certifié.');"
          style="flex-shrink: 0;">
        <input type="hidden" name="_token" value="{{ csrf_token('approve' ~ certRequest.id) }}">
        <button type="submit" class="btn" style="background: #10b981; color: white; border-color: #10b981; padding: 0.65rem 1.5rem; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 0.4rem;">
            <svg style="width: 16px; height: 16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            Approuver la demande
        </button>
    </form>

    {# Refuser #}
    <form method="post" action="{{ path('bo_certifications_reject', {id: certRequest.id}) }}"
          onsubmit="return confirm('Refuser cette demande ?');"
          style="display: flex; gap: 0.5rem; align-items: flex-end; flex: 1; min-width: 280px;">
        <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ certRequest.id) }}">
        <div style="flex: 1;">
            <label style="font-size: 12px; color: #6b7280; display: block; margin-bottom: 0.25rem;">Motif de refus (optionnel)</label>
            <input type="text" name="reason" class="form-input" placeholder="Ex: documents insuffisants..." style="width: 100%;">
        </div>
        <button type="submit" class="btn" style="background: #ef4444; color: white; border-color: #ef4444; white-space: nowrap; flex-shrink: 0; display: flex; align-items: center; gap: 0.4rem;">
            <svg style="width: 16px; height: 16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
            Refuser
        </button>
    </form>
</div>
{% endif %}

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
    {# Infos demande #}
    <div class="card">
        <div class="card-header"><h3 style="margin:0;">Informations de la demande</h3></div>
        <div class="card-body">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                <div>
                    <div style="font-size: 12px; color: #9ca3af; margin-bottom: 0.25rem;">Statut</div>
                    <div>
                        {% if certRequest.status == 'PENDING' %}
                            <span style="display:inline-flex;align-items:center;gap:0.3rem;padding:0.3rem 0.75rem;background:#fef3c7;color:#92400e;border-radius:50px;font-size:12px;font-weight:600;">
                                ⏳ En attente
                            </span>
                        {% elseif certRequest.status == 'APPROVED' %}
                            <span style="display:inline-flex;align-items:center;gap:0.3rem;padding:0.3rem 0.75rem;background:#d1fae5;color:#065f46;border-radius:50px;font-size:12px;font-weight:600;">
                                ✅ Approuvée
                            </span>
                        {% elseif certRequest.status == 'REJECTED' %}
                            <span style="display:inline-flex;align-items:center;gap:0.3rem;padding:0.3rem 0.75rem;background:#fee2e2;color:#991b1b;border-radius:50px;font-size:12px;font-weight:600;">
                                ❌ Refusée
                            </span>
                        {% else %}
                            <span style="padding:0.3rem 0.75rem;background:#f3f4f6;color:#6b7280;border-radius:50px;font-size:12px;">{{ certRequest.status }}</span>
                        {% endif %}
                    </div>
                </div>
                <div>
                    <div style="font-size: 12px; color: #9ca3af; margin-bottom: 0.25rem;">Demandé le</div>
                    <div style="color: #111827;">{{ certRequest.requestedAt|date('d/m/Y à H:i') }}</div>
                </div>
            </div>

            {% if certRequest.motivation %}
            <div style="margin-bottom: 1rem;">
                <div style="font-size: 12px; color: #9ca3af; margin-bottom: 0.25rem;">Motivation</div>
                <div style="color: #111827; white-space: pre-wrap; background: #f9fafb; padding: 0.75rem; border-radius: 6px; line-height: 1.6;">{{ certRequest.motivation }}</div>
            </div>
            {% endif %}

            {% if certRequest.reviewedAt %}
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                <div>
                    <div style="font-size: 12px; color: #9ca3af; margin-bottom: 0.25rem;">Traité le</div>
                    <div style="color: #111827;">{{ certRequest.reviewedAt|date('d/m/Y à H:i') }}</div>
                </div>
                <div>
                    <div style="font-size: 12px; color: #9ca3af; margin-bottom: 0.25rem;">Traité par</div>
                    <div style="color: #111827;">{{ certRequest.reviewedBy ? certRequest.reviewedBy.fullName : '-' }}</div>
                </div>
            </div>
            {% endif %}

            {% if certRequest.reason %}
            <div>
                <div style="font-size: 12px; color: #9ca3af; margin-bottom: 0.25rem;">Motif de refus</div>
                <div style="color: #991b1b; background: #fef2f2; padding: 0.75rem; border-radius: 6px;">{{ certRequest.reason }}</div>
            </div>
            {% endif %}
        </div>
    </div>

    {# Infos utilisateur #}
    <div class="card">
        <div class="card-header"><h3 style="margin:0;">Utilisateur</h3></div>
        <div class="card-body">
            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
                <div style="width: 48px; height: 48px; border-radius: 50%; background: #111827; color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 18px; flex-shrink: 0;">
                    {{ certRequest.user.fullName|slice(0,2)|upper }}
                </div>
                <div>
                    <div style="font-weight: 700; color: #111827;">{{ certRequest.user.fullName }}</div>
                    <div style="font-size: 13px; color: #6b7280;">{{ certRequest.user.email }}</div>
                </div>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div>
                    <div style="font-size: 12px; color: #9ca3af; margin-bottom: 0.25rem;">Type actuel</div>
                    <div>
                        <span style="padding:0.25rem 0.65rem;background:#ede9fe;color:#5b21b6;border-radius:50px;font-size:12px;font-weight:600;">
                            {{ certRequest.user.userType ?? certRequest.user.role }}
                        </span>
                    </div>
                </div>
                <div>
                    <div style="font-size: 12px; color: #9ca3af; margin-bottom: 0.25rem;">Inscrit le</div>
                    <div style="color: #111827;">{{ certRequest.user.createdAt|date('d/m/Y') }}</div>
                </div>
            </div>
            <div style="margin-top: 1rem;">
                <a href="{{ path('bo_user_profiles_show', {id: certRequest.user.id}) }}" class="btn btn-secondary btn-sm" style="font-size: 12px;">
                    Voir le profil complet →
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
