{% extends 'layouts/bo.html.twig' %}

{% block title %}Encadrement - StudySprint BO{% endblock %}
{% block breadcrumb %}Encadrement{% endblock %}

{% block content %}
{% if state == 'empty' %}
    <div class="bo-page-header">
        <h1 class="bo-page-title">Encadrement</h1>
    </div>
    {{ include('components/_empty_state.html.twig', {
        title: 'Aucun groupe',
        description: 'Aucun groupe d\'etude n\'a encore ete cree.',
        variant: 'bo'
    }) }}
{% else %}
    <div class="bo-page-header">
        <h1 class="bo-page-title">Encadrement</h1>
    </div>

    {# Stats Row #}
    <div class="bo-stats-row">
        <div class="bo-stat-item">
            <span class="bo-stat-value">{{ data.stats.total_groups }}</span>
            <span class="bo-stat-label">Groupes</span>
        </div>
        <div class="bo-stat-item">
            <span class="bo-stat-value" style="color: var(--color-success);">{{ data.stats.public_groups }}</span>
            <span class="bo-stat-label">Publics</span>
        </div>
        <div class="bo-stat-item">
            <span class="bo-stat-value">{{ data.stats.total_members }}</span>
            <span class="bo-stat-label">Membres totaux</span>
        </div>
        <div class="bo-stat-item">
            <span class="bo-stat-value">{{ data.stats.total_posts }}</span>
            <span class="bo-stat-label">Posts</span>
        </div>
    </div>

    {# Search / Filter bar #}
    <form method="get" action="{{ path('admin_mentoring') }}" style="display:flex; gap:0.75rem; align-items:center; margin-bottom:1.25rem; flex-wrap:wrap;">
        <input type="text" name="q" value="{{ q }}" placeholder="Rechercher un groupe…"
               style="flex:1; min-width:200px; padding:0.5rem 0.875rem; border:1.5px solid var(--color-border); border-radius:8px; font-size:13px; outline:none;"
               onfocus="this.style.borderColor='var(--color-primary)'" onblur="this.style.borderColor='var(--color-border)'">
        <select name="privacy" style="padding:0.5rem 0.75rem; border:1.5px solid var(--color-border); border-radius:8px; font-size:13px;">
            <option value="" {{ privacy == '' ? 'selected' : '' }}>Tous</option>
            <option value="PUBLIC" {{ privacy == 'PUBLIC' ? 'selected' : '' }}>Public</option>
            <option value="PRIVATE" {{ privacy == 'PRIVATE' ? 'selected' : '' }}>Privé</option>
        </select>
        <button type="submit" class="btn btn-primary btn-sm">Filtrer</button>
        {% if q or privacy %}<a href="{{ path('admin_mentoring') }}" class="btn btn-secondary btn-sm">Réinitialiser</a>{% endif %}
    </form>

    {# Tabs #}
    <div style="border-bottom: 1px solid var(--color-gray-200); margin-bottom: 1.25rem;">
        <nav class="flex gap-4">
            <button class="bo-tab active" data-tab="groups">Groupes</button>
            <button class="bo-tab" data-tab="posts">Posts recents</button>
        </nav>
    </div>

    {# Tab: Groups #}
    <div class="tab-panel" id="tab-groups">
        <div class="table-container">
            <table class="bo-table">
                <thead>
                    <tr>
                        <th>Groupe</th>
                        <th>Confidentialite</th>
                        <th>Membres</th>
                        <th>Posts</th>
                        <th>Cree le</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for group in data.groups %}
                    <tr>
                        <td class="font-medium">{{ group.name }}</td>
                        <td>
                            <span class="badge badge-{{ group.privacy == 'PUBLIC' ? 'success' : 'neutral' }}">
                                {{ group.privacy == 'PUBLIC' ? 'Public' : 'Prive' }}
                            </span>
                        </td>
                        <td>{{ group.members }}</td>
                        <td>{{ group.posts }}</td>
                        <td class="text-muted">{{ group.created_at }}</td>
                        <td>
                            <a href="{{ path('app_group_detail', {id: group.id}) }}" class="btn btn-ghost btn-sm" target="_blank">Voir</a>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="6" class="text-center text-muted" style="padding: 2rem;">Aucun groupe</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# Tab: Recent Posts #}
    <div class="tab-panel" id="tab-posts" style="display: none;">
        <div class="table-container">
            <table class="bo-table">
                <thead>
                    <tr>
                        <th>Contenu</th>
                        <th>Auteur</th>
                        <th>Groupe</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    {% for post in data.recent_posts %}
                    <tr>
                        <td style="max-width: 300px;">
                            <span class="text-sm text-muted" style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: block;">
                                {{ post.excerpt }}
                            </span>
                        </td>
                        <td class="font-medium">{{ post.author }}</td>
                        <td>{{ post.group }}</td>
                        <td class="text-muted">{{ post.created_at }}</td>
                    </tr>
                    {% else %}
                    <tr><td colspan="4" class="text-center text-muted" style="padding: 2rem;">Aucun post</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endif %}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function () {
    const tabs = document.querySelectorAll('.bo-tab');
    const panels = document.querySelectorAll('.tab-panel');
    tabs.forEach(btn => {
        btn.addEventListener('click', function () {
            tabs.forEach(t => t.classList.remove('active'));
            panels.forEach(p => p.style.display = 'none');
            this.classList.add('active');
            const panel = document.getElementById('tab-' + this.dataset.tab);
            if (panel) panel.style.display = '';
        });
    });
});
</script>
{% endblock %}
