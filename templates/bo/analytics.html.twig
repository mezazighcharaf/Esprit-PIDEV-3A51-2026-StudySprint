{% extends 'layouts/bo.html.twig' %}

{% block title %}Analytics - StudySprint BO{% endblock %}
{% block breadcrumb %}Analytics{% endblock %}

{% block topbar_actions %}
<button class="btn btn-secondary btn-sm" data-drawer-open="analytics-drawer">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    Detail analytique
</button>
<a href="{{ path('admin_analytics_export') }}" class="btn btn-secondary btn-sm">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="7 10 12 15 17 10"/>
        <line x1="12" y1="15" x2="12" y2="3"/>
    </svg>
    Exporter CSV
</a>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .chartjs-container { position: relative; width: 100%; height: 250px; }
        .chart-doughnut-container { position: relative; width: 100%; height: 220px; }
    </style>
{% endblock %}

{% block content %}
{% if state == 'loading' %}
    {# ─── LOADING STATE ─── #}
    <div class="bo-page-header">
        <h1 class="bo-page-title">Analytics</h1>
    </div>

    <div class="filterbar mb-4">
        <div class="skeleton" style="height: 32px; width: 120px;"></div>
        <div class="skeleton" style="height: 32px; width: 120px;"></div>
        <div class="skeleton" style="height: 32px; width: 120px;"></div>
    </div>

    <div class="bo-kpi-row">
        {% for i in 1..5 %}
        <div class="bo-kpi-card">
            <div class="skeleton" style="height: 14px; width: 80px; margin-bottom: 8px;"></div>
            <div class="skeleton" style="height: 28px; width: 60px; margin-bottom: 8px;"></div>
            <div class="skeleton" style="height: 12px; width: 100px;"></div>
        </div>
        {% endfor %}
    </div>

    <div class="bo-analytics-grid">
        <div class="bo-analytics-main">
            <div class="bo-chart-card">
                <div class="bo-chart-header">
                    <div class="skeleton" style="height: 16px; width: 150px;"></div>
                </div>
                <div class="bo-chart-body">
                    <div class="skeleton" style="height: 200px;"></div>
                </div>
            </div>
        </div>
        <div class="bo-analytics-side">
            <div class="bo-chart-card">
                <div class="bo-chart-header">
                    <div class="skeleton" style="height: 16px; width: 100px;"></div>
                </div>
                <div class="bo-chart-body">
                    {{ include('components/_skeleton.html.twig', { type: 'row', count: 5 }) }}
                </div>
            </div>
        </div>
    </div>

{% elseif state == 'empty' %}
    {# ─── EMPTY STATE ─── #}
    <div class="bo-page-header">
        <h1 class="bo-page-title">Analytics</h1>
    </div>
    {{ include('components/_empty_state.html.twig', {
        title: 'Aucune donnee disponible',
        description: 'Les donnees analytiques seront disponibles une fois que des utilisateurs auront commence a utiliser la plateforme.',
        variant: 'bo'
    }) }}

{% else %}
    {# ─── DEFAULT STATE ─── #}
    <div class="bo-page-header">
        <h1 class="bo-page-title">Analytics</h1>
    </div>

    {# Filterbar #}
    <form method="get" action="{{ path('admin_analytics') }}" id="analytics-filter-form">
        {{ include('components/_filterbar.html.twig', {
            filters: data.filters,
            show_clear: true
        }) }}
    </form>
    <script>
    document.getElementById('analytics-filter-form').querySelectorAll('select').forEach(function(s){
        s.addEventListener('change', function(){ document.getElementById('analytics-filter-form').submit(); });
    });
    document.querySelectorAll('.filterbar-clear').forEach(function(btn){
        btn.addEventListener('click', function(){ window.location.href = '{{ path('admin_analytics') }}'; });
    });
    </script>

    {# KPIs Row #}
    <div class="bo-kpi-row">
        {% for kpi in data.kpis %}
        <div class="bo-kpi-card">
            <div class="bo-kpi-header">
                <span class="bo-kpi-label">{{ kpi.label }}</span>
                {% if kpi.trend %}
                <span class="bo-kpi-trend {{ kpi.trend_direction }}">
                    {% if kpi.trend_direction == 'up' %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                    </svg>
                    {% elseif kpi.trend_direction == 'down' %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="23 18 13.5 8.5 8.5 13.5 1 6"/>
                    </svg>
                    {% endif %}
                    {{ kpi.trend }}
                </span>
                {% endif %}
            </div>
            <div class="bo-kpi-value">{{ kpi.value }}</div>
            <div class="bo-kpi-subtitle">{{ kpi.subtitle }}</div>
            {% if kpi.sparkline is defined and kpi.sparkline %}
            <div class="bo-kpi-sparkline">
                <svg viewBox="0 0 100 32" preserveAspectRatio="none">
                    <polyline
                        fill="none"
                        stroke="var(--color-primary)"
                        stroke-width="2"
                        points="0,28 15,24 30,26 45,18 60,20 75,12 90,16 100,8"
                    />
                </svg>
            </div>
            {% endif %}
        </div>
        {% endfor %}
    </div>

    {# Main Analytics Grid #}
    <div class="bo-analytics-grid">
        <div class="bo-analytics-main">
            {# Activity Trend Chart #}
            <div class="bo-chart-card">
                <div class="bo-chart-header">
                    <h3 class="bo-chart-title">Tendance activite (7 jours)</h3>
                    <div class="flex gap-4 text-xs">
                        <span class="flex items-center gap-1">
                            <span style="width: 12px; height: 3px; background: var(--color-primary); border-radius: 2px;"></span>
                            Cette semaine
                        </span>
                        <span class="flex items-center gap-1">
                            <span style="width: 12px; height: 3px; background: var(--color-gray-300); border-radius: 2px;"></span>
                            Semaine precedente
                        </span>
                    </div>
                </div>
                <div class="bo-chart-body">
                    <div class="chartjs-container">
                        <canvas id="activityTrendChart"></canvas>
                    </div>
                </div>
            </div>

            {# Insights #}
            <div class="bo-chart-card">
                <div class="bo-chart-header">
                    <h3 class="bo-chart-title">Insights contenu</h3>
                </div>
                <div class="bo-chart-body">
                    <div class="bo-insights-list">
                        {% for insight in data.insights %}
                        <div class="bo-insight-item {{ insight.type }}">
                            <div class="bo-insight-icon">
                                {% if insight.type == 'success' %}
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                                    <polyline points="22 4 12 14.01 9 11.01"/>
                                </svg>
                                {% elseif insight.type == 'warning' %}
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                                    <line x1="12" y1="9" x2="12" y2="13"/>
                                    <line x1="12" y1="17" x2="12.01" y2="17"/>
                                </svg>
                                {% elseif insight.type == 'error' %}
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"/>
                                    <line x1="15" y1="9" x2="9" y2="15"/>
                                    <line x1="9" y1="9" x2="15" y2="15"/>
                                </svg>
                                {% else %}
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"/>
                                    <line x1="12" y1="16" x2="12" y2="12"/>
                                    <line x1="12" y1="8" x2="12.01" y2="8"/>
                                </svg>
                                {% endif %}
                            </div>
                            <div class="bo-insight-content">
                                <div class="bo-insight-text">{{ insight.text|raw }}</div>
                                {% if insight.action is defined and insight.action %}
                                <div class="bo-insight-action">{{ insight.action }}</div>
                                {% endif %}
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        <div class="bo-analytics-side">
            {# Top Subjects - Doughnut Chart #}
            <div class="bo-chart-card">
                <div class="bo-chart-header">
                    <h3 class="bo-chart-title">Top matieres</h3>
                </div>
                <div class="bo-chart-body">
                    <div class="chart-doughnut-container">
                        <canvas id="subjectsDoughnutChart"></canvas>
                    </div>
                    <div class="bo-top-list" style="margin-top: 1rem;">
                        {% for subject in data.top_subjects %}
                        <div class="bo-top-item">
                            <div class="bo-top-rank">{{ loop.index }}</div>
                            <div class="bo-top-info">
                                <div class="bo-top-name">{{ subject.name }}</div>
                            </div>
                            <div class="bo-top-value">{{ subject.value }}</div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>

            {# Anomalies #}
            <div class="bo-anomalies-card">
                <div class="bo-anomalies-header">
                    <h3 class="bo-anomalies-title">A surveiller</h3>
                    <span class="bo-anomalies-count">{{ data.anomalies|length }}</span>
                </div>
                <table class="bo-table">
                    <thead>
                        <tr>
                            <th>Utilisateur</th>
                            <th>Anomalie</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for anomaly in data.anomalies %}
                        <tr>
                            <td>
                                <div class="cell-user">
                                    <div class="cell-user-avatar">{{ anomaly.user|slice(0,1) }}{{ anomaly.user|split(' ')|last|slice(0,1) }}</div>
                                    <div class="cell-user-info">
                                        <div class="cell-user-name">{{ anomaly.user }}</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="text-xs">
                                    <div class="font-medium" style="color: var(--color-{{ anomaly.severity == 'error' ? 'error' : 'warning' }});">{{ anomaly.type }}</div>
                                    <div class="text-muted">{{ anomaly.details }}</div>
                                </div>
                            </td>
                            <td>
                                <button class="btn btn-ghost btn-sm">Voir</button>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endif %}
{% endblock %}

{% block drawers %}
{# Drawer: Detail analytique #}
<div class="drawer" id="analytics-drawer">
    <div class="drawer-header">
        <h2 class="drawer-title">Detail analytique</h2>
        <button class="drawer-close" data-drawer-close aria-label="Fermer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
    </div>
    <div class="drawer-body">
        <div class="bo-drawer-section">
            <h4 class="bo-drawer-section-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="20" x2="18" y2="10"/>
                    <line x1="12" y1="20" x2="12" y2="4"/>
                    <line x1="6" y1="20" x2="6" y2="14"/>
                </svg>
                Metriques cles
            </h4>
            <div class="bo-drawer-stat-grid">
                <div class="bo-drawer-stat">
                    <div class="bo-drawer-stat-label">Sessions totales</div>
                    <div class="bo-drawer-stat-value">1,247</div>
                </div>
                <div class="bo-drawer-stat">
                    <div class="bo-drawer-stat-label">Temps moyen</div>
                    <div class="bo-drawer-stat-value">42 min</div>
                </div>
                <div class="bo-drawer-stat">
                    <div class="bo-drawer-stat-label">Taux completion</div>
                    <div class="bo-drawer-stat-value">68%</div>
                </div>
                <div class="bo-drawer-stat">
                    <div class="bo-drawer-stat-label">Score moyen quiz</div>
                    <div class="bo-drawer-stat-value">74%</div>
                </div>
            </div>
        </div>

        <div class="bo-drawer-section">
            <h4 class="bo-drawer-section-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                </svg>
                Segments utilisateurs
            </h4>
            <div class="mb-3">
                <div class="flex justify-between text-sm mb-1">
                    <span>Tres actifs (>5 sessions/sem)</span>
                    <span class="font-medium">32%</span>
                </div>
                <div class="progress">
                    <div class="progress-bar success" style="width: 32%;"></div>
                </div>
            </div>
            <div class="mb-3">
                <div class="flex justify-between text-sm mb-1">
                    <span>Actifs reguliers (2-5 sessions/sem)</span>
                    <span class="font-medium">45%</span>
                </div>
                <div class="progress">
                    <div class="progress-bar" style="width: 45%;"></div>
                </div>
            </div>
            <div class="mb-3">
                <div class="flex justify-between text-sm mb-1">
                    <span>Occasionnels (<2 sessions/sem)</span>
                    <span class="font-medium">18%</span>
                </div>
                <div class="progress">
                    <div class="progress-bar warning" style="width: 18%;"></div>
                </div>
            </div>
            <div>
                <div class="flex justify-between text-sm mb-1">
                    <span>Inactifs (0 session)</span>
                    <span class="font-medium">5%</span>
                </div>
                <div class="progress">
                    <div class="progress-bar error" style="width: 5%;"></div>
                </div>
            </div>
        </div>

        <div class="bo-drawer-section">
            <h4 class="bo-drawer-section-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                    <polyline points="7 10 12 15 17 10"/>
                    <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                Actions rapides
            </h4>
            <div class="flex flex-col gap-2">
                <button class="btn btn-secondary" style="width: 100%; justify-content: flex-start;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                    </svg>
                    Exporter en CSV
                </button>
                <button class="btn btn-secondary" style="width: 100%; justify-content: flex-start;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                        <line x1="3" y1="9" x2="21" y2="9"/>
                        <line x1="9" y1="21" x2="9" y2="9"/>
                    </svg>
                    Generer rapport PDF
                </button>
                <button class="btn btn-secondary" style="width: 100%; justify-content: flex-start;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                        <polyline points="22,6 12,13 2,6"/>
                    </svg>
                    Envoyer par email
                </button>
            </div>
        </div>
    </div>
    <div class="drawer-footer">
        <button class="btn btn-secondary" data-drawer-close>Fermer</button>
        <button class="btn btn-primary">Exporter</button>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
{% if state == 'default' %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // --- Activity Trend Line Chart ---
    const trendCtx = document.getElementById('activityTrendChart');
    if (trendCtx) {
        const labels = {{ data.activity_trend.labels|json_encode|raw }};
        const currentData = {{ data.activity_trend.data|json_encode|raw }};
        const previousData = {{ data.activity_trend.previous|json_encode|raw }};

        new Chart(trendCtx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Cette semaine',
                        data: currentData,
                        borderColor: '#667eea',
                        backgroundColor: 'rgba(102, 126, 234, 0.1)',
                        borderWidth: 3,
                        fill: true,
                        tension: 0.4,
                        pointBackgroundColor: '#667eea',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        pointRadius: 5,
                        pointHoverRadius: 7
                    },
                    {
                        label: 'Semaine precedente',
                        data: previousData,
                        borderColor: '#d1d5db',
                        borderWidth: 2,
                        borderDash: [5, 5],
                        fill: false,
                        tension: 0.4,
                        pointRadius: 3,
                        pointBackgroundColor: '#d1d5db'
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(0,0,0,0.8)',
                        titleFont: { size: 13 },
                        bodyFont: { size: 12 },
                        padding: 10,
                        cornerRadius: 8
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        max: 100,
                        grid: { color: 'rgba(0,0,0,0.05)' },
                        ticks: { font: { size: 11 }, color: '#9ca3af' }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { font: { size: 11 }, color: '#9ca3af' }
                    }
                }
            }
        });
    }

    // --- Subjects Doughnut Chart ---
    const doughnutCtx = document.getElementById('subjectsDoughnutChart');
    if (doughnutCtx) {
        const subjectNames = {{ data.top_subjects|map(s => s.name)|json_encode|raw }};
        const subjectValues = {{ data.top_subjects|map(s => s.value)|json_encode|raw }};
        const colors = ['#667eea', '#f093fb', '#43e97b', '#f5576c', '#fa709a', '#fee140'];

        new Chart(doughnutCtx, {
            type: 'doughnut',
            data: {
                labels: subjectNames,
                datasets: [{
                    data: subjectValues,
                    backgroundColor: colors.slice(0, subjectValues.length),
                    borderWidth: 0,
                    hoverOffset: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(0,0,0,0.8)',
                        padding: 10,
                        cornerRadius: 8
                    }
                }
            }
        });
    }
});
</script>
{% endif %}
{% endblock %}
