{% extends 'base.html.twig' %}

{% block title %}Objectif index{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1>Mes Objectifs</h1>

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Titre</th>
                    <th>Description</th>
                    <th>Date de début</th>
                    <th>Date de fin</th>
                    <th>Statut</th>
                    <th>actions</th>
                </tr>
            </thead>
            <tbody>
            {% for objectif in objectifs %}
                <tr>
                    <td>{{ objectif.titre }}</td>
                    <td>{{ objectif.description }}</td>
                    <td>{{ objectif.dateDebut ? objectif.dateDebut|date('Y-m-d') : '' }}</td>
                    <td>{{ objectif.dateFin ? objectif.dateFin|date('Y-m-d') : '' }}</td>
                    <td>
                        <span class="badge {% if objectif.statut == 'EN_COURS' %}bg-primary{% elseif objectif.statut == 'TERMINE' %}bg-success{% else %}bg-secondary{% endif %}">
                            {{ objectif.statut }}
                        </span>
                    </td>
                    <td>
                        <a href="{{ path('app_objectif_show', {'id': objectif.id}) }}" class="btn btn-sm btn-info">Voir</a>
                        <a href="{{ path('app_objectif_edit', {'id': objectif.id}) }}" class="btn btn-sm btn-warning">Modifier</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7">Aucun objectif trouvé</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <a href="{{ path('app_objectif_new') }}" class="btn btn-primary">Créer un nouvel objectif</a>
    </div>
{% endblock %}
