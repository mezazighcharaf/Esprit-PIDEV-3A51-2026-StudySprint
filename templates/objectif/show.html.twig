{% extends 'base.html.twig' %}

{% block title %}Objectif{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1>{{ objectif.titre }}</h1>

        <div class="card mb-4">
            <div class="card-body">
                <p class="card-text">{{ objectif.description }}</p>
                <div class="row">
                    <div class="col-md-4">
                        <strong>Début:</strong> {{ objectif.dateDebut ? objectif.dateDebut|date('Y-m-d') : '' }}
                    </div>
                    <div class="col-md-4">
                        <strong>Fin:</strong> {{ objectif.dateFin ? objectif.dateFin|date('Y-m-d') : '' }}
                    </div>
                    <div class="col-md-4">
                        <strong>Statut:</strong> {{ objectif.statut }}
                    </div>
                </div>
                
                {% set remaining = 0 %}
                {% for t in objectif.taches %}
                    {% if t.statut != 'TERMINE' %}
                        {% set remaining = remaining + t.duree %}
                    {% endif %}
                {% endfor %}
                
                {% if remaining > 0 %}
                <div class="mt-2 text-muted">
                    <i class="bi bi-clock"></i> Temps estimé restant: {{ remaining }} min
                </div>
                {% endif %}
            </div>
            <div class="card-footer">
                <a href="{{ path('app_objectif_edit', {'id': objectif.id}) }}" class="btn btn-warning">Modifier</a>
                <a href="{{ path('app_objectif_index') }}" class="btn btn-secondary">Retour à la liste</a>
                <div class="d-inline-block ms-2">
                    {{ include('objectif/_delete_form.html.twig') }}
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Tâches</h2>
            <div class="d-flex gap-2">
                <form method="post" action="{{ path('app_objectif_generate_tasks', {'id': objectif.id}) }}">
                    <button class="btn btn-outline-primary fw-bold border-2">
                        ✨ Magic Breakdown
                    </button>
                </form>
                <a href="{{ path('app_tache_new', {'id': objectif.id}) }}" class="btn btn-success">Ajouter une tâche</a>
            </div>
        </div>

        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Titre</th>
                    <th>Date</th>
                    <th>Durée (min)</th>
                    <th>Priorité</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for tache in objectif.taches %}
                <tr>
                    <td>{{ tache.titre }}</td>
                    <td>{{ tache.date ? tache.date|date('Y-m-d') : '' }}</td>
                    <td>{{ tache.duree }}</td>
                    <td>{{ tache.priorite }}</td>
                    <td>
                        {% if tache.statut == 'TERMINE' %}
                            <span class="badge bg-success">Terminé</span>
                        {% else %}
                             <span class="badge bg-warning text-dark">{{ tache.statut }}</span>
                        {% endif %}
                    </td>
                    <td>
                        <form method="post" action="{{ path('app_tache_toggle', {'id': tache.id}) }}" class="d-inline">
                             <button class="btn btn-sm {% if tache.statut == 'TERMINE' %}btn-secondary{% else %}btn-success{% endif %}">
                                 {% if tache.statut == 'TERMINE' %}Rouvrir{% else %}Terminer{% endif %}
                             </button>
                        </form>
                        <a href="{{ path('app_tache_edit', {'id': tache.id}) }}" class="btn btn-sm btn-primary">Modifier</a>
                        <div class="d-inline-block">
                             {{ include('tache/_delete_form.html.twig') }}
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5">Aucune tâche pour cet objectif</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        
        <!-- Progress Bar (Optional) -->
        {% set total = objectif.taches|length %}
        {% set completed = 0 %}
        {% for t in objectif.taches %}
            {% if t.statut == 'TERMINE' %}{% set completed = completed + 1 %}{% endif %}
        {% endfor %}
        
        {% if total > 0 %}
            <div class="progress mt-3">
                <div class="progress-bar" role="progressbar" style="width: {{ (completed / total * 100)|round }}%;" aria-valuenow="{{ (completed / total * 100)|round }}" aria-valuemin="0" aria-valuemax="100">
                    {{ (completed / total * 100)|round }}%
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}
