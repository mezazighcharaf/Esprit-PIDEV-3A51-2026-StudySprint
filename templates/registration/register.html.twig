{% extends 'layouts/auth.html.twig' %}

{% block title %}Inscription - StudySprint{% endblock %}

{% block content %}
    <h1 class="auth-title">Créer un compte</h1>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success" style="background: #dcfce7; color: #166534; padding: 1rem; border-radius: 6px; margin-bottom: 1.5rem;">
            {{ message }}
        </div>
    {% endfor %}

    {{ form_start(registrationForm, {'attr': {'class': 'auth-form', 'novalidate': 'novalidate'}}) }}

        {# Custom Role Selector #}
        <div class="role-selector-wrapper">
            <div class="role-title">Je souhaite m'inscrire en tant que :</div>
            <div class="role-options">
                {% for child in registrationForm.role %}
                    <div class="role-option">
                        {{ form_widget(child) }}
                        {{ form_label(child) }}
                    </div>
                {% endfor %}
            </div>
            {{ form_errors(registrationForm.role) }}
        </div>

        <div class="grid grid-2" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div class="form-group">
                {{ form_label(registrationForm.nom) }}
                {{ form_widget(registrationForm.nom, {'attr': {'class': 'form-control', 'placeholder': 'Votre nom'}}) }}
                {{ form_errors(registrationForm.nom) }}
            </div>
            <div class="form-group">
                {{ form_label(registrationForm.prenom) }}
                {{ form_widget(registrationForm.prenom, {'attr': {'class': 'form-control', 'placeholder': 'Votre prénom'}}) }}
                {{ form_errors(registrationForm.prenom) }}
            </div>
        </div>

        <div class="form-group">
            {{ form_label(registrationForm.email) }}
            {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control', 'placeholder': 'exemple@email.com'}}) }}
            {{ form_errors(registrationForm.email) }}
        </div>

        <div class="form-group">
            {{ form_label(registrationForm.telephone) }}
            {{ form_widget(registrationForm.telephone, {'attr': {'class': 'form-control', 'placeholder': '+216...'}}) }}
            {{ form_errors(registrationForm.telephone) }}
        </div>

        <div class="form-group">
            {{ form_label(registrationForm.motDePasse) }}
            {{ form_widget(registrationForm.motDePasse, {'attr': {'class': 'form-control', 'placeholder': '••••••••'}}) }}
            {{ form_errors(registrationForm.motDePasse) }}
        </div>

        <div class="form-group">
            {{ form_label(registrationForm.pays) }}
            {{ form_widget(registrationForm.pays, {'attr': {'class': 'form-select'}}) }}
            {{ form_errors(registrationForm.pays) }}
        </div>

        {# Common Academic Fields (Age, Sexe, Etablissement) - Hidden by default #}
        <div id="common-academic-fields" style="display:none; border-top: 1px solid #e2e8f0; padding-top: 1.5rem; margin-top: 1.5rem;">
            <div class="grid grid-2" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="form-group">
                    {{ form_label(registrationForm.age) }}
                    {{ form_widget(registrationForm.age, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(registrationForm.age) }}
                </div>
                <div class="form-group">
                    {{ form_label(registrationForm.sexe) }}
                    {{ form_widget(registrationForm.sexe, {'attr': {'class': 'form-select'}}) }}
                    {{ form_errors(registrationForm.sexe) }}
                </div>
            </div>

            <div class="form-group">
                {{ form_label(registrationForm.etablissement) }}
                {{ form_widget(registrationForm.etablissement, {'attr': {'class': 'form-select', 'disabled': 'disabled'}}) }}
                {{ form_errors(registrationForm.etablissement) }}
            </div>
        </div>

        {# Student Specific Fields #}
        <div id="student-fields" style="display:none;">
            <div class="form-group">
                {{ form_label(registrationForm.niveau) }}
                {{ form_widget(registrationForm.niveau, {'attr': {'class': 'form-select', 'disabled': 'disabled'}}) }}
                {{ form_errors(registrationForm.niveau) }}
            </div>
        </div>

        {# Professor Specific Fields #}
        <div id="professor-fields" style="display:none;">
            <div class="form-group">
                {{ form_label(registrationForm.specialite) }}
                {{ form_widget(registrationForm.specialite, {'attr': {'class': 'form-select'}}) }}
                {{ form_errors(registrationForm.specialite) }}
            </div>
            <div class="form-group">
                {{ form_label(registrationForm.niveauEnseignement) }}
                {{ form_widget(registrationForm.niveauEnseignement, {'attr': {'class': 'form-select'}}) }}
                {{ form_errors(registrationForm.niveauEnseignement) }}
            </div>
            <div class="form-group">
                {{ form_label(registrationForm.anneesExperience) }}
                {{ form_widget(registrationForm.anneesExperience, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(registrationForm.anneesExperience) }}
            </div>
        </div>

        <div style="margin-top: 2rem;">
            <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; padding: 0.8rem;">
                Créer mon compte
            </button>
        </div>
        
        <p style="text-align: center; margin-top: 1.5rem; color: #64748b; font-size: 0.9rem;">
            Déjà inscrit ? <a href="{{ path('app_login') }}" style="color: var(--color-primary); text-decoration: none; font-weight: 500;">Se connecter</a>
        </p>

    {{ form_end(registrationForm) }}

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const studentFields = document.getElementById('student-fields');
        const professorFields = document.getElementById('professor-fields');
        const roleInputs = document.querySelectorAll('input[name="registration[role]"]');
        const countrySelect = document.getElementById('registration_pays');
        const schoolSelect = document.getElementById('registration_etablissement');
        const levelSelect = document.getElementById('registration_niveau');

        const commonAcademicFields = document.getElementById('common-academic-fields');

        // Toggle Fields based on Role
        function toggleFields() {
            let selectedRole = document.querySelector('input[name="registration[role]"]:checked')?.value;
            
            if (selectedRole === 'student') {
                commonAcademicFields.style.display = 'block';
                studentFields.style.display = 'block';
                professorFields.style.display = 'none';
            } else if (selectedRole === 'professor') {
                commonAcademicFields.style.display = 'block';
                studentFields.style.display = 'none';
                professorFields.style.display = 'block';
            } else {
                commonAcademicFields.style.display = 'none';
                studentFields.style.display = 'none';
                professorFields.style.display = 'none';
            }
        }

        roleInputs.forEach(input => {
            input.addEventListener('change', toggleFields);
        });

        toggleFields();

        // Dynamic Country -> School/Level
        countrySelect.addEventListener('change', function() {
            const countryCode = this.value;
            
            if (!countryCode) {
                resetSelect(schoolSelect);
                resetSelect(levelSelect);
                return;
            }

            // Fetch Schools (used by both Student and Professor)
            fetch(`/api/location/schools/${countryCode}`)
                .then(response => response.json())
                .then(data => {
                    updateSelect(schoolSelect, data);
                });

            // Fetch Levels (only for students, but harmless if fetch runs)
            if (levelSelect) {
                fetch(`/api/location/levels/${countryCode}`)
                    .then(response => response.json())
                    .then(data => {
                        updateSelect(levelSelect, data);
                    });
            }
        });

        function updateSelect(selectElement, items) {
            selectElement.innerHTML = '';
            selectElement.disabled = false;
            
            // Add placeholder
            const placeholder = document.createElement('option');
            placeholder.value = '';
            placeholder.text = 'Choisir...';
            selectElement.appendChild(placeholder);

            items.forEach(item => {
                const option = document.createElement('option');
                option.value = item;
                option.text = item;
                selectElement.appendChild(option);
            });
        }

        function resetSelect(selectElement) {
            selectElement.innerHTML = '<option value="">Choisir un pays d\'abord</option>';
            selectElement.disabled = true;
        }
    });
</script>
{% endblock %}
