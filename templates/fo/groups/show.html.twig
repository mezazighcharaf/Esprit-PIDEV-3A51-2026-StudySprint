{% extends 'layouts/fo.html.twig' %}
{% block title %}{{ group.name }} - StudySprint{% endblock %}

{% block content %}
{# Breadcrumb #}
<div style="margin-bottom: 1.5rem;">
    <a href="{{ path('app_groups') }}" style="color: #6b7280; text-decoration: none; font-size: 13px; display: inline-flex; align-items: center; gap: 0.375rem; transition: color 0.2s;" onmouseover="this.style.color='#111827';" onmouseout="this.style.color='#6b7280';">
        <svg style="width: 14px; height: 14px; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Retour aux groupes
    </a>
</div>

{# Flash messages #}
{% for message in app.flashes('success') %}
    <div class="alert alert-success" style="margin-bottom: 1.5rem;">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="alert alert-danger" style="margin-bottom: 1.5rem;">{{ message }}</div>
{% endfor %}

{# ══════ HERO SECTION ══════ #}
<div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 16px; padding: 2rem; color: white; margin-bottom: 2rem;">
    <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 1rem;">
        <div style="flex: 1;">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
                <h1 style="font-size: 26px; font-weight: 700; margin: 0;">{{ group.name }}</h1>
                <span style="background: {{ group.privacy == 'PUBLIC' ? 'rgba(255,255,255,0.2)' : 'rgba(255,255,255,0.15)' }}; color: white; font-size: 11px; padding: 0.25rem 0.625rem; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">
                    {{ group.privacy }}
                </span>
            </div>
            {% if group.description %}
                <p style="font-size: 14px; opacity: 0.9; margin: 0 0 1rem 0; line-height: 1.5;">{{ group.description }}</p>
            {% endif %}
            <div style="display: flex; align-items: center; gap: 0.5rem; font-size: 13px; opacity: 0.85;">
                <svg style="width: 16px; height: 16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
                Créé par {{ group.createdBy.fullName }} {{ include('components/_teacher_badge.html.twig', {user: group.createdBy}) }}
            </div>
        </div>
    </div>
    <div style="display: flex; gap: 1rem; margin-top: 1.25rem;">
        <div style="background: rgba(255,255,255,0.15); border-radius: 10px; padding: 0.75rem 1.25rem; flex: 1; text-align: center;">
            <div style="font-size: 24px; font-weight: 700;">{{ group.members|length }}</div>
            <div style="font-size: 12px; opacity: 0.85;">Membres</div>
        </div>
        <div style="background: rgba(255,255,255,0.15); border-radius: 10px; padding: 0.75rem 1.25rem; flex: 1; text-align: center;">
            <div style="font-size: 24px; font-weight: 700;">{{ group.posts|length }}</div>
            <div style="font-size: 12px; opacity: 0.85;">Publications</div>
        </div>
        <div style="background: rgba(255,255,255,0.15); border-radius: 10px; padding: 0.75rem 1.25rem; flex: 1; text-align: center;">
            {% set memberAvatars = group.members|slice(0, 4) %}
            <div style="display: flex; justify-content: center; margin-bottom: 0.25rem;">
                {% for member in memberAvatars %}
                <div style="width: 28px; height: 28px; border-radius: 50%; background: rgba(255,255,255,0.3); color: white; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 11px; margin-left: {{ loop.first ? '0' : '-6px' }}; border: 2px solid rgba(102, 126, 234, 0.8);" title="{{ member.user.fullName }}">
                    {{ member.user.fullName|slice(0,1)|upper }}
                </div>
                {% endfor %}
            </div>
            <div style="font-size: 12px; opacity: 0.85;">Équipe</div>
        </div>
    </div>
</div>

{# ══════ TWO-COLUMN LAYOUT ══════ #}
<style>
@media (min-width: 1024px) {
    .group-feed-layout {
        display: grid !important;
        grid-template-columns: 1fr 300px;
        gap: 1.5rem;
        align-items: start;
    }
}
</style>

<div class="group-feed-layout" style="display: flex; flex-direction: column; gap: 1.5rem;">
    
    {# FEED GAUCHE (zone principale) #}
    <div style="display: flex; flex-direction: column; gap: 1.5rem; min-width: 0;">
        
        {# Composer #}
        {% include 'fo/groups/_composer.html.twig' with {group: group} %}

        {# Feed Header #}
        <div style="display: flex; align-items: center; justify-content: space-between; padding: 0 0.25rem;">
            <h2 style="font-size: 18px; font-weight: 600; color: #111827; margin: 0;">
                Publications
                {% if posts is not empty %}
                    <span style="color: #9ca3af; font-weight: 400; font-size: 14px;">({{ (page - 1) * 10 + 1 }}-{{ min(page * 10, (page - 1) * 10 + posts|length) }})</span>
                {% endif %}
            </h2>
            {% if totalPages > 1 %}
                <span style="font-size: 13px; color: #9ca3af;">Page {{ page }}/{{ totalPages }}</span>
            {% endif %}
        </div>

        {# Posts #}
        {% if posts is empty %}
            <div class="card" style="text-align: center; padding: 4rem 2rem; border-radius: 12px;">
                <svg style="width: 80px; height: 80px; margin: 0 auto 1.5rem; color: #d1d5db;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
                <h3 style="font-size: 18px; font-weight: 600; color: #1f2937; margin: 0 0 0.5rem 0;">Aucune publication</h3>
                <p style="color: #6b7280; font-size: 14px; margin: 0 0 1.5rem 0;">Soyez le premier à partager avec le groupe</p>
            </div>
        {% else %}
            <div style="display: flex; flex-direction: column; gap: 1.25rem;">
                {% for post in posts %}
                    {% include 'fo/groups/_post_card.html.twig' with {
                        post: post,
                        group: group,
                        currentUser: currentUser,
                        isOwnerOrAdmin: isOwnerOrAdmin
                    } %}
                {% endfor %}
            </div>

            {# Pagination #}
            {% if totalPages > 1 %}
            <div style="display: flex; align-items: center; justify-content: center; gap: 0.75rem; padding: 1.5rem 0 0.5rem;">
                {% if page > 1 %}
                    <a href="{{ path('app_group_detail', {id: group.id, page: page - 1}) }}" class="btn btn-ghost btn-sm" style="padding: 0.5rem 0.75rem;">
                        <svg style="width: 14px; height: 14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                        Précédent
                    </a>
                {% endif %}
                <div style="display: flex; align-items: center; gap: 0.25rem;">
                    {% for p in 1..totalPages %}
                        {% if p == page %}
                            <span class="btn btn-primary btn-sm" style="min-width: 36px; padding: 0.5rem;">{{ p }}</span>
                        {% else %}
                            <a href="{{ path('app_group_detail', {id: group.id, page: p}) }}" class="btn btn-ghost btn-sm" style="min-width: 36px; padding: 0.5rem;">{{ p }}</a>
                        {% endif %}
                    {% endfor %}
                </div>
                {% if page < totalPages %}
                    <a href="{{ path('app_group_detail', {id: group.id, page: page + 1}) }}" class="btn btn-ghost btn-sm" style="padding: 0.5rem 0.75rem;">
                        Suivant
                        <svg style="width: 14px; height: 14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </a>
                {% endif %}
            </div>
            {% endif %}
        {% endif %}
    </div>

    {# SIDEBAR DROITE (300px) #}
    <div style="position: sticky; top: 1.5rem;">
        
        {# Règles #}
        <div class="card" style="border-radius: 12px; padding: 1.25rem; margin-bottom: 1rem;">
            <h4 style="font-size: 14px; font-weight: 600; color: #111827; margin: 0 0 0.75rem 0; display: flex; align-items: center; gap: 0.375rem;">
                <svg style="width: 16px; height: 16px; color: #f59e0b;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
                Règles
            </h4>
            <ul style="margin: 0; padding-left: 1.25rem; list-style: disc; display: flex; flex-direction: column; gap: 0.375rem;">
                <li style="font-size: 12px; color: #374151;">Soyez respectueux</li>
                <li style="font-size: 12px; color: #374151;">Pas de spam</li>
                <li style="font-size: 12px; color: #374151;">Travaillez ensemble</li>
            </ul>
        </div>

        {# Membres #}
        {% if group.members|length > 0 %}
        <div class="card" style="border-radius: 12px; padding: 1.25rem; margin-bottom: 1rem;">
            <h4 style="font-size: 14px; font-weight: 600; color: #111827; margin: 0 0 0.75rem 0;">
                Membres ({{ group.members|length }})
            </h4>
            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                {% for member in group.members|slice(0, 5) %}
                <div style="display: flex; align-items: center; gap: 0.5rem;">
                    <div style="width: 32px; height: 32px; border-radius: 50%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 12px; flex-shrink: 0;">
                        {{ member.user.fullName|slice(0,1)|upper }}
                    </div>
                    <div style="flex: 1; min-width: 0;">
                        <div style="font-size: 13px; color: #111827; font-weight: 500;">{{ member.user.fullName }}</div>
                        <div style="font-size: 11px; color: #9ca3af;">{{ member.memberRole == 'admin' ? 'Admin' : (member.memberRole == 'owner' ? 'Créateur' : 'Membre') }}</div>
                    </div>
                    <svg style="width: 14px; height: 14px; color: #10b981; flex-shrink: 0;" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        {# Activité récente #}
        {% if group.posts|length > 0 %}
        <div class="card" style="border-radius: 12px; padding: 1.25rem;">
            <h4 style="font-size: 14px; font-weight: 600; color: #111827; margin: 0 0 0.75rem 0;">Activité récente</h4>
            <div style="display: flex; flex-direction: column; gap: 0.625rem;">
                {% for post in group.posts|slice(0, 3) %}
                <div style="display: flex; align-items: start; gap: 0.5rem; padding: 0.625rem; background: #f9fafb; border-radius: 8px; border-left: 3px solid #667eea;">
                    <div style="width: 24px; height: 24px; border-radius: 50%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 10px; flex-shrink: 0;">
                        {{ post.author.fullName|slice(0,1)|upper }}
                    </div>
                    <div style="flex: 1; min-width: 0;">
                        <div style="font-size: 11px; color: #111827; font-weight: 500;">{{ post.author.fullName }} {{ include('components/_teacher_badge.html.twig', {user: post.author}) }}</div>
                        <div style="font-size: 11px; color: #6b7280; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                            {% if post.title %}{{ post.title }}{% else %}{{ post.body|slice(0, 40) }}...{% endif %}
                        </div>
                        <div style="font-size: 10px; color: #9ca3af; margin-top: 0.25rem;">{{ post.createdAt|date('d/m H:i') }}</div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}
    </div>

</div>

<style>
@keyframes aispin { to { transform: rotate(360deg); } }
</style>

<script>
// AJAX AI Summarize Post
document.querySelectorAll('.ai-summarize-btn').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
        e.preventDefault();
        var postId = btn.dataset.postId;
        var groupId = btn.dataset.groupId;
        var token = btn.dataset.token;
        var icon = btn.querySelector('.ai-sum-icon');
        var spinner = btn.querySelector('.ai-sum-spinner');
        var label = btn.querySelector('.ai-sum-label');
        var zone = document.getElementById('ai-summary-zone-' + postId);

        btn.disabled = true;
        btn.style.opacity = '0.7';
        btn.style.cursor = 'wait';
        if (icon) icon.style.display = 'none';
        if (spinner) spinner.style.display = 'block';

        var seconds = 0;
        var timer = setInterval(function() {
            seconds++;
            label.textContent = 'Génération... ' + seconds + 's';
        }, 1000);

        fetch('/fo/groups/' + groupId + '/post/' + postId + '/ai-summarize', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({ _token: token })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            clearInterval(timer);
            if (data.success) {
                var tagsHtml = '';
                if (data.tags && data.tags.length) {
                    tagsHtml = '<div style="display:flex;flex-wrap:wrap;gap:0.375rem;">';
                    data.tags.forEach(function(t) {
                        tagsHtml += '<span class="badge badge-primary" style="font-size:10px;padding:0.25rem 0.5rem;">' + t + '</span>';
                    });
                    tagsHtml += '</div>';
                }
                zone.innerHTML = '<div style="margin-top:1rem;padding:1rem;background:linear-gradient(135deg,#f9fafb 0%,#f3f4f6 100%);border-radius:8px;border-left:3px solid #667eea;">'
                    + '<div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem;">'
                    + '<svg style="width:16px;height:16px;color:#667eea;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>'
                    + '<strong style="font-size:12px;color:#667eea;">Résumé IA</strong>'
                    + (data.category ? '<span class="badge badge-secondary" style="font-size:10px;margin-left:auto;">' + data.category + '</span>' : '')
                    + '</div>'
                    + '<p style="font-size:13px;color:#374151;line-height:1.5;margin:0 0 0.5rem 0;">' + data.summary + '</p>'
                    + tagsHtml
                    + '</div>'
                    + buildFeedbackWidget(data.ai_log_id);
            } else {
                label.textContent = data.error || 'Erreur';
                btn.style.opacity = '1';
                btn.style.background = '#ef4444';
                setTimeout(function() { btn.disabled = false; btn.style.opacity = '1'; btn.style.background = ''; label.textContent = 'Résumer (IA)'; if(icon) icon.style.display=''; if(spinner) spinner.style.display='none'; }, 3000);
            }
        })
        .catch(function(err) {
            clearInterval(timer);
            label.textContent = 'Erreur réseau';
            btn.style.background = '#ef4444';
            setTimeout(function() { btn.disabled = false; btn.style.opacity = '1'; btn.style.background = ''; label.textContent = 'Résumer (IA)'; if(icon) icon.style.display=''; if(spinner) spinner.style.display='none'; }, 3000);
        });
    });
});

// Reusable: build feedback widget HTML
function buildFeedbackWidget(logId) {
    if (!logId) return '';
    var stars = '';
    for (var i = 1; i <= 5; i++) {
        stars += '<button type="button" class="ai-fb-star" data-rating="' + i + '" style="background:none;border:none;cursor:pointer;padding:2px;transition:transform 0.15s;" title="' + i + '/5">'
            + '<svg viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="2" width="18" height="18" style="transition:all 0.15s;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>'
            + '</button>';
    }
    return '<div class="ai-feedback-widget" data-log-id="' + logId + '" style="display:inline-flex;align-items:center;gap:0.5rem;margin-top:0.5rem;padding:0.5rem 0.75rem;background:#f9fafb;border-radius:8px;border:1px solid #e5e7eb;">'
        + '<span style="font-size:12px;color:#6b7280;">Utile ?</span>'
        + '<div class="ai-feedback-stars" style="display:flex;gap:2px;">' + stars + '</div>'
        + '<span class="ai-fb-msg" style="font-size:11px;color:#10b981;display:none;">Merci !</span>'
        + '</div>';
}

// Global: AI Feedback star click handler (delegated)
document.addEventListener('click', function(e) {
    var star = e.target.closest('.ai-fb-star');
    if (!star) return;
    var widget = star.closest('.ai-feedback-widget');
    if (!widget || widget.dataset.sent) return;
    var logId = widget.dataset.logId;
    var rating = parseInt(star.dataset.rating);
    var allStars = widget.querySelectorAll('.ai-fb-star svg');
    allStars.forEach(function(s, idx) {
        s.setAttribute('fill', idx < rating ? '#f59e0b' : 'none');
        s.setAttribute('stroke', idx < rating ? '#f59e0b' : '#d1d5db');
    });
    widget.dataset.sent = '1';
    widget.querySelectorAll('.ai-fb-star').forEach(function(b) { b.style.pointerEvents = 'none'; });
    var msg = widget.querySelector('.ai-fb-msg');

    fetch('{{ path("fo_ai_feedback") }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ log_id: logId, rating: rating })
    })
    .then(function(r) { return r.json(); })
    .then(function(d) { if (msg) { msg.style.display = 'inline'; msg.textContent = 'Merci !'; } })
    .catch(function() { if (msg) { msg.style.display = 'inline'; msg.textContent = 'Erreur'; msg.style.color = '#ef4444'; } });
});
</script>
{% endblock %}
