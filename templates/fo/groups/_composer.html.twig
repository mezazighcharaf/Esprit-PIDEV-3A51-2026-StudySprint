{# Composant: Formulaire création post #}
{# Props attendues: group #}
<div class="card" id="composer" style="border-radius: 12px;">
    <div style="padding: 1.25rem 1.5rem; border-bottom: 1px solid #f3f4f6;">
        <h3 style="font-size: 16px; font-weight: 600; color: #111827; margin: 0; display: flex; align-items: center; gap: 0.5rem;">
            <svg style="width: 18px; height: 18px; flex-shrink: 0; color: #6b7280;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
            </svg>
            Nouvelle publication
        </h3>
    </div>
    <div style="padding: 1.5rem;">
        <form action="{{ path('fo_groups_create_post', {id: group.id}) }}" method="post">
            <input type="hidden" name="_token" value="{{ csrf_token('create_post_' ~ group.id) }}">
            <div style="margin-bottom: 1.25rem;">
                <label for="title" style="display: block; font-size: 13px; font-weight: 500; color: #374151; margin-bottom: 0.5rem;">
                    Titre <span style="color: #9ca3af; font-weight: 400;">(optionnel)</span>
                </label>
                <input 
                    type="text" 
                    name="title" 
                    id="title" 
                    class="form-input" 
                    style="width: 100%; font-size: 14px; padding: 0.625rem 0.875rem; border-radius: 8px;"
                    placeholder="Un titre accrocheur pour votre publication...">
            </div>
            
            <div style="margin-bottom: 1.25rem;">
                <label for="body" style="display: block; font-size: 13px; font-weight: 500; color: #374151; margin-bottom: 0.5rem;">
                    Message <span style="color: #ef4444; font-weight: 600;">*</span>
                </label>
                <textarea 
                    name="body" 
                    id="body" 
                    class="form-textarea" 
                    style="width: 100%; font-size: 14px; padding: 0.75rem; border-radius: 8px; line-height: 1.6;"
                    rows="4" 
                    required 
                    placeholder="Partagez vos idées, questions ou ressources..."></textarea>
            </div>
            
            <div style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding-top: 0.5rem;">
                <p style="font-size: 12px; color: #9ca3af; display: flex; align-items: center; gap: 0.375rem;">
                    <svg style="width: 14px; height: 14px; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    Soyez respectueux
                </p>
                <button type="submit" class="btn btn-primary">
                    <svg style="width: 16px; height: 16px; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                    </svg>
                    Publier
                </button>
            </div>
        </form>
    </div>
</div>
