{# Composant: Card Post avec commentaires #}
{# Props attendues: post, group, currentUser, isOwnerOrAdmin #}
<div class="card" id="post-{{ post.id }}" style="border-radius: 12px;">
    <div style="padding: 1.5rem;">
        {# Header post #}
        <div style="display: flex; align-items: flex-start; gap: 0.875rem; margin-bottom: 1rem;">
            <div style="width: 42px; height: 42px; border-radius: 50%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 16px; flex-shrink: 0;">
                {{ post.author.fullName|slice(0,1)|upper }}
            </div>
            <div style="flex: 1; min-width: 0;">
                <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 0.75rem;">
                    <div>
                        <div style="font-weight: 600; color: #111827; font-size: 14px; margin-bottom: 0.125rem;">{{ post.author.fullName }} {{ include('components/_teacher_badge.html.twig', {user: post.author}) }}</div>
                        <div style="font-size: 12px; color: #9ca3af;">{{ post.createdAt|date('d/m/Y à H:i') }}</div>
                    </div>
                    {% if currentUser and (post.author.id == currentUser.id or isOwnerOrAdmin) %}
                    <form action="{{ path('fo_groups_delete_post', {groupId: group.id, postId: post.id}) }}"
                          method="post"
                          onsubmit="return confirm('Supprimer cette publication ?')"
                          style="display: inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_post_' ~ post.id) }}">
                        <button type="submit" style="color: #d1d5db; background: none; border: none; cursor: pointer; padding: 0.25rem; border-radius: 6px; transition: all 0.2s;" title="Supprimer" onmouseover="this.style.color='#ef4444'; this.style.background='#fef2f2';" onmouseout="this.style.color='#d1d5db'; this.style.background='none';">
                            <svg style="width: 18px; height: 18px; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                            </svg>
                        </button>
                    </form>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Contenu post #}
        {% if post.title %}
            <h4 style="font-weight: 600; font-size: 17px; color: #111827; margin: 0 0 0.75rem 0; line-height: 1.4;">{{ post.title }}</h4>
        {% endif %}
        <div style="color: #374151; line-height: 1.65; font-size: 14px;">{{ post.body|nl2br }}</div>

        {# Résumé IA #}
        <div id="ai-summary-zone-{{ post.id }}">
        {% if post.aiSummary or post.aiCategory or post.aiTags %}
        <div style="margin-top: 1rem; padding: 1rem; background: linear-gradient(135deg, #f9fafb 0%, #f3f4f6 100%); border-radius: 8px; border-left: 3px solid #667eea;">
            <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
                <svg style="width: 16px; height: 16px; color: #667eea;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
                <strong style="font-size: 12px; color: #667eea;">Résumé IA</strong>
                {% if post.aiCategory %}
                <span class="badge badge-secondary" style="font-size: 10px; margin-left: auto;">{{ post.aiCategory }}</span>
                {% endif %}
            </div>
            <p style="font-size: 13px; color: #374151; line-height: 1.5; margin: 0 0 0.5rem 0;">{{ post.aiSummary }}</p>
            {% if post.aiTags %}
            <div style="display: flex; flex-wrap: wrap; gap: 0.375rem;">
                {% for tag in post.aiTags %}
                <span class="badge badge-primary" style="font-size: 10px; padding: 0.25rem 0.5rem;">{{ tag }}</span>
                {% endfor %}
            </div>
            {% endif %}
        </div>
        {% else %}
        <button type="button" class="btn btn-sm ai-summarize-btn" data-post-id="{{ post.id }}" data-group-id="{{ group.id }}" data-token="{{ csrf_token('ai_summarize_post_' ~ post.id) }}" style="margin-top: 1rem; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; font-size: 12px; display: inline-flex; align-items: center; gap: 0.25rem;">
            <svg class="ai-sum-icon" style="width: 14px; height: 14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
            <span class="ai-sum-spinner" style="display: none; width: 14px; height: 14px; border: 2px solid rgba(255,255,255,0.3); border-top-color: white; border-radius: 50%; animation: aispin 0.8s linear infinite;"></span>
            <span class="ai-sum-label">Résumer (IA)</span>
        </button>
        {% endif %}
        </div>

        {# Zone commentaires #}
        {% if post.replies|length > 0 %}
        <div style="margin-top: 1.25rem; padding-top: 1.25rem; border-top: 1px solid #f3f4f6;">
            <p style="font-size: 13px; font-weight: 600; color: #6b7280; margin: 0 0 1rem 0;">
                {{ post.replies|length }} commentaire{{ post.replies|length > 1 ? 's' : '' }}
            </p>
            <div style="display: flex; flex-direction: column; gap: 1rem;">
                {% for reply in post.replies %}
                <div style="display: flex; align-items: flex-start; gap: 0.75rem; padding-left: 1.25rem; border-left: 3px solid #f3f4f6;">
                    <div style="width: 32px; height: 32px; border-radius: 50%; background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%); color: #6b7280; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; flex-shrink: 0;">
                        {{ reply.author.fullName|slice(0,1)|upper }}
                    </div>
                    <div style="flex: 1; min-width: 0;">
                        <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem; margin-bottom: 0.375rem;">
                            <div>
                                <strong style="font-size: 13px; color: #111827; font-weight: 600;">{{ reply.author.fullName }} {{ include('components/_teacher_badge.html.twig', {user: reply.author}) }}</strong>
                                <span style="font-size: 11px; color: #9ca3af; margin-left: 0.375rem;">{{ reply.createdAt|date('d/m H:i') }}</span>
                            </div>
                            {% if currentUser and (reply.author.id == currentUser.id or isOwnerOrAdmin) %}
                            <form action="{{ path('fo_groups_delete_post', {groupId: group.id, postId: reply.id}) }}"
                                  method="post"
                                  onsubmit="return confirm('Supprimer ce commentaire ?')"
                                  style="display: inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_post_' ~ reply.id) }}">
                                <button type="submit" style="color: #d1d5db; background: none; border: none; cursor: pointer; padding: 0.125rem; border-radius: 4px; transition: all 0.2s;" title="Supprimer" onmouseover="this.style.color='#ef4444'; this.style.background='#fef2f2';" onmouseout="this.style.color='#d1d5db'; this.style.background='none';">
                                    <svg style="width: 14px; height: 14px; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                    </svg>
                                </button>
                            </form>
                            {% endif %}
                        </div>
                        <p style="font-size: 13px; color: #374151; line-height: 1.5; margin: 0;">{{ reply.body|nl2br }}</p>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        {# Formulaire commentaire #}
        <div style="margin-top: 1.25rem; padding-top: 1.25rem; border-top: 1px solid #f3f4f6;">
            <form action="{{ path('fo_groups_create_comment', {groupId: group.id, postId: post.id}) }}"
                  method="post"
                  style="display: flex; gap: 0.625rem; align-items: center;">
                <input type="hidden" name="_token" value="{{ csrf_token('create_comment_' ~ post.id) }}">
                <input 
                    type="text"
                    name="body"
                    class="form-input"
                    style="flex: 1; font-size: 13px; padding: 0.625rem 0.875rem; border-radius: 8px;"
                    placeholder="Écrire un commentaire..."
                    required>
                <button type="submit" class="btn btn-secondary btn-sm" style="padding: 0.625rem 1rem; border-radius: 8px;">
                    <svg style="width: 14px; height: 14px; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                    </svg>
                </button>
            </form>
        </div>
    </div>
</div>
