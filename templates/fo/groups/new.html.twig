{% extends 'layouts/fo.html.twig' %}
{% block title %}Nouveau Groupe - StudySprint{% endblock %}

{% block content %}
<div style="margin-bottom: 1.5rem;">
    <a href="{{ path('app_groups') }}" class="btn btn-ghost btn-sm">
        <svg style="width: 16px; height: 16px; margin-right: 0.375rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Retour aux groupes
    </a>
</div>

<div style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); border-radius: 12px; padding: 2rem; margin-bottom: 2rem; color: white;">
    <div style="display: flex; align-items: center; gap: 1rem;">
        <div style="width: 56px; height: 56px; background: rgba(255,255,255,0.25); border-radius: 12px; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(10px);">
            <svg style="width: 28px; height: 28px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
        </div>
        <div>
            <h1 style="font-size: 24px; font-weight: 700; margin: 0;">Créer un groupe d'étude</h1>
            <p style="font-size: 14px; opacity: 0.9; margin: 0;">Espace collaboratif pour travailler ensemble</p>
        </div>
    </div>
</div>

<div class="card" style="max-width: 700px; border-radius: 12px;">
    <div style="padding: 2rem;">
        {{ form_start(form) }}
            <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                <div>
                    {{ form_label(form.name, null, {'label_attr': {'style': 'display: block; font-weight: 600; margin-bottom: 0.5rem; color: #111827; font-size: 14px;'}}) }}
                    {{ form_widget(form.name, {'attr': {'class': 'form-input', 'style': 'width: 100%; padding: 0.75rem; border-radius: 8px; border: 2px solid #e5e7eb; font-size: 15px;', 'placeholder': 'Ex: Groupe Maths L3'}}) }}
                    {{ form_errors(form.name) }}
                </div>

                <div>
                    {{ form_label(form.description, null, {'label_attr': {'style': 'display: block; font-weight: 600; margin-bottom: 0.5rem; color: #111827; font-size: 14px;'}}) }}
                    {{ form_widget(form.description, {'attr': {'class': 'form-textarea', 'style': 'width: 100%; padding: 0.75rem; border-radius: 8px; border: 2px solid #e5e7eb; font-size: 15px; min-height: 100px;', 'placeholder': 'Décrivez l\'objectif du groupe...'}}) }}
                    {{ form_errors(form.description) }}
                </div>

                <div>
                    {{ form_label(form.privacy, null, {'label_attr': {'style': 'display: block; font-weight: 600; margin-bottom: 0.5rem; color: #111827; font-size: 14px;'}}) }}
                    {{ form_widget(form.privacy, {'attr': {'class': 'form-select', 'style': 'width: 100%; padding: 0.75rem; border-radius: 8px; border: 2px solid #e5e7eb; font-size: 15px;'}}) }}
                    {{ form_errors(form.privacy) }}
                    <p style="font-size: 12px; color: #6b7280; margin-top: 0.375rem;">
                        🔒 Publics: visibles par tous • Privés: sur invitation uniquement
                    </p>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center; padding-top: 1.5rem; border-top: 2px solid #f3f4f6;">
                    <a href="{{ path('app_groups') }}" class="btn btn-ghost">Annuler</a>
                    <button type="submit" class="btn btn-primary" style="padding: 0.75rem 2rem;">
                        <svg style="width: 18px; height: 18px; margin-right: 0.5rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        Créer le groupe
                    </button>
                </div>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
