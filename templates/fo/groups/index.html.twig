{% extends 'layouts/fo.html.twig' %}
{% block title %}Groupes d'étude - StudySprint{% endblock %}

{% block content %}
{# Header #}
<div style="margin-bottom: 2rem;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1.5rem; margin-bottom: 0.75rem;">
        <div style="flex: 1;">
            <h1 style="font-size: 24px; font-weight: 700; color: #1f2937; margin: 0 0 0.5rem 0;">Groupes d'Étude</h1>
            <p style="font-size: 14px; color: #6b7280; margin: 0;">Rejoignez et collaborez avec vos pairs</p>
        </div>
        <a href="{{ path('fo_groups_new') }}" class="btn btn-primary">
            <svg style="width: 16px; height: 16px; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
            </svg>
            Créer un groupe
        </a>
    </div>
</div>

{# Flash messages #}
{% for message in app.flashes('success') %}
    <div class="alert alert-success" style="margin-bottom: 1.5rem;">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="alert alert-danger" style="margin-bottom: 1.5rem;">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('info') %}
    <div class="alert alert-info" style="margin-bottom: 1.5rem;">{{ message }}</div>
{% endfor %}

{# Search Bar #}
<form method="get" action="{{ path('app_groups') }}" style="display: flex; gap: 0.75rem; margin-bottom: 1.5rem; align-items: center;">
    <div style="flex: 1; position: relative;">
        <svg style="position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: #9ca3af;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input type="text" name="q" value="{{ q }}" placeholder="Rechercher un groupe..." style="width: 100%; padding: 0.625rem 0.75rem 0.625rem 2.25rem; border: 1px solid #d1d5db; border-radius: 8px; font-size: 14px; outline: none;" />
    </div>
    <button type="submit" class="btn btn-primary btn-sm">Rechercher</button>
    {% if q %}
    <a href="{{ path('app_groups') }}" class="btn btn-ghost btn-sm">Réinitialiser</a>
    {% endif %}
</form>

{# MES GROUPES #}
{% if myGroups is not empty %}
<div style="margin-bottom: 3rem;">
    <h2 style="font-size: 18px; font-weight: 600; color: #111827; margin: 0 0 1.25rem 0;">
        Mes groupes <span style="color: #9ca3af; font-weight: 400;">({{ myGroups|length }})</span>
    </h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
        {% for group in myGroups %}
            {% set bgColors = ['linear-gradient(135deg, #e0f2fe 0%, #bfdbfe 100%)', 'linear-gradient(135deg, #fed7aa 0%, #fdba74 100%)', 'linear-gradient(135deg, #dbeafe 0%, #93c5fd 100%)', 'linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%)'] %}
            {% set bgColor = bgColors[loop.index0 % 4] %}
            <div class="card" style="border-radius: 12px; transition: transform 0.2s, box-shadow 0.2s; overflow: hidden;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 10px 25px rgba(0,0,0,0.08)';" onmouseout="this.style.transform=''; this.style.boxShadow='';">
                {# Zone illustration #}
                <div style="height: 120px; background: {{ bgColor }}; display: flex; align-items: center; justify-content: center; position: relative;">
                    <svg style="width: 80px; height: 80px; opacity: 0.4;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                    </svg>
                </div>
                
                <div style="padding: 1.5rem;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; margin-bottom: 1rem;">
                        <h3 style="font-size: 16px; font-weight: 600; color: #111827; line-height: 1.4; flex: 1; margin: 0;">{{ group.name }}</h3>
                        <span class="badge badge-{{ group.privacy == 'PUBLIC' ? 'success' : 'secondary' }}" style="flex-shrink: 0; font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em;">
                            {{ group.privacy == 'PUBLIC' ? 'PUBLIC' : 'PRIVÉ' }}
                        </span>
                    </div>
                    
                    <p style="font-size: 13px; color: #6b7280; line-height: 1.5; margin: 0 0 1.25rem 0;">
                        {% if group.description %}
                            {{ group.description|length > 90 ? group.description|slice(0, 90) ~ '...' : group.description }}
                        {% else %}
                            <span style="font-style: italic; color: #9ca3af;">Aucune description</span>
                        {% endif %}
                    </p>
                    
                    <div style="display: flex; align-items: center; gap: 1.5rem; margin-bottom: 1.25rem;">
                        <span style="display: flex; align-items: center; gap: 0.375rem; font-size: 13px; color: #6b7280;">
                            <svg style="width: 16px; height: 16px; flex-shrink: 0; color: #9ca3af;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                            </svg>
                            {{ group.members|length }} Membre{{ group.members|length > 1 ? 's' : '' }}
                        </span>
                        <span style="display: flex; align-items: center; gap: 0.375rem; font-size: 13px; color: #6b7280;">
                            <svg style="width: 16px; height: 16px; flex-shrink: 0; color: #9ca3af;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                            </svg>
                            {{ group.posts|length }} Post{{ group.posts|length > 1 ? 's' : '' }}
                        </span>
                    </div>
                    
                    <a href="{{ path('app_group_detail', {id: group.id}) }}" class="btn btn-primary btn-sm" style="width: 100%; justify-content: center;">Voir le groupe</a>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endif %}

{# AUTRES GROUPES #}
<div>
    <h2 style="font-size: 18px; font-weight: 600; color: #111827; margin: 0 0 1.25rem 0;">
        {% if myGroups is empty %}Tous les groupes{% else %}Autres groupes publics{% endif %} <span style="color: #9ca3af; font-weight: 400;">({{ otherGroups|length }})</span>
    </h2>
    
    {% if otherGroups is empty %}
        <div class="card" style="text-align: center; padding: 4rem 2rem; border-radius: 12px;">
            <svg style="width: 80px; height: 80px; margin: 0 auto 1.5rem; color: #d1d5db;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
            <h3 style="font-size: 18px; font-weight: 600; color: #1f2937; margin: 0 0 0.5rem 0;">
                {% if myGroups is empty %}Aucun groupe disponible{% else %}Tous les groupes rejoints{% endif %}
            </h3>
            <p style="color: #6b7280; font-size: 14px; margin: 0 0 1.5rem 0;">
                {% if myGroups is empty %}Créez le premier groupe pour commencer à collaborer{% else %}Vous avez rejoint tous les groupes publics{% endif %}
            </p>
            {% if myGroups is empty %}
                <a href="{{ path('fo_groups_new') }}" class="btn btn-primary">
                    <svg style="width: 16px; height: 16px; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                    </svg>
                    Créer un groupe
                </a>
            {% endif %}
        </div>
    {% else %}
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
            {% for group in otherGroups %}
                {% set bgColors = ['linear-gradient(135deg, #e0f2fe 0%, #bfdbfe 100%)', 'linear-gradient(135deg, #fed7aa 0%, #fdba74 100%)', 'linear-gradient(135deg, #dbeafe 0%, #93c5fd 100%)', 'linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%)'] %}
                {% set bgColor = bgColors[loop.index0 % 4] %}
                <div class="card" style="border-radius: 12px; transition: transform 0.2s, box-shadow 0.2s; overflow: hidden;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 10px 25px rgba(0,0,0,0.08)';" onmouseout="this.style.transform=''; this.style.boxShadow='';">
                    {# Zone illustration #}
                    <div style="height: 120px; background: {{ bgColor }}; display: flex; align-items: center; justify-content: center; position: relative;">
                        <svg style="width: 80px; height: 80px; opacity: 0.4;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                        </svg>
                    </div>
                    
                    <div style="padding: 1.5rem;">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; margin-bottom: 1rem;">
                            <h3 style="font-size: 16px; font-weight: 600; color: #111827; line-height: 1.4; flex: 1; margin: 0;">{{ group.name }}</h3>
                            <span class="badge badge-success" style="flex-shrink: 0; font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em;">PUBLIC</span>
                        </div>
                        
                        <p style="font-size: 13px; color: #6b7280; line-height: 1.5; margin: 0 0 1.25rem 0;">
                            {% if group.description %}
                                {{ group.description|length > 90 ? group.description|slice(0, 90) ~ '...' : group.description }}
                            {% else %}
                                <span style="font-style: italic; color: #9ca3af;">Aucune description</span>
                            {% endif %}
                        </p>
                        
                        <div style="display: flex; align-items: center; gap: 1.5rem; margin-bottom: 1.25rem;">
                            <span style="display: flex; align-items: center; gap: 0.375rem; font-size: 13px; color: #6b7280;">
                                <svg style="width: 16px; height: 16px; flex-shrink: 0; color: #9ca3af;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                                </svg>
                                {{ group.members|length }} Membre{{ group.members|length > 1 ? 's' : '' }}
                            </span>
                            <span style="display: flex; align-items: center; gap: 0.375rem; font-size: 13px; color: #6b7280;">
                                <svg style="width: 16px; height: 16px; flex-shrink: 0; color: #9ca3af;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                                </svg>
                                {{ group.posts|length }} Post{{ group.posts|length > 1 ? 's' : '' }}
                            </span>
                        </div>
                        
                        <a href="{{ path('app_group_detail', {id: group.id}) }}" class="btn btn-primary btn-sm" style="width: 100%; justify-content: center;">Voir le groupe</a>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
