{% if posts is empty %}
<div class="text-center py-12">
    <div style="width: 80px; height: 80px; background: var(--color-gray-100); color: var(--color-gray-300); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto var(--space-4);">
        <i class="fa-solid fa-newspaper fa-3x"></i>
    </div>
    <h3 style="color: var(--color-gray-900); font-weight: var(--font-bold); margin-bottom: var(--space-2);">Aucun post pour le moment</h3>
    <p style="color: var(--color-gray-500);">Soyez le premier à partager quelque chose avec ce groupe !</p>
</div>
{% else %}
    {% for post in posts %}
    <article class="glass-card post-card mb-6 overflow-hidden" data-post-id="{{ post.id }}" style="border-radius: var(--border-radius-xl);">
        <div class="p-6">
            <div class="d-flex justify-content-between align-items-start mb-6">
                <div class="d-flex gap-4">
                    <div class="avatar avatar-md avatar-initials" style="background: var(--color-primary-light); color: var(--color-primary); box-shadow: var(--shadow-sm);">
                        {{ post.author_initials }}
                    </div>
                    <div>
                        <div style="font-weight: var(--font-bold); color: var(--color-gray-900); font-size: var(--text-base);">{{ post.author }}</div>
                        <div class="d-flex align-items-center gap-2 mt-1">
                            <span class="badge" style="background: var(--color-gray-100); color: var(--color-gray-500); border: none; font-size: 0.7rem; text-transform: capitalize;">{{ post.author_role }}</span>
                            <span style="color: var(--color-gray-400); font-size: var(--text-xs);">• {{ post.created_at }}</span>
                        </div>
                    </div>
                </div>
                
                {% if post.can_delete %}
                <div class="dropdown">
                    <button class="btn btn-ghost btn-sm btn-icon" data-dropdown-trigger style="border-radius: var(--border-radius-full);">
                        <i class="fa-solid fa-ellipsis-vertical"></i>
                    </button>
                    <div class="dropdown-menu dropdown-menu-right">
                        <button class="dropdown-item text-danger" data-post-delete="{{ post.id }}">
                            <i class="fa-solid fa-trash-can me-2"></i> Supprimer
                        </button>
                    </div>
                </div>
                {% endif %}
            </div>

            {% if post.title %}
            <h2 style="font-size: var(--text-xl); font-weight: var(--font-bold); color: var(--color-gray-900); margin-bottom: var(--space-3); line-height: 1.3;">
                {{ post.title }}
            </h2>
            {% endif %}

            <div style="color: var(--color-gray-700); font-size: var(--text-base); line-height: 1.6; margin-bottom: var(--space-6);">
                {{ post.body|nl2br }}
            </div>

            {% if post.attachment_url %}
            <div class="mb-6">
                <a href="{{ post.attachment_url }}" target="_blank" class="p-4" style="display: flex; align-items: center; gap: var(--space-3); background: var(--color-gray-50); border: 1px solid var(--color-gray-200); border-radius: var(--border-radius-lg); text-decoration: none; color: var(--color-gray-900); transition: all var(--transition-fast);">
                    <div style="width: 40px; height: 40px; border-radius: var(--border-radius-md); background: white; display: flex; align-items: center; justify-content: center; color: var(--color-primary); box-shadow: var(--shadow-xs);">
                        <i class="fa-solid fa-file-pdf fa-xl"></i>
                    </div>
                    <div style="flex: 1; min-width: 0;">
                        <div style="font-weight: var(--font-semibold); font-size: var(--text-sm); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">Voir la ressource jointe</div>
                        <div style="font-size: var(--text-xs); color: var(--color-gray-500);">Document partagé</div>
                    </div>
                    <i class="fa-solid fa-chevron-right text-muted"></i>
                </a>
            </div>
            {% endif %}

            <div style="display: flex; align-items: center; justify-content: space-between; padding-top: var(--space-4); border-top: 1px solid var(--color-gray-100);">
                <div style="display: flex; gap: var(--space-2);">
                    <button class="btn btn-ghost btn-sm {{ post.user_liked ? 'active' : '' }}" data-like-post="{{ post.id }}" style="border-radius: var(--border-radius-full); padding: 6px 16px; gap: 8px;">
                        <i class="{{ post.user_liked ? 'fa-solid' : 'fa-regular' }} fa-heart" style="color: {{ post.user_liked ? 'var(--color-error)' : 'inherit' }};"></i>
                        <span style="font-weight: var(--font-semibold);">{{ post.likes_count }}</span>
                    </button>
                    <button class="btn btn-ghost btn-sm" data-view-comments="{{ post.id }}" style="border-radius: var(--border-radius-full); padding: 6px 16px; gap: 8px;">
                        <i class="fa-regular fa-comment"></i>
                        <span style="font-weight: var(--font-semibold);">{{ post.comments_count }}</span>
                    </button>
                    <button class="btn btn-ghost btn-sm" data-share-post="{{ post.id }}" style="border-radius: var(--border-radius-full); padding: 6px 16px;">
                        <i class="fa-solid fa-share-nodes"></i>
                    </button>
                </div>

                <div class="user-rating-stars" data-post-rating="{{ post.id }}" data-current-rating="{{ post.user_rating }}" style="display: flex; align-items: center; gap: 4px;">
                    {% for i in 1..5 %}
                    <button class="star-btn" data-value="{{ i }}" style="background: none; border: none; padding: 2px; cursor: pointer; color: {{ post.user_rating >= i ? 'var(--color-warning)' : 'var(--color-gray-300)' }}; transition: transform 0.1s ease;">
                        <i class="{{ post.user_rating >= i ? 'fa-solid' : 'fa-regular' }} fa-star" style="font-size: 1.1rem;"></i>
                    </button>
                    {% endfor %}
                    <span class="rating-value ms-2" style="font-size: var(--text-sm); font-weight: var(--font-bold); color: var(--color-gray-900);">{{ post.avg_rating|number_format(1) }}</span>
                </div>
            </div>
        </div>
    </article>
    {% endfor %}
{% endif %}
