<aside class="group-detail-sidebar">
    {# STATS CARD #}
    <div class="glass-card mb-6 p-5">
        <h4 style="font-size: var(--text-xs); font-weight: var(--font-bold); text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-gray-400); margin-bottom: var(--space-4);">Statistiques</h4>
        <div style="display: flex; flex-direction: column; gap: var(--space-3);">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <span style="color: var(--color-gray-600); font-size: var(--text-sm);"><i class="fa-solid fa-users" style="width: 20px; color: var(--color-primary);"></i> Membres</span>
                <span class="badge" style="background: var(--color-primary-light); color: var(--color-primary); font-weight: var(--font-semibold); border: none;">{{ group.members_count }}</span>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <span style="color: var(--color-gray-600); font-size: var(--text-sm);"><i class="fa-solid fa-newspaper" style="width: 20px; color: var(--color-primary);"></i> Publications</span>
                <span class="badge" style="background: var(--color-gray-100); color: var(--color-gray-600); border: none;">{{ posts|length }}</span>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <span style="color: var(--color-gray-600); font-size: var(--text-sm);"><i class="fa-solid fa-clock" style="width: 20px; color: var(--color-primary);"></i> Activité</span>
                <span style="color: var(--color-success); font-weight: var(--font-medium); font-size: var(--text-xs);">Haute</span>
            </div>
        </div>
    </div>

    {# MEMBERS CARD #}
    <div class="glass-card p-5">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-4);">
            <h4 style="font-size: var(--text-xs); font-weight: var(--font-bold); text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-gray-400); margin: 0;">Membres</h4>
            <a href="#" class="btn-link" style="font-size: var(--text-xs); color: var(--color-primary); text-decoration: none;" data-modal-open="view-members-modal">Tout voir</a>
        </div>

        <div class="sidebar-members-list" style="display: flex; flex-direction: column; gap: var(--space-3);">
            {% for member in group.members|slice(0, 5) %}
            <div style="display: flex; align-items: center; gap: var(--space-3);">
                <div class="avatar avatar-sm avatar-initials" style="background: var(--color-gray-100); color: var(--color-gray-600); font-weight: var(--font-semibold); font-size: 0.75rem;">
                    {{ member.initials }}
                </div>
                <div style="flex: 1; min-width: 0;">
                    <div style="font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--color-gray-900); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                        {{ member.name }}
                    </div>
                    <div style="font-size: var(--text-xs); color: var(--color-gray-500); text-transform: capitalize;">
                        {{ member.role }}
                    </div>
                </div>
                {% if member.role == 'admin' %}
                    <i class="fa-solid fa-crown" style="color: var(--color-warning); font-size: 0.7rem;" title="Administrateur"></i>
                {% endif %}
            </div>
            {% endfor %}
        </div>

        {% if is_member and can_invite and group.privacy == 'private' %}
        <button class="btn btn-primary btn-sm w-100 mt-5" data-modal-open="invite-members-modal" style="border-radius: var(--border-radius-md); font-weight: var(--font-semibold); box-shadow: var(--shadow-sm);">
            <i class="fa-solid fa-user-plus" style="margin-right: 6px;"></i>
            Inviter des membres
        </button>
        {% endif %}
    </div>
</aside>
