{% extends 'layouts/fo.html.twig' %}
{% block title %}Planning - StudySprint{% endblock %}

{% block content %}
<div class="planning-header-row">
    <div>
        <h1 class="planning-title">Planning</h1>
        <p class="planning-subtitle">Organise tes sessions et optimise ton plan avec l IA.</p>
    </div>
    <div class="planning-actions">
        <a href="{{ path('fo_planning_session_new') }}" class="btn btn-secondary">Nouvelle session</a>
        <a href="{{ path('fo_planning_plan_new') }}" class="btn btn-primary">Nouveau planning</a>
    </div>
</div>

{% for message in app.flashes('success') %}
    <div class="planning-alert success">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="planning-alert error">{{ message }}</div>
{% endfor %}

<div class="planning-kpis">
    <div class="planning-kpi kpi-a">
        <span class="planning-kpi-value">{{ sessionsCount }}</span>
        <span class="planning-kpi-label">Sessions ce mois</span>
    </div>
    <div class="planning-kpi kpi-b">
        <span class="planning-kpi-value">{{ (totalMinutes / 60)|number_format(1) }}h</span>
        <span class="planning-kpi-label">Travail planifie</span>
    </div>
    <div class="planning-kpi kpi-c">
        <span class="planning-kpi-value">{{ completionRate }}%</span>
        <span class="planning-kpi-label">Taux completion</span>
    </div>
</div>

<div class="planning-grid">
    <section class="planning-main">
        <div class="card planning-card">
            <h2 class="planning-section-title">Calendrier interactif</h2>
            <div id="fullCalendar"></div>
        </div>
    </section>

    <aside class="planning-side">
        <div class="card planning-card">
            <h2 class="planning-section-title">Sessions par jour</h2>
            <canvas id="planningSessionsChart" height="130"></canvas>
        </div>

        <div class="card planning-card">
            <h2 class="planning-section-title">Sessions a venir</h2>
            {% if upcomingTasks is empty %}
                <p class="planning-empty">Aucune session planifiee.</p>
            {% else %}
                <div class="planning-list">
                    {% for task in upcomingTasks %}
                        <a href="{{ path('fo_planning_show', {id: task.plan.id}) }}" class="planning-item">
                            <div class="planning-item-top">
                                <strong>{{ task.title }}</strong>
                                <span class="badge badge-{% if task.taskType == 'REVISION' %}primary{% elseif task.taskType == 'QUIZ' %}warning{% else %}secondary{% endif %}">{{ task.taskType }}</span>
                            </div>
                            <div class="planning-item-meta">{{ task.startAt|date('d/m/Y H:i') }}</div>
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="card planning-card">
            <h2 class="planning-section-title">Optimiser avec l IA</h2>
            {% if userPlans is empty %}
                <p class="planning-empty">Cree un plan pour utiliser l IA.</p>
            {% else %}
                <div class="planning-list">
                    {% for plan in userPlans %}
                        <div class="planning-item-row">
                            <a href="{{ path('fo_planning_show', {id: plan.id}) }}" class="planning-item-link">
                                <strong>{{ plan.title|slice(0, 36) }}</strong>
                                <span>{{ plan.startDate|date('d/m') }} -> {{ plan.endDate|date('d/m') }}</span>
                            </a>
                            <button
                                type="button"
                                class="btn btn-sm btn-primary ai-suggest-btn"
                                data-plan-id="{{ plan.id }}"
                                data-token="{{ csrf_token('ai_suggest_' ~ plan.id) }}"
                                title="Optimiser avec l IA"
                            >
                                IA
                            </button>
                        </div>
                    {% endfor %}
                </div>
                <div id="aiLoadingBanner" class="planning-info-banner" style="display: none;">
                    <span id="aiLoadingText">Analyse IA en cours...</span>
                </div>
            {% endif %}
        </div>
    </aside>
</div>

<style>
.planning-header-row { display:flex; flex-direction:column; align-items:center; gap:.55rem; margin-bottom:1rem; text-align:center; }
.planning-title { margin:0; font-size:1.35rem; font-weight:700; color:#111827; }
.planning-subtitle { margin:.25rem 0 0 0; color:#6b7280; font-size:.92rem; }
.planning-actions { display:flex; flex-wrap:wrap; gap:.5rem; justify-content:center; }
.planning-alert { border-radius:10px; padding:.8rem 1rem; margin-bottom:.8rem; font-weight:500; }
.planning-alert.success { background:#f0fdf4; border:1px solid #bbf7d0; color:#166534; }
.planning-alert.error { background:#fef2f2; border:1px solid #fecaca; color:#991b1b; }
.planning-kpis { display:grid; grid-template-columns:repeat(3, minmax(0,1fr)); gap:1rem; margin-bottom:1rem; }
.planning-kpi { border-radius:12px; padding:1rem 1.1rem; color:#fff; display:flex; flex-direction:column; }
.planning-kpi.kpi-a { background:linear-gradient(135deg,#4facfe 0%,#00f2fe 100%); }
.planning-kpi.kpi-b { background:linear-gradient(135deg,#667eea 0%,#764ba2 100%); }
.planning-kpi.kpi-c { background:linear-gradient(135deg,#43e97b 0%,#38f9d7 100%); }
.planning-kpi-value { font-size:1.9rem; font-weight:700; line-height:1; }
.planning-kpi-label { margin-top:.45rem; font-size:.84rem; opacity:.95; }
.planning-grid { display:grid; grid-template-columns:minmax(0,1fr) 330px; gap:1rem; align-items:start; }
.planning-main, .planning-side { min-width:0; }
.planning-side { display:flex; flex-direction:column; gap:1rem; }
.planning-card { padding:1rem; border-radius:12px; }
.planning-section-title { margin:0 0 .8rem 0; font-size:1rem; font-weight:700; color:#111827; }
.planning-empty { color:#6b7280; margin:.4rem 0; font-size:.9rem; }
.planning-list { display:flex; flex-direction:column; gap:.6rem; }
.planning-item { display:block; text-decoration:none; color:inherit; border:1px solid #e5e7eb; border-radius:10px; padding:.7rem .8rem; background:#f9fafb; }
.planning-item:hover { background:#f3f4f6; border-color:#d1d5db; }
.planning-item-top { display:flex; justify-content:space-between; gap:.5rem; align-items:center; margin-bottom:.25rem; }
.planning-item-meta { color:#6b7280; font-size:.78rem; }
.planning-item-row { display:flex; align-items:center; gap:.5rem; }
.planning-item-link { flex:1; text-decoration:none; color:#111827; border:1px solid #e5e7eb; border-radius:9px; padding:.62rem .75rem; background:#f9fafb; display:flex; flex-direction:column; gap:.2rem; }
.planning-item-link span { color:#6b7280; font-size:.75rem; }
.planning-info-banner { margin-top:.7rem; padding:.7rem .8rem; border-radius:8px; background:#eff6ff; border:1px solid #bfdbfe; color:#1e40af; font-size:.82rem; }
@media (max-width: 1200px) {
    .planning-grid { grid-template-columns:minmax(0,1fr); }
}
@media (max-width: 900px) {
    .planning-kpis { grid-template-columns:1fr; }
}
</style>

<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.17/index.global.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.17/index.global.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    var calEl = document.getElementById('fullCalendar');
    if (calEl) {
        var showPlanUrlTemplate = '{{ path("fo_planning_show", {id: 0}) }}';
        var calendar = new FullCalendar.Calendar(calEl, {
            initialView: 'dayGridMonth',
            locale: 'fr',
            headerToolbar: { left: 'prev,next today', center: 'title', right: 'dayGridMonth,timeGridWeek,listWeek' },
            buttonText: { today: "Aujourd'hui", month: 'Mois', week: 'Semaine', list: 'Liste' },
            events: '{{ path("fo_planning_events_json") }}',
            editable: false,
            eventDisplay: 'block',
            height: 'auto',
            eventClick: function(info) {
                var props = info.event.extendedProps || {};
                if (props.planId) {
                    window.location.href = showPlanUrlTemplate.replace('/0', '/' + props.planId);
                }
            }
        });
        calendar.render();
    }

    var chartCanvas = document.getElementById('planningSessionsChart');
    if (chartCanvas) {
        var labels = {{ sessionsChartLabels|json_encode|raw }};
        var values = {{ sessionsChartData|json_encode|raw }};
        new Chart(chartCanvas, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Sessions',
                    data: values,
                    backgroundColor: '#667eea',
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    x: { ticks: { color: '#6b7280', autoSkip: true, maxTicksLimit: 8 } },
                    y: { beginAtZero: true, ticks: { color: '#6b7280', stepSize: 1 } }
                }
            }
        });
    }

    document.querySelectorAll('.ai-suggest-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var planId = btn.dataset.planId;
            var token = btn.dataset.token;
            var banner = document.getElementById('aiLoadingBanner');
            var bannerText = document.getElementById('aiLoadingText');
            if (banner) banner.style.display = 'block';
            if (bannerText) bannerText.textContent = 'Analyse IA en cours...';
            btn.disabled = true;

            fetch('/fo/planning/' + planId + '/ai-suggest', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify({ _token: token })
            })
            .then(function(resp) { return resp.json(); })
            .then(function(data) {
                if (data.success && data.confirm_url) {
                    window.location.href = data.confirm_url;
                    return;
                }
                if (bannerText) bannerText.textContent = data.error || 'Erreur IA';
                btn.disabled = false;
            })
            .catch(function() {
                if (bannerText) bannerText.textContent = 'Erreur reseau';
                btn.disabled = false;
            });
        });
    });
});
</script>
{% endblock %}
