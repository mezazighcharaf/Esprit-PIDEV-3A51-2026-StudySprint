{% extends 'layouts/fo.html.twig' %}
{% block title %}Nouvelle Session - StudySprint{% endblock %}

{% block content %}
<div style="margin-bottom: 1.5rem;">
    <a href="{{ path('fo_planning_index') }}" class="btn btn-ghost btn-sm">
        <svg style="width: 16px; height: 16px; margin-right: 0.375rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Retour au planning
    </a>
</div>

{# Header gradient #}
<div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px; padding: 2rem; margin-bottom: 2rem; color: white;">
    <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.75rem;">
        <div style="width: 56px; height: 56px; background: rgba(255,255,255,0.25); border-radius: 12px; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(10px);">
            <svg style="width: 28px; height: 28px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
        </div>
        <div>
            <h1 style="font-size: 24px; font-weight: 700; margin: 0;">Nouvelle Session</h1>
            <p style="font-size: 14px; opacity: 0.9; margin: 0;">Planifiez une session de révision, quiz ou flashcards</p>
        </div>
    </div>
</div>

<div class="card" style="max-width: 700px; border-radius: 12px;">
    <div style="padding: 2rem;">
        {{ form_start(form) }}
            <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                <div>
                    {{ form_label(form.title, null, {'label_attr': {'style': 'display: block; font-weight: 600; margin-bottom: 0.5rem; color: #111827; font-size: 14px;'}}) }}
                    {{ form_widget(form.title, {'attr': {'class': 'form-input', 'style': 'width: 100%; padding: 0.75rem; border-radius: 8px; border: 2px solid #e5e7eb; font-size: 15px;', 'placeholder': 'Ex: Révision Algèbre'}}) }}
                    {{ form_errors(form.title) }}
                </div>

                <div>
                    {{ form_label(form.taskType, null, {'label_attr': {'style': 'display: block; font-weight: 600; margin-bottom: 0.5rem; color: #111827; font-size: 14px;'}}) }}
                    {{ form_widget(form.taskType, {'attr': {'class': 'form-select', 'style': 'width: 100%; padding: 0.75rem; border-radius: 8px; border: 2px solid #e5e7eb; font-size: 15px;'}}) }}
                    {{ form_errors(form.taskType) }}
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div>
                        {{ form_label(form.startAt, null, {'label_attr': {'style': 'display: block; font-weight: 600; margin-bottom: 0.5rem; color: #111827; font-size: 14px;'}}) }}
                        {{ form_widget(form.startAt, {'attr': {'style': 'width: 100%; padding: 0.75rem; border-radius: 8px; border: 2px solid #e5e7eb; font-size: 15px;'}}) }}
                        {{ form_errors(form.startAt) }}
                    </div>
                    <div>
                        {{ form_label(form.endAt, null, {'label_attr': {'style': 'display: block; font-weight: 600; margin-bottom: 0.5rem; color: #111827; font-size: 14px;'}}) }}
                        {{ form_widget(form.endAt, {'attr': {'style': 'width: 100%; padding: 0.75rem; border-radius: 8px; border: 2px solid #e5e7eb; font-size: 15px;'}}) }}
                        {{ form_errors(form.endAt) }}
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div>
                        {{ form_label(form.priority, null, {'label_attr': {'style': 'display: block; font-weight: 600; margin-bottom: 0.5rem; color: #111827; font-size: 14px;'}}) }}
                        {{ form_widget(form.priority, {'attr': {'class': 'form-select', 'style': 'width: 100%; padding: 0.75rem; border-radius: 8px; border: 2px solid #e5e7eb; font-size: 15px;'}}) }}
                        {{ form_errors(form.priority) }}
                    </div>
                    <div>
                        {{ form_label(form.status, null, {'label_attr': {'style': 'display: block; font-weight: 600; margin-bottom: 0.5rem; color: #111827; font-size: 14px;'}}) }}
                        {{ form_widget(form.status, {'attr': {'class': 'form-select', 'style': 'width: 100%; padding: 0.75rem; border-radius: 8px; border: 2px solid #e5e7eb; font-size: 15px;'}}) }}
                        {{ form_errors(form.status) }}
                    </div>
                </div>

                <div>
                    {{ form_label(form.notes, null, {'label_attr': {'style': 'display: block; font-weight: 600; margin-bottom: 0.5rem; color: #111827; font-size: 14px;'}}) }}
                    {{ form_widget(form.notes, {'attr': {'class': 'form-textarea', 'style': 'width: 100%; padding: 0.75rem; border-radius: 8px; border: 2px solid #e5e7eb; font-size: 15px; min-height: 100px;', 'placeholder': 'Notes additionnelles...'}}) }}
                    {{ form_errors(form.notes) }}
            </div>

            <div style="display: flex; justify-content: space-between; padding-top: 1rem; border-top: 1px solid #e5e7eb;">
                <a href="{{ path('fo_planning_index') }}" class="btn btn-ghost">Annuler</a>
                <button type="submit" class="btn btn-primary">Créer la session</button>
            </div>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
