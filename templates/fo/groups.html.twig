{% extends 'layouts/fo.html.twig' %}

{% set user = data.user %}

{% block title %}Groupes - StudySprint{% endblock %}
{% block page_title %}Groupes{% endblock %}

{% block topbar_actions %}
<a href="{{ path('app_group_create') }}" class="btn btn-primary">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
        <line x1="12" y1="5" x2="12" y2="19"/>
        <line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    Créer un groupe
</a>
{% endblock %}

{% block content %}
{% if state == 'loading' %}
    {# ─── LOADING STATE ─── #}
    {{ include('components/_tabs.html.twig', {
        id: 'groups-tabs',
        tabs: [
            { id: 'my-groups', label: 'Mes groupes', active: true },
            { id: 'invitations', label: 'Invitations' },
            { id: 'feedbacks', label: 'Feedbacks' }
        ]
    }) }}
    <div class="grid grid-3 gap-4">
        {{ include('components/_skeleton.html.twig', { type: 'card', count: 3 }) }}
    </div>

{% else %}
    {# ─── DEFAULT STATE ─── #}

    {# Tabs #}
    {{ include('components/_tabs.html.twig', {
        id: 'groups-tabs',
        tabs: [
            { id: 'my-groups', label: 'Mes groupes', count: data.groups|length, active: true },
            { id: 'invitations', label: 'Invitations', count: data.invitations|length },
            { id: 'feedbacks', label: 'Feedbacks', count: data.feedbacks|length }
        ]
    }) }}

    <div data-tab-content="groups-tabs">
        {# Tab: My Groups #}
        <div data-tab-panel="my-groups" class="tab-content active">
            {# SEARCH & SORT TOOLBAR #}
            <div class="fo-groups-toolbar mb-4" style="display: flex; gap: var(--space-3); flex-wrap: wrap; background: var(--color-gray-50); padding: var(--space-3); border-radius: 8px;">
                <div style="flex: 1; min-width: 250px; position: relative;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--color-gray-400);">
                        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                    <input type="text" id="group-search-input" class="form-input" placeholder="Rechercher par nom ou matière..." style="padding-left: 40px; border-color: var(--color-gray-200);">
                </div>
                
                <div style="display: flex; gap: var(--space-2);">
                    <select id="group-sort-select" class="form-select" style="min-width: 150px; border-color: var(--color-gray-200);">
                        <option value="activity">Activité récente</option>
                        <option value="name-asc">Nom (A-Z)</option>
                        <option value="name-desc">Nom (Z-A)</option>
                        <option value="members">Plus de membres</option>
                        <option value="date-desc">Plus récents</option>
                    </select>

                    <select id="group-filter-role" class="form-select" style="min-width: 130px; border-color: var(--color-gray-200);">
                        <option value="all">Tous les rôles</option>
                        <option value="admin">Administrateur</option>
                        <option value="moderator">Modérateur</option>
                        <option value="member">Membre</option>
                    </select>
                </div>
            </div>

            <div class="grid grid-3 gap-4" id="my-groups-container">
                {% for group in data.groups %}
                <div class="fo-group-card" 
                     data-group-card 
                     data-name="{{ group.name|lower }}" 
                     data-subject="{{ group.subject|lower }}" 
                     data-role="{{ group.role }}"
                     data-members-count="{{ group.members_count }}"
                     data-activity="{{ group.activity_timestamp }}"
                     data-created="{{ group.created_at }}"
                     style="cursor: pointer; position: relative;" 
                     onclick="if (!event.target.closest('button, .dropdown, a')) window.location.href='{{ path('app_group_detail', { id: group.id }) }}'">
                    <div class="dropdown" style="position: absolute; top: var(--space-3); right: var(--space-2); z-index: 10;">
                        <button class="btn btn-ghost btn-icon btn-sm" data-dropdown-toggle>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                                <circle cx="12" cy="12" r="1"/>
                                <circle cx="12" cy="5" r="1"/>
                                <circle cx="12" cy="19" r="1"/>
                            </svg>
                        </button>
                        <div class="dropdown-menu">
                            <a href="{{ path('app_group_detail', { id: group.id }) }}" class="dropdown-item">Ouvrir</a>
                            {% if group.role == 'admin' or group.role == 'moderator' %}
                            <a href="{{ path('app_group_edit', { id: group.id }) }}" class="dropdown-item">Paramètres</a>
                            {% endif %}
                            
                            <div class="dropdown-divider"></div>
                            
                            {% if group.role == 'admin' %}
                            <button class="dropdown-item danger leave-group-btn" type="button" data-group-id="{{ group.id }}" data-group-name="{{ group.name }}" data-action="delete" data-csrf="{{ csrf_token('delete-group-' ~ group.id) }}">Supprimer le groupe</button>
                            {% else %}
                            <button class="dropdown-item danger leave-group-btn" type="button" data-group-id="{{ group.id }}" data-group-name="{{ group.name }}" data-action="leave" data-csrf="{{ csrf_token('leave-group-' ~ group.id) }}">Quitter le groupe</button>
                            {% endif %}
                        </div>
                    </div>

                    <div class="fo-group-header">
                        <div class="fo-group-avatar">{{ group.initials }}</div>
                        <div class="fo-group-info">
                            <div class="fo-group-name">{{ group.name }}</div>
                            <div class="fo-group-meta">
                                {% if group.role == 'admin' %}
                                    <span style="background: var(--color-primary); color: white; padding: 2px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: 600; white-space: nowrap;">Admin</span>
                                {% elseif group.role == 'moderator' %}
                                    <span style="background: var(--color-secondary-light); color: var(--color-secondary); padding: 2px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: 600; white-space: nowrap;">Modérateur</span>
                                {% else %}
                                    <span style="background: var(--color-gray-100); color: var(--color-gray-600); padding: 2px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: 600; white-space: nowrap;">Membre</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    <p class="text-sm text-muted mb-3">{{ group.description }}</p>
                    <button class="fo-group-members" style="background: none; border: none; padding: 0; cursor: pointer; position: relative; z-index: 2;" data-modal-open="members-modal-{{ group.id }}" title="Cliquez pour voir les membres">
                        <div class="avatar-group">
                            {% set member_initials = [] %}
                            {% for member in group.members %}
                                {% if member_initials|length < 3 %}
                                    {% set member_initials = member_initials|merge([member.initials]) %}
                                    <div class="avatar avatar-sm avatar-initials">{{ member.initials }}</div>
                                {% endif %}
                            {% endfor %}
                            {% if group.members|length > 3 %}
                            <div class="avatar avatar-sm" style="background: var(--color-gray-200); color: var(--color-gray-600); cursor: pointer;">+{{ group.members|length - 3 }}</div>
                            {% endif %}
                        </div>
                    </button>
                    <div class="text-xs text-muted mt-3">
                        Derniere activite : {{ group.last_activity }}
                    </div>
                </div>
                {% endfor %}

                {# Join group card #}
                <div class="fo-group-card" style="border-style: dashed; display: flex; align-items: center; justify-content: center; min-height: 200px; cursor: pointer;" data-modal-open="join-group-modal">
                    <div class="text-center">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="32" height="32" style="margin: 0 auto 8px; color: var(--color-gray-400);">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                            <circle cx="8.5" cy="7" r="4"/>
                            <line x1="20" y1="8" x2="20" y2="14"/>
                            <line x1="23" y1="11" x2="17" y2="11"/>
                        </svg>
                        <div class="text-sm text-muted">Rejoindre un groupe</div>
                    </div>
                </div>
            </div>
        </div>

        {# Tab: Invitations #}
        <div data-tab-panel="invitations" class="tab-content">
            {% if data.invitations is not empty %}
                <div class="card">
                    <div class="card-body">

                        {% for invitation in data.invitations %}
                            <div class="flex items-center justify-between p-3
                                {% if not loop.last %}border-bottom{% endif %}">

                                {# Infos groupe #}
                                <div class="flex items-center gap-3">
                                    <div class="fo-group-avatar"
                                        style="width: 40px; height: 40px; font-size: 14px;">
                                        {{ invitation.group_name|slice(0, 2)|upper }}
                                    </div>

                                    <div>
                                        <div class="font-medium">
                                            {{ invitation.group_name }}
                                        </div>
                                        <div class="text-sm text-muted">
                                            Invité par
                                            {{ invitation.invited_by }}
                                            · {{ invitation.date }}
                                        </div>
                                    </div>
                                </div>

                                {# Actions #}
                                <div class="flex gap-2">
                                    <form
                                        action="{{ path('app_invitation_respond', {id: invitation.id, action: 'decline'}) }}"
                                        method="post">
                                        <input type="hidden" name="_token"
                                            value="{{ csrf_token('respond-invitation-' ~ invitation.id) }}">
                                        <button type="submit"
                                                class="btn btn-secondary btn-sm">
                                            Refuser
                                        </button>
                                    </form>

                                    <form
                                        action="{{ path('app_invitation_respond', {id: invitation.id, action: 'accept'}) }}"
                                        method="post">
                                        <input type="hidden" name="_token"
                                            value="{{ csrf_token('respond-invitation-' ~ invitation.id) }}">
                                        <button type="submit"
                                                class="btn btn-primary btn-sm">
                                            Accepter
                                        </button>
                                    </form>
                                </div>
                            </div>
                        {% endfor %}

                    </div>
                </div>
            {% else %}
                {{ include('components/_empty_state.html.twig', {
                    icon: 'users',
                    title: 'Aucune invitation',
                    description: 'Vous n\'avez aucune invitation en attente.'
                }) }}
            {% endif %}
        </div>


        {# Tab: Feedbacks #}
        <div data-tab-panel="feedbacks" class="tab-content">
            {% if data.feedbacks|length > 0 %}
            <div class="card">
                <div class="card-body" style="padding: 0;">
                    {% for feedback in data.feedbacks %}
                    <div class="p-4" style="{{ not loop.last ? 'border-bottom: 1px solid var(--border-color);' : '' }}">
                        <div class="flex items-start justify-between mb-2">
                            <div class="flex items-center gap-2">
                                <div class="avatar avatar-sm avatar-initials">{{ feedback.from|slice(0, 1) }}{{ feedback.from|split(' ')|last|slice(0, 1) }}</div>
                                <div>
                                    <div class="font-medium">{{ feedback.from }}</div>
                                    <div class="text-xs text-muted">{{ feedback.group }} - {{ feedback.date }}</div>
                                </div>
                            </div>
                            <div class="flex gap-1">
                                {% for i in 1..5 %}
                                <svg viewBox="0 0 24 24" fill="{{ i <= feedback.rating ? 'var(--color-warning)' : 'none' }}" stroke="var(--color-warning)" stroke-width="2" width="14" height="14">
                                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                                </svg>
                                {% endfor %}
                            </div>
                        </div>
                        <p class="text-sm" style="margin-left: 44px;">{{ feedback.message }}</p>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% else %}
            {{ include('components/_empty_state.html.twig', {
                icon: 'file',
                title: 'Aucun feedback',
                description: 'Vous n\'avez pas encore recu de feedback.'
            }) }}
            {% endif %}
        </div>
    </div>
{% endif %}
{% endblock %}

{% block drawers %}
{# Drawer: Create Group #}
<div class="drawer" id="create-group-drawer">
    <div class="drawer-header">
        <h2 class="drawer-title">Creer un groupe</h2>
        <button class="drawer-close" data-drawer-close aria-label="Fermer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
    </div>
    <div class="drawer-body">
        <div class="form-group">
            <label class="form-label required">Nom du groupe</label>
            <input type="text" class="form-input" placeholder="Ex: Prepa MPSI - Maths">
        </div>
        <div class="form-group">
            <label class="form-label">Description</label>
            <textarea class="form-textarea" placeholder="Decrivez l'objectif du groupe..."></textarea>
        </div>
        <div class="form-group">
            <label class="form-label">Matiere principale</label>
            <select class="form-select">
                <option value="">Aucune (groupe general)</option>
                <option value="math">Mathematiques</option>
                <option value="physics">Physique</option>
                <option value="chemistry">Chimie</option>
                <option value="english">Anglais</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Visibilite</label>
            <select class="form-select">
                <option value="private">Prive (sur invitation uniquement)</option>
                <option value="public">Public (visible par tous)</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Inviter des membres (emails)</label>
            <textarea class="form-textarea" placeholder="Entrez les emails separes par des virgules..."></textarea>
            <div class="form-hint">Les invitations seront envoyees par email.</div>
        </div>
    </div>
    <div class="drawer-footer">
        <button class="btn btn-secondary" data-drawer-close>Annuler</button>
        <button class="btn btn-primary">Creer le groupe</button>
    </div>
</div>

{% for group in data.groups %}
    {% if group.role == 'admin' %}
    <div class="drawer" id="group-settings-drawer-{{ group.id }}">
        <div class="drawer-header">
            <h2 class="drawer-title">Parametres du groupe</h2>
            <button class="drawer-close" data-drawer-close aria-label="Fermer">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>
        <div class="drawer-body">
            <div class="form-group">
                <label class="form-label">Nom du groupe</label>
                <input type="text" class="form-input" value="{{ group.name }}">
            </div>
            <div class="form-group">
                <label class="form-label">Description</label>
                <textarea class="form-textarea" rows="3">{{ group.description }}</textarea>
            </div>
            <div class="form-group">
                <label class="form-label">Matiere principale</label>
                <select class="form-select">
                    <option value="">Aucune</option>
                    <option value="math" {% if group.subject == 'math' %}selected{% endif %}>Mathematiques</option>
                    <option value="physics" {% if group.subject == 'physics' %}selected{% endif %}>Physique</option>
                    <option value="chemistry" {% if group.subject == 'chemistry' %}selected{% endif %}>Chimie</option>
                    <option value="english" {% if group.subject == 'english' %}selected{% endif %}>Anglais</option>
                </select>
                <div class="form-hint">Selectionnez la matiere principale du groupe.</div>
            </div>
            <div class="form-group">
                <label class="form-label">Type de groupe</label>
                <div class="flex gap-3 mt-2">
                    <label class="flex items-center gap-2">
                        <input type="radio" name="visibility" value="private" checked>
                        <span class="text-sm">Prive (sur invitation)</span>
                    </label>
                    <label class="flex items-center gap-2">
                        <input type="radio" name="visibility" value="public">
                        <span class="text-sm">Public</span>
                    </label>
                </div>
            </div>

            <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--border-color);">
                <h3 style="font-size: 0.875rem; font-weight: 600; margin-bottom: 1rem; color: var(--color-gray-900);">Gestion des membres</h3>
                <div style="max-height: 300px; overflow-y: auto;">
                    {% for member in group.members %}
                    <div class="member-item" data-member-id="{{ member.id }}" style="display: flex; align-items: center; justify-content: space-between; padding: 0.75rem; margin-bottom: 0.5rem; background: var(--color-gray-50); border-radius: 0.5rem;">
                        <div style="display: flex; align-items: center; gap: 0.75rem;">
                            <div class="avatar avatar-sm avatar-initials">{{ member.initials }}</div>
                            <div>
                                <div style="font-size: 0.875rem; font-weight: 500;">{{ member.name }}</div>
                                <div style="font-size: 0.75rem; color: var(--color-gray-600);">{{ member.email }}</div>
                            </div>
                        </div>
                        {% if member.role != 'admin' %}
                        <button class="btn btn-ghost btn-icon btn-xs kick-member-btn" data-member-id="{{ member.id }}" data-member-name="{{ member.name }}" data-group-id="{{ group.id }}" title="Retirer le membre" type="button">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" style="color: var(--color-error);">
                                <polyline points="3 6 5 6 21 6"/>
                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                <line x1="10" y1="11" x2="10" y2="17"/>
                                <line x1="14" y1="11" x2="14" y2="17"/>
                            </svg>
                        </button>
                        {% else %}
                        <span style="font-size: 0.75rem; font-weight: 500; color: var(--color-gray-600);">Admin</span>
                        {% endif %}
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        <div class="drawer-footer">
            <button class="btn btn-secondary" data-drawer-close>Annuler</button>
            <button class="btn btn-primary">Enregistrer les modifications</button>
        </div>
    </div>
    {% endif %}
{% endfor %}
{% endblock %}

{% block modals %}
{% for group in data.groups %}
<div class="modal" id="invite-members-modal-{{ group.id }}">
    <div class="modal-dialog" style="width: 90%; max-width: 500px;">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title">Inviter des membres - {{ group.name }}</h2>
                <button class="modal-close" data-modal-close aria-label="Fermer">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"/>
                        <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>
            <div class="modal-body">
                <form id="invite-form-{{ group.id }}" action="{{ path('app_group_invite', {id: group.id}) }}" method="post">
                    <input type="hidden" name="_token" value="{{ csrf_token('invite-members-' ~ group.id) }}">
                    <div class="form-group">
                        <label class="form-label required">Adresses emails</label>
                        <textarea name="emails" class="form-textarea" placeholder="marie@example.com&#10;thomas@example.com&#10;julie@example.com" rows="4" required></textarea>
                        <div class="form-hint">Entrez les adresses separees par des retours a la ligne.</div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Role</label>
                        <select name="role" class="form-select">
                            <option value="member">Membre</option>
                            <option value="moderator">Moderateur</option>
                        </select>
                        <div class="form-hint">Les modérateurs peuvent gérer les autres membres.</div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Message personalise (optionnel)</label>
                        <textarea name="message" class="form-textarea" placeholder="Dites pourquoi vous les invitez..." rows="3"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-modal-close>Annuler</button>
                <button type="submit" form="invite-form-{{ group.id }}" class="btn btn-primary">Envoyer les invitations</button>
            </div>
        </div>
    </div>
</div>
{% endfor %}

<div class="modal" id="join-group-modal">
    <div class="modal-dialog" style="width: 90%; max-width: 500px;">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title">Rejoindre un groupe</h2>
                <button class="modal-close" data-modal-close aria-label="Fermer">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"/>
                        <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>
            <div class="modal-body">
                <form action="{{ path('app_group_join_code') }}" method="post">
                    <div class="form-group">
                        <label class="form-label">Code d'invitation</label>
                        <div style="display: flex; gap: var(--space-2);">
                            <input type="text" name="code" class="form-input" placeholder="Entrez le code d'invitation" required>
                            <button type="submit" class="btn btn-primary">Rejoindre</button>
                        </div>
                        <div class="form-hint">Demandez le code au createur du groupe.</div>
                    </div>
                </form>

                <div class="mt-6 mb-4 text-center text-sm text-muted">ou recherchez un groupe public</div>

                <div class="form-group">
                    <label class="form-label">Rechercher</label>
                    <input type="text" id="public-group-search" class="form-input" placeholder="Nom du groupe, matiere...">
                </div>

                <div class="mt-4">
                    <div class="text-sm font-medium mb-3">Groupes disponibles</div>
                    <div id="public-groups-container" style="max-height: 250px; overflow-y: auto;">
                        {% if data.available_groups is not empty %}
                            {% for group in data.available_groups %}
                            <div class="card mb-2" data-public-group-item data-search-content="{{ group.name|lower }} {{ group.subject|lower }} {{ group.description|lower }}">
                                <div class="card-body p-3">
                                    <div class="flex items-center gap-3">
                                        <div class="fo-group-avatar" style="width: 36px; height: 36px; font-size: 12px;">{{ group.initials }}</div>
                                        <div class="flex-1">
                                            <div class="font-medium text-sm">{{ group.name }}</div>
                                            <div class="text-xs text-muted">{{ group.members_count }} membres - {{ group.subject }}</div>
                                        </div>
                                        <form action="{{ path('app_group_join_public', {id: group.id}) }}" method="post" style="margin: 0;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('join-group-' ~ group.id) }}">
                                            <button type="submit" class="btn btn-secondary btn-sm">Rejoindre</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                            {% endfor %}
                            <div id="public-groups-no-results" class="text-center p-6 text-muted" style="display: none;">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48" style="margin: 0 auto 1rem; opacity: 0.4;">
                                    <circle cx="11" cy="11" r="8"/>
                                    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                                    <line x1="8" y1="11" x2="14" y2="11"/>
                                </svg>
                                <div class="font-medium text-gray-900 mb-1">Aucun groupe trouvé</div>
                                <p class="text-sm">Nous n'avons trouvé aucun groupe public correspondant à "{{ '{{ query }}' }}".</p>
                            </div>
                        {% else %}
                            <div class="text-center p-4 text-muted text-sm">
                                Aucun nouveau groupe public disponible for now.
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-modal-close>Fermer</button>
            </div>
        </div>
    </div>
</div>

{% for group in data.groups %}
<div class="modal" id="members-modal-{{ group.id }}">
    <div class="modal-dialog" style="width: 90%; max-width: 300px;">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title">Membres - {{ group.name }}</h2>
                <button class="modal-close" data-modal-close aria-label="Fermer">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"/>
                        <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>
            <div class="modal-body">
                <div style="max-height: 400px; overflow-y: auto;">
                    {# Administrators #}
                    {% set admin_members = group.members|filter(m => m.role == 'admin') %}
                    {% if admin_members|length > 0 %}
                    <div style="margin-bottom: var(--space-3); padding-bottom: var(--space-3); border-bottom: 1px solid var(--border-color);" data-member-section="admin">
                        <div style="font-size: 0.75rem; font-weight: 600; color: var(--color-gray-600); text-transform: uppercase; margin-bottom: var(--space-2);">Administrateurs (<span data-member-section-count="admin">{{ admin_members|length }}</span>)</div>
                        {% for member in admin_members %}
                        <div style="display: flex; align-items: center; justify-content: space-between; padding: var(--space-2); margin-bottom: var(--space-1); background: var(--color-gray-50); border-radius: 6px; flex-wrap: wrap; gap: var(--space-2);" data-member-user-id="{{ member.user_id }}" class="member-item">
                            <div style="display: flex; align-items: center; gap: var(--space-2); min-width: 0; flex: 1;">
                                <div class="avatar avatar-sm avatar-initials" style="flex-shrink: 0;">{{ member.initials }}</div>
                                <div style="min-width: 0;">
                                    <div style="font-size: 0.875rem; font-weight: 500; color: var(--color-gray-900); overflow: hidden; text-overflow: ellipsis;">{{ member.name }}</div>
                                    <div style="font-size: 0.75rem; color: var(--color-gray-500); overflow: hidden; text-overflow: ellipsis;">{{ member.email }}</div>
                                </div>
                            </div>
                            <span style="background: var(--color-primary); color: white; padding: 2px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: 600; white-space: nowrap; flex-shrink: 0;">Admin</span>
                        </div>
                        {% endfor %}
                    </div>
                    {% endif %}

                    {# Moderators #}
                    {% set moderator_members = group.members|filter(m => m.role == 'moderator') %}
                    {% if moderator_members|length > 0 %}
                    <div style="margin-bottom: var(--space-3); padding-bottom: var(--space-3); border-bottom: 1px solid var(--border-color);" data-member-section="moderator">
                        <div style="font-size: 0.75rem; font-weight: 600; color: var(--color-gray-600); text-transform: uppercase; margin-bottom: var(--space-2);">Modérateurs (<span data-member-section-count="moderator">{{ moderator_members|length }}</span>)</div>
                        {% for member in moderator_members %}
                        <div style="display: flex; align-items: center; justify-content: space-between; padding: var(--space-2); margin-bottom: var(--space-1); border-radius: 6px; flex-wrap: wrap; gap: var(--space-2);" data-member-user-id="{{ member.user_id }}" class="member-item">
                            <div style="display: flex; align-items: center; gap: var(--space-2); min-width: 0; flex: 1;">
                                <div class="avatar avatar-sm avatar-initials" style="flex-shrink: 0;">{{ member.initials }}</div>
                                <div style="min-width: 0;">
                                    <div style="font-size: 0.875rem; font-weight: 500; color: var(--color-gray-900); overflow: hidden; text-overflow: ellipsis;">{{ member.name }}</div>
                                    <div style="font-size: 0.75rem; color: var(--color-gray-500); overflow: hidden; text-overflow: ellipsis;">{{ member.email }}</div>
                                </div>
                            </div>
                            <span style="background: var(--color-secondary-light); color: var(--color-secondary); padding: 2px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: 600; white-space: nowrap; flex-shrink: 0;">Modérateur</span>
                        </div>
                        {% endfor %}
                    </div>
                    {% endif %}

                    {# Members #}
                    {% set regular_members = group.members|filter(m => m.role == 'member') %}
                    {% if regular_members|length > 0 %}
                    <div data-member-section="member">
                        <div style="font-size: 0.75rem; font-weight: 600; color: var(--color-gray-600); text-transform: uppercase; margin-bottom: var(--space-2);">Membres (<span data-member-section-count="member">{{ regular_members|length }}</span>)</div>
                        {% for member in regular_members %}
                        <div style="display: flex; align-items: center; justify-content: space-between; padding: var(--space-2); margin-bottom: var(--space-1); border-radius: 6px; flex-wrap: wrap; gap: var(--space-2);">
                            <div style="display: flex; align-items: center; gap: var(--space-2); min-width: 0; flex: 1;">
                                <div class="avatar avatar-sm avatar-initials" style="flex-shrink: 0;">{{ member.initials }}</div>
                                <div style="min-width: 0;">
                                    <div style="font-size: 0.875rem; font-weight: 500; color: var(--color-gray-900); overflow: hidden; text-overflow: ellipsis;">{{ member.name }}</div>
                                    <div style="font-size: 0.75rem; color: var(--color-gray-500); overflow: hidden; text-overflow: ellipsis;">{{ member.email }}</div>
                                </div>
                            </div>
                            <span style="background: var(--color-gray-100); color: var(--color-gray-600); padding: 2px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: 600; white-space: nowrap; flex-shrink: 0;">Membre</span>
                        </div>
                        {% endfor %}
                    </div>
                    {% endif %}
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-modal-close>Fermer</button>
            </div>
        </div>
    </div>
</div>
{% endfor %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('assets/js/groups.js') }}"></script>
{% endblock %}