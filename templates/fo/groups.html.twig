{% extends 'layouts/fo.html.twig' %}

{% set user = data.user %}

{% block title %}Groupes - StudySprint{% endblock %}
{% block page_title %}Groupes{% endblock %}

{% block topbar_actions %}
<button class="btn btn-primary" data-drawer-open="create-group-drawer">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
        <line x1="12" y1="5" x2="12" y2="19"/>
        <line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    Creer un groupe
</button>
{% endblock %}

{% block content %}
{% if state == 'loading' %}
    {# ─── LOADING STATE ─── #}
    {{ include('components/_tabs.html.twig', {
        id: 'groups-tabs',
        tabs: [
            { id: 'my-groups', label: 'Mes groupes', active: true },
            { id: 'invitations', label: 'Invitations' },
            { id: 'feedbacks', label: 'Feedbacks' }
        ]
    }) }}
    <div class="grid grid-3 gap-4">
        {{ include('components/_skeleton.html.twig', { type: 'card', count: 3 }) }}
    </div>

{% elseif state == 'empty' %}
    {# ─── EMPTY STATE ─── #}
    {{ include('components/_empty_state.html.twig', {
        icon: 'users',
        title: 'Aucun groupe',
        description: 'Rejoignez un groupe d\'etude ou creez le votre pour collaborer avec d\'autres etudiants.',
        cta_text: 'Creer un groupe',
        cta_url: '#'
    }) }}

{% else %}
    {# ─── DEFAULT STATE ─── #}

    {# Tabs #}
    {{ include('components/_tabs.html.twig', {
        id: 'groups-tabs',
        tabs: [
            { id: 'my-groups', label: 'Mes groupes', count: data.groups|length, active: true },
            { id: 'invitations', label: 'Invitations', count: data.invitations|length },
            { id: 'feedbacks', label: 'Feedbacks', count: data.feedbacks|length }
        ]
    }) }}

    <div data-tab-content="groups-tabs">
        {# Tab: My Groups #}
        <div data-tab-panel="my-groups" class="tab-content active">
            <div class="grid grid-3 gap-4">
                {% for group in data.groups %}
                <div class="fo-group-card">
                    <div class="fo-group-header">
                        <div class="fo-group-avatar">{{ group.initials }}</div>
                        <div class="fo-group-info">
                            <div class="fo-group-name">{{ group.name }}</div>
                            <div class="fo-group-meta">
                                <span class="badge badge-{{ group.role == 'admin' ? 'primary' : 'neutral' }}">{{ group.role }}</span>
                            </div>
                        </div>
                    </div>
                    <p class="text-sm text-muted mb-3">{{ group.description }}</p>
                    <div class="fo-group-members">
                        <div class="avatar-group">
                            {% for i in 1..min(3, group.members_count) %}
                            <div class="avatar avatar-sm avatar-initials">{{ ['JD', 'ML', 'TB'][i-1] }}</div>
                            {% endfor %}
                            {% if group.members_count > 3 %}
                            <div class="avatar avatar-sm" style="background: var(--color-gray-200); color: var(--color-gray-600);">+{{ group.members_count - 3 }}</div>
                            {% endif %}
                        </div>
                        <span class="fo-group-members-label">{{ group.members_count }} membres</span>
                    </div>
                    <div class="text-xs text-muted mt-3">
                        Derniere activite : {{ group.last_activity }}
                    </div>
                    <div class="flex gap-2 mt-3">
                        <button class="btn btn-secondary btn-sm flex-1">Voir</button>
                        <div class="dropdown">
                            <button class="btn btn-ghost btn-icon btn-sm" data-dropdown-toggle>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                                    <circle cx="12" cy="12" r="1"/>
                                    <circle cx="12" cy="5" r="1"/>
                                    <circle cx="12" cy="19" r="1"/>
                                </svg>
                            </button>
                            <div class="dropdown-menu">
                                <button class="dropdown-item">Inviter des membres</button>
                                <button class="dropdown-item">Parametres</button>
                                {% if group.role == 'admin' %}
                                <div class="dropdown-divider"></div>
                                <button class="dropdown-item danger">Supprimer le groupe</button>
                                {% else %}
                                <div class="dropdown-divider"></div>
                                <button class="dropdown-item danger">Quitter le groupe</button>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}

                {# Join group card #}
                <div class="fo-group-card" style="border-style: dashed; display: flex; align-items: center; justify-content: center; min-height: 200px; cursor: pointer;" data-drawer-open="join-group-drawer">
                    <div class="text-center">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="32" height="32" style="margin: 0 auto 8px; color: var(--color-gray-400);">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                            <circle cx="8.5" cy="7" r="4"/>
                            <line x1="20" y1="8" x2="20" y2="14"/>
                            <line x1="23" y1="11" x2="17" y2="11"/>
                        </svg>
                        <div class="text-sm text-muted">Rejoindre un groupe</div>
                    </div>
                </div>
            </div>
        </div>

        {# Tab: Invitations #}
        <div data-tab-panel="invitations" class="tab-content">
            {% if data.invitations|length > 0 %}
            <div class="card">
                <div class="card-body">
                    {% for invitation in data.invitations %}
                    <div class="flex items-center justify-between p-3 {{ not loop.last ? 'border-bottom: 1px solid var(--border-color);' : '' }}" style="{{ not loop.last ? 'border-bottom: 1px solid var(--border-color);' : '' }}">
                        <div class="flex items-center gap-3">
                            <div class="fo-group-avatar" style="width: 40px; height: 40px; font-size: 14px;">{{ invitation.group_name|slice(0, 2)|upper }}</div>
                            <div>
                                <div class="font-medium">{{ invitation.group_name }}</div>
                                <div class="text-sm text-muted">Invite par {{ invitation.invited_by }} - {{ invitation.date }}</div>
                            </div>
                        </div>
                        <div class="flex gap-2">
                            <button class="btn btn-secondary btn-sm">Refuser</button>
                            <button class="btn btn-primary btn-sm">Accepter</button>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% else %}
            {{ include('components/_empty_state.html.twig', {
                icon: 'users',
                title: 'Aucune invitation',
                description: 'Vous n\'avez pas d\'invitation en attente.'
            }) }}
            {% endif %}
        </div>

        {# Tab: Feedbacks #}
        <div data-tab-panel="feedbacks" class="tab-content">
            {% if data.feedbacks|length > 0 %}
            <div class="card">
                <div class="card-body" style="padding: 0;">
                    {% for feedback in data.feedbacks %}
                    <div class="p-4" style="{{ not loop.last ? 'border-bottom: 1px solid var(--border-color);' : '' }}">
                        <div class="flex items-start justify-between mb-2">
                            <div class="flex items-center gap-2">
                                <div class="avatar avatar-sm avatar-initials">{{ feedback.from|slice(0, 1) }}{{ feedback.from|split(' ')|last|slice(0, 1) }}</div>
                                <div>
                                    <div class="font-medium">{{ feedback.from }}</div>
                                    <div class="text-xs text-muted">{{ feedback.group }} - {{ feedback.date }}</div>
                                </div>
                            </div>
                            <div class="flex gap-1">
                                {% for i in 1..5 %}
                                <svg viewBox="0 0 24 24" fill="{{ i <= feedback.rating ? 'var(--color-warning)' : 'none' }}" stroke="var(--color-warning)" stroke-width="2" width="14" height="14">
                                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                                </svg>
                                {% endfor %}
                            </div>
                        </div>
                        <p class="text-sm" style="margin-left: 44px;">{{ feedback.message }}</p>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% else %}
            {{ include('components/_empty_state.html.twig', {
                icon: 'file',
                title: 'Aucun feedback',
                description: 'Vous n\'avez pas encore recu de feedback.'
            }) }}
            {% endif %}
        </div>
    </div>
{% endif %}
{% endblock %}

{% block drawers %}
{# Drawer: Create Group #}
<div class="drawer" id="create-group-drawer">
    <div class="drawer-header">
        <h2 class="drawer-title">Creer un groupe</h2>
        <button class="drawer-close" data-drawer-close aria-label="Fermer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
    </div>
    <div class="drawer-body">
        <div class="form-group">
            <label class="form-label required">Nom du groupe</label>
            <input type="text" class="form-input" placeholder="Ex: Prepa MPSI - Maths">
        </div>
        <div class="form-group">
            <label class="form-label">Description</label>
            <textarea class="form-textarea" placeholder="Decrivez l'objectif du groupe..."></textarea>
        </div>
        <div class="form-group">
            <label class="form-label">Matiere principale</label>
            <select class="form-select">
                <option value="">Aucune (groupe general)</option>
                <option value="math">Mathematiques</option>
                <option value="physics">Physique</option>
                <option value="chemistry">Chimie</option>
                <option value="english">Anglais</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Visibilite</label>
            <select class="form-select">
                <option value="private">Prive (sur invitation uniquement)</option>
                <option value="public">Public (visible par tous)</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Inviter des membres (emails)</label>
            <textarea class="form-textarea" placeholder="Entrez les emails separes par des virgules..."></textarea>
            <div class="form-hint">Les invitations seront envoyees par email.</div>
        </div>
    </div>
    <div class="drawer-footer">
        <button class="btn btn-secondary" data-drawer-close>Annuler</button>
        <button class="btn btn-primary">Creer le groupe</button>
    </div>
</div>

{# Drawer: Join Group #}
<div class="drawer" id="join-group-drawer">
    <div class="drawer-header">
        <h2 class="drawer-title">Rejoindre un groupe</h2>
        <button class="drawer-close" data-drawer-close aria-label="Fermer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
    </div>
    <div class="drawer-body">
        <div class="form-group">
            <label class="form-label">Code d'invitation</label>
            <input type="text" class="form-input" placeholder="Entrez le code d'invitation">
            <div class="form-hint">Demandez le code au createur du groupe.</div>
        </div>

        <div class="mt-6 mb-4 text-center text-sm text-muted">ou recherchez un groupe public</div>

        <div class="form-group">
            <label class="form-label">Rechercher</label>
            <input type="text" class="form-input" placeholder="Nom du groupe, matiere...">
        </div>

        <div class="mt-4">
            <div class="text-sm font-medium mb-3">Groupes suggeres</div>
            <div class="card mb-2" style="cursor: pointer;">
                <div class="card-body p-3">
                    <div class="flex items-center gap-3">
                        <div class="fo-group-avatar" style="width: 36px; height: 36px; font-size: 12px;">MP</div>
                        <div class="flex-1">
                            <div class="font-medium text-sm">Maths Prepa</div>
                            <div class="text-xs text-muted">15 membres - Mathematiques</div>
                        </div>
                        <button class="btn btn-secondary btn-sm">Rejoindre</button>
                    </div>
                </div>
            </div>
            <div class="card" style="cursor: pointer;">
                <div class="card-body p-3">
                    <div class="flex items-center gap-3">
                        <div class="fo-group-avatar" style="width: 36px; height: 36px; font-size: 12px;">SC</div>
                        <div class="flex-1">
                            <div class="font-medium text-sm">Sciences Co</div>
                            <div class="text-xs text-muted">8 membres - Physique, Chimie</div>
                        </div>
                        <button class="btn btn-secondary btn-sm">Rejoindre</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="drawer-footer">
        <button class="btn btn-secondary" data-drawer-close>Fermer</button>
    </div>
</div>
{% endblock %}
