{% extends 'layouts/fo.html.twig' %}

{% set user = data.user %}

{% block title %}Training - StudySprint{% endblock %}
{% block page_title %}Training{% endblock %}

{% block topbar_actions %}
<button class="btn btn-primary" data-drawer-open="generate-ai-drawer">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
    </svg>
    Generer avec l'IA
</button>
{% endblock %}

{% block content %}
{% if state == 'loading' %}
    {# ─── LOADING STATE ─── #}
    {{ include('components/_tabs.html.twig', {
        id: 'training-tabs',
        tabs: [
            { id: 'decks', label: 'Mes decks', active: true },
            { id: 'quizzes', label: 'Quiz' },
            { id: 'history', label: 'Historique' }
        ]
    }) }}
    <div class="grid grid-3 gap-4">
        {{ include('components/_skeleton.html.twig', { type: 'card', count: 6 }) }}
    </div>

{% elseif state == 'empty' %}
    {# ─── EMPTY STATE ─── #}
    {{ include('components/_empty_state.html.twig', {
        icon: 'file',
        title: 'Aucun deck de revision',
        description: 'Creez votre premier deck de flashcards ou generez-en un automatiquement avec l\'IA.',
        cta_text: 'Creer un deck',
        cta_url: '#'
    }) }}

{% else %}
    {# ─── DEFAULT STATE ─── #}

    {# Stats IA #}
    <div class="card mb-6" style="background: linear-gradient(135deg, var(--color-secondary) 0%, #4F46E5 100%); border: none; color: white;">
        <div class="card-body">
            <div class="flex items-center justify-between">
                <div>
                    <div class="text-sm" style="opacity: 0.8;">Generation IA</div>
                    <div class="text-2xl font-bold">{{ data.ai_generation.available_credits }} credits restants</div>
                    <div class="text-sm" style="opacity: 0.8;">{{ data.ai_generation.used_this_month }} utilises ce mois</div>
                </div>
                <div>
                    <div class="text-sm mb-2" style="opacity: 0.8;">Suggestions</div>
                    {% for suggestion in data.ai_generation.suggestions %}
                    <div class="chip mb-1" style="background: rgba(255,255,255,0.2); color: white; font-size: 12px;">{{ suggestion }}</div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    {# Tabs #}
    {{ include('components/_tabs.html.twig', {
        id: 'training-tabs',
        tabs: [
            { id: 'decks', label: 'Mes decks', count: data.decks|length, active: true },
            { id: 'quizzes', label: 'Quiz', count: data.quizzes|length },
            { id: 'history', label: 'Historique' }
        ]
    }) }}

    <div data-tab-content="training-tabs">
        {# Tab: Decks #}
        <div data-tab-panel="decks" class="tab-content active">
            <div class="grid grid-3 gap-4">
                {% for deck in data.decks %}
                <div class="fo-deck-card">
                    <div class="fo-deck-header">
                        <div>
                            <div class="fo-deck-subject">{{ deck.subject }}</div>
                            <div class="fo-deck-title">{{ deck.title }}</div>
                        </div>
                        <div class="dropdown">
                            <button class="btn btn-ghost btn-icon btn-sm" data-dropdown-toggle>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                                    <circle cx="12" cy="12" r="1"/>
                                    <circle cx="12" cy="5" r="1"/>
                                    <circle cx="12" cy="19" r="1"/>
                                </svg>
                            </button>
                            <div class="dropdown-menu">
                                <button class="dropdown-item">Reviser</button>
                                <button class="dropdown-item">Modifier</button>
                                <div class="dropdown-divider"></div>
                                <button class="dropdown-item danger">Supprimer</button>
                            </div>
                        </div>
                    </div>
                    <div class="fo-deck-stats">
                        <span>{{ deck.cards_count }} cartes</span>
                        <span>{{ deck.cards_mastered }} maitrisees</span>
                    </div>
                    <div class="fo-deck-progress">
                        <div class="fo-deck-progress-label">
                            <span>Progression</span>
                            <span>{{ ((deck.cards_mastered / deck.cards_count) * 100)|round }}%</span>
                        </div>
                        <div class="progress">
                            <div class="progress-bar" style="width: {{ ((deck.cards_mastered / deck.cards_count) * 100)|round }}%;"></div>
                        </div>
                    </div>
                    <div class="text-xs text-muted mt-2">
                        Prochaine revision : {{ deck.next_review }}
                    </div>
                </div>
                {% endfor %}

                {# Add deck card #}
                <div class="fo-deck-card" style="border-style: dashed; display: flex; align-items: center; justify-content: center; min-height: 180px;" data-drawer-open="add-deck-drawer">
                    <div class="text-center">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="32" height="32" style="margin: 0 auto 8px; color: var(--color-gray-400);">
                            <line x1="12" y1="5" x2="12" y2="19"/>
                            <line x1="5" y1="12" x2="19" y2="12"/>
                        </svg>
                        <div class="text-sm text-muted">Creer un deck</div>
                    </div>
                </div>
            </div>
        </div>

        {# Tab: Quizzes #}
        <div data-tab-panel="quizzes" class="tab-content">
            <div class="grid grid-2 gap-4">
                {% for quiz in data.quizzes %}
                <div class="card">
                    <div class="card-body">
                        <div class="flex items-start justify-between mb-3">
                            <div>
                                <div class="font-medium">{{ quiz.title }}</div>
                                <div class="text-sm text-muted">{{ quiz.subject }} - {{ quiz.questions_count }} questions</div>
                            </div>
                            <span class="badge badge-success">{{ quiz.best_score }}%</span>
                        </div>
                        <div class="text-xs text-muted mb-3">{{ quiz.attempts }} tentatives</div>
                        <button class="btn btn-secondary btn-sm" style="width: 100%;">Recommencer</button>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>

        {# Tab: History #}
        <div data-tab-panel="history" class="tab-content">
            <div class="card">
                <div class="card-body" style="padding: 0;">
                    {% for item in data.history %}
                    <div class="flex items-center gap-4 p-4" style="border-bottom: 1px solid var(--border-color);">
                        <div class="fo-activity-icon {{ item.type == 'quiz' ? 'quiz' : 'session' }}">
                            {% if item.type == 'quiz' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M9 11l3 3L22 4"/>
                                <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
                            </svg>
                            {% else %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="2" y="4" width="20" height="16" rx="2"/>
                                <line x1="2" y1="10" x2="22" y2="10"/>
                            </svg>
                            {% endif %}
                        </div>
                        <div class="flex-1">
                            <div class="font-medium">{{ item.title }}</div>
                            <div class="text-sm text-muted">{{ item.score }}</div>
                        </div>
                        <div class="text-sm text-muted">{{ item.date }}</div>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
{% endif %}
{% endblock %}

{% block drawers %}
{# Drawer: Generate with AI #}
<div class="drawer" id="generate-ai-drawer">
    <div class="drawer-header">
        <h2 class="drawer-title">Generer avec l'IA</h2>
        <button class="drawer-close" data-drawer-close aria-label="Fermer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
    </div>
    <div class="drawer-body">
        <div class="form-group">
            <label class="form-label required">Type de contenu</label>
            <select class="form-select">
                <option value="flashcards">Deck de flashcards</option>
                <option value="quiz">Quiz</option>
                <option value="summary">Resume de cours</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label required">Matiere</label>
            <select class="form-select">
                <option value="">Selectionner</option>
                <option value="math">Mathematiques</option>
                <option value="physics">Physique</option>
                <option value="chemistry">Chimie</option>
                <option value="english">Anglais</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Sujet / Theme</label>
            <input type="text" class="form-input" placeholder="Ex: Les integrales, Vocabulaire B2...">
        </div>
        <div class="form-group">
            <label class="form-label">Nombre d'elements</label>
            <select class="form-select">
                <option value="10">10 elements</option>
                <option value="20" selected>20 elements</option>
                <option value="30">30 elements</option>
                <option value="50">50 elements</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Niveau de difficulte</label>
            <select class="form-select">
                <option value="easy">Facile</option>
                <option value="medium" selected>Intermediaire</option>
                <option value="hard">Difficile</option>
            </select>
        </div>

        <div class="card mt-4" style="background: var(--color-info-light); border-color: var(--color-info);">
            <div class="card-body">
                <div class="flex items-center gap-2 text-sm" style="color: var(--color-info-dark);">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="16" x2="12" y2="12"/>
                        <line x1="12" y1="8" x2="12.01" y2="8"/>
                    </svg>
                    Cette action utilisera 1 credit de generation IA.
                </div>
            </div>
        </div>
    </div>
    <div class="drawer-footer">
        <button class="btn btn-secondary" data-drawer-close>Annuler</button>
        <button class="btn btn-primary">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            </svg>
            Generer
        </button>
    </div>
</div>

{# Drawer: Add deck #}
<div class="drawer" id="add-deck-drawer">
    <div class="drawer-header">
        <h2 class="drawer-title">Creer un deck</h2>
        <button class="drawer-close" data-drawer-close aria-label="Fermer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
    </div>
    <div class="drawer-body">
        <div class="form-group">
            <label class="form-label required">Nom du deck</label>
            <input type="text" class="form-input" placeholder="Ex: Formules de trigonometrie">
        </div>
        <div class="form-group">
            <label class="form-label required">Matiere</label>
            <select class="form-select">
                <option value="">Selectionner</option>
                <option value="math">Mathematiques</option>
                <option value="physics">Physique</option>
                <option value="chemistry">Chimie</option>
                <option value="english">Anglais</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Description</label>
            <textarea class="form-textarea" placeholder="Description du deck..."></textarea>
        </div>
    </div>
    <div class="drawer-footer">
        <button class="btn btn-secondary" data-drawer-close>Annuler</button>
        <button class="btn btn-primary">Creer le deck</button>
    </div>
</div>
{% endblock %}
