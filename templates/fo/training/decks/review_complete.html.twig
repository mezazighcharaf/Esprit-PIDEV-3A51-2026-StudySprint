{% extends 'layouts/fo.html.twig' %}
{% block title %}Révision terminée - {{ deck.title }}{% endblock %}

{% block content %}
<div class="mb-4">
    <a href="{{ path('fo_training_decks_show', {id: deck.id}) }}" class="btn btn-ghost btn-sm">&larr; Retour au deck</a>
</div>

<div class="max-w-xl mx-auto text-center py-12">
    <div class="text-6xl mb-6">🎉</div>

    <h1 class="text-3xl font-bold mb-4">Félicitations !</h1>

    <p class="text-xl text-muted mb-8">
        Vous avez terminé votre session de révision pour aujourd'hui.
    </p>

    <div class="card mb-8">
        <div class="card-body">
            <div class="grid grid-cols-2 gap-6">
                <div>
                    <div class="text-3xl font-bold text-primary-600">{{ totalReviewed }}</div>
                    <div class="text-muted">Cartes révisées aujourd'hui</div>
                </div>
                <div>
                    <div class="text-3xl font-bold {{ dueCount > 0 ? 'text-warning' : 'text-green-600' }}">{{ dueCount }}</div>
                    <div class="text-muted">Cartes encore dues</div>
                </div>
            </div>
        </div>
    </div>

    {% if dueCount > 0 %}
        <p class="text-muted mb-6">
            Il reste encore {{ dueCount }} carte(s) à réviser. Continuez pour les voir !
        </p>
        <a href="{{ path('fo_training_decks_review', {id: deck.id}) }}" class="btn btn-primary btn-lg">
            Continuer la révision
        </a>
    {% else %}
        <p class="text-muted mb-6">
            Toutes les cartes sont à jour. Revenez demain pour continuer votre apprentissage.
        </p>
        <a href="{{ path('fo_training_decks_index') }}" class="btn btn-primary btn-lg">
            Voir les autres decks
        </a>
    {% endif %}

    <div class="mt-8">
        <a href="{{ path('fo_training_decks_show', {id: deck.id}) }}" class="btn btn-ghost">
            Retour au deck
        </a>
    </div>
</div>
{% endblock %}
