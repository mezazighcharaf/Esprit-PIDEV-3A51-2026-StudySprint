{% extends 'layouts/fo.html.twig' %}
{% block title %}Mes Flashcards - StudySprint{% endblock %}

{% block content %}
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <div>
        <h1 style="font-size: 1.875rem; font-weight: 700; color: #1f2937; margin-bottom: 0.5rem;">Mes Decks de Flashcards</h1>
        <p style="color: #6b7280;">Créez et gérez vos flashcards personnalisées</p>
    </div>
    <a href="{{ path('fo_training_decks_manage_new') }}" class="btn btn-primary">
        <svg style="width: 16px; height: 16px; margin-right: 0.25rem; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Créer un deck
    </a>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success" style="margin-bottom: 1.5rem;">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="alert alert-danger" style="margin-bottom: 1.5rem;">{{ message }}</div>
{% endfor %}

{% if decks is empty %}
    <div class="card" style="text-align: center; padding: 4rem 2rem;">
        <svg style="width: 80px; height: 80px; margin: 0 auto 1.5rem; color: #d1d5db;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
        </svg>
        <h3 style="font-size: 1.25rem; font-weight: 600; color: #1f2937; margin-bottom: 0.75rem;">Aucun deck créé</h3>
        <p style="color: #6b7280; margin-bottom: 1.5rem;">Les flashcards sont idéales pour mémoriser des définitions, vocabulaire, formules...</p>
        <a href="{{ path('fo_training_decks_manage_new') }}" class="btn btn-primary">Créer mon premier deck</a>
    </div>
{% else %}
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 1.5rem;">
        {% for deck in decks %}
        <div class="card" style="border-left: 4px solid {{ deck.isPublished ? '#10b981' : '#9ca3af' }}; transition: transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 20px rgba(0,0,0,0.08)';" onmouseout="this.style.transform=''; this.style.boxShadow='';">
            <div class="card-body">
                <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 0.75rem;">
                    <h3 style="font-size: 1.125rem; font-weight: 600; color: #1f2937; flex: 1; line-height: 1.4;">{{ deck.title }}</h3>
                    <span class="badge badge-{{ deck.isPublished ? 'success' : 'secondary' }}" style="flex-shrink: 0; margin-left: 0.5rem;">
                        {{ deck.isPublished ? 'Publié' : 'Brouillon' }}
                    </span>
                </div>
                
                <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1rem; padding: 0.75rem; background: linear-gradient(135deg, #f9fafb 0%, #f3f4f6 100%); border-radius: 0.5rem; border: 1px solid #e5e7eb;">
                    <div style="display: flex; align-items: center; gap: 0.5rem; font-size: 14px; color: #374151;">
                        <div style="width: 32px; height: 32px; border-radius: 50%; background: {{ deck.flashcards|length > 10 ? '#10b981' : (deck.flashcards|length > 5 ? '#3b82f6' : '#f59e0b') }}; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <svg style="width: 18px; height: 18px; color: white;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                            </svg>
                        </div>
                        <span><strong style="font-size: 16px; color: #1f2937;">{{ deck.flashcards|length }}</strong> <span style="color: #6b7280;">carte{{ deck.flashcards|length > 1 ? 's' : '' }}</span></span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 0.5rem; font-size: 13px; color: #6b7280;">
                        <svg style="width: 14px; height: 14px; flex-shrink: 0; color: #3b82f6;" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
                        </svg>
                        <span style="font-weight: 500;">{{ deck.subject.name }}</span>
                    </div>
                    {% if deck.chapter %}
                    <div style="display: flex; align-items: center; gap: 0.5rem; font-size: 13px; color: #6b7280;">
                        <svg style="width: 14px; height: 14px; flex-shrink: 0; color: #8b5cf6;" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/>
                        </svg>
                        <span>{{ deck.chapter.title }}</span>
                    </div>
                    {% endif %}
                </div>

                <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                    <a href="{{ path('fo_training_decks_manage_edit', {id: deck.id}) }}" class="btn btn-ghost btn-sm">
                        <svg style="width: 14px; height: 14px; margin-right: 0.25rem; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                        Modifier
                    </a>
                    
                    <form method="post" action="{{ path('fo_training_decks_manage_toggle_publish', {id: deck.id}) }}" style="display: inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('toggle_publish_' ~ deck.id) }}">
                        <button type="submit" class="btn btn-{{ deck.isPublished ? 'secondary' : 'success' }} btn-sm">
                            {{ deck.isPublished ? 'Dépublier' : 'Publier' }}
                        </button>
                    </form>

                    <form method="post" action="{{ path('fo_training_decks_manage_delete', {id: deck.id}) }}" onsubmit="return confirm('Supprimer ce deck ?')" style="display: inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_deck_' ~ deck.id) }}">
                        <button type="submit" class="btn btn-ghost btn-sm" style="color: #ef4444;">
                            <svg style="width: 14px; height: 14px; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                            </svg>
                        </button>
                    </form>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
