{% extends 'layouts/fo.html.twig' %}
{% block title %}Révision - {{ deck.title }}{% endblock %}

{% block content %}
{# Header immersif gradient #}
<div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 2rem; color: white;">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <div style="display: flex; align-items: center; gap: 1rem;">
            <a href="{{ path('fo_training_decks_show', {id: deck.id}) }}" class="btn btn-ghost btn-sm" style="background: rgba(255,255,255,0.2); color: white; border: none;" onmouseover="this.style.background='rgba(255,255,255,0.3)';" onmouseout="this.style.background='rgba(255,255,255,0.2)';">
                <svg style="width: 16px; height: 16px; margin-right: 0.375rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                Quitter
            </a>
            <div style="height: 20px; width: 1px; background: rgba(255,255,255,0.3);"></div>
            <div>
                <div style="font-size: 16px; font-weight: 600;">{{ deck.title }}</div>
                <div style="font-size: 12px; opacity: 0.85;">Révision espacée SM-2</div>
            </div>
        </div>
        <div style="display: flex; align-items: center; gap: 1.5rem; font-size: 13px;">
            <div style="text-align: center;">
                <div style="font-size: 20px; font-weight: 700;">{{ state.intervalDays }}</div>
                <div style="opacity: 0.85;">jours</div>
            </div>
            <div style="text-align: center;">
                <div style="font-size: 20px; font-weight: 700;">{{ state.repetitions }}</div>
                <div style="opacity: 0.85;">répétitions</div>
            </div>
        </div>
    </div>
</div>

{% for message in app.flashes('error') %}
    <div class="alert alert-danger" style="margin-bottom: 1.5rem; border-radius: 8px;">{{ message }}</div>
{% endfor %}

<div style="max-width: 700px; margin: 0 auto;">
    <div class="card" style="border-radius: 16px; overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.1);" id="flashcard">
        <div style="padding: 3rem 2rem; text-align: center; min-height: 400px; display: flex; flex-direction: column; justify-content: center;">
            <div id="card-front">
                <div style="width: 56px; height: 56px; background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); border-radius: 14px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
                    <svg style="width: 28px; height: 28px; color: white;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div style="font-size: 14px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1.5rem;">Question</div>
                <div style="font-size: 28px; font-weight: 700; color: #111827; margin-bottom: 2.5rem; line-height: 1.4;">{{ flashcard.front }}</div>

                {% if flashcard.hint %}
                <div style="margin-bottom: 2rem;">
                    <button type="button" onclick="document.getElementById('hint').classList.toggle('hidden')" style="background: none; border: none; color: #667eea; text-decoration: underline; cursor: pointer; font-size: 14px;">
                        💡 Afficher l'indice
                    </button>
                    <div id="hint" class="hidden" style="margin-top: 1rem; padding: 1rem; background: #fef3c7; border-radius: 8px; color: #92400e; font-style: italic; font-size: 14px;">{{ flashcard.hint }}</div>
                </div>
                {% endif %}

                <button type="button" onclick="showAnswer()" class="btn btn-primary btn-lg" style="padding: 1rem 3rem; font-size: 16px;">
                    <svg style="width: 20px; height: 20px; margin-right: 0.5rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                    Voir la réponse
                </button>

                <div style="display: flex; gap: 0.75rem; justify-content: center; margin-top: 1.25rem; flex-wrap: wrap;">
                    <button type="button" onclick="openDictionaryModal()" class="btn btn-ghost btn-sm" style="border: 1px solid #e5e7eb; color: #374151;">
                        <svg style="width: 15px; height: 15px; margin-right: 0.375rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                        </svg>
                        Définition
                    </button>
                    <button type="button" onclick="openTranslateModal()" class="btn btn-ghost btn-sm" style="border: 1px solid #e5e7eb; color: #374151;">
                        <svg style="width: 15px; height: 15px; margin-right: 0.375rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/>
                        </svg>
                        Traduire
                    </button>
                </div>
            </div>

            <div id="card-back" class="hidden">
                <div style="width: 56px; height: 56px; background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); border-radius: 14px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
                    <svg style="width: 28px; height: 28px; color: white;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div style="font-size: 14px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1.5rem;">Réponse</div>
                <div style="font-size: 28px; font-weight: 700; color: #10b981; margin-bottom: 2.5rem; line-height: 1.4;">{{ flashcard.back }}</div>

                <div style="border-top: 2px solid #f3f4f6; padding-top: 2rem;">
                    <p style="color: #6b7280; margin-bottom: 1.5rem; font-size: 15px;">Comment avez-vous trouvé cette carte ?</p>

                    <form action="{{ path('fo_training_decks_review_grade', {id: deck.id}) }}" method="post">
                        <input type="hidden" name="_token" value="{{ csrf_token('grade_card_' ~ state.id) }}">
                        <input type="hidden" name="state_id" value="{{ state.id }}">

                        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem;">
                            <button type="submit" name="button" value="again" class="btn btn-danger" style="padding: 1rem; display: flex; flex-direction: column; gap: 0.375rem; align-items: center;">
                                <div style="font-weight: 600; font-size: 15px;">Again</div>
                                <div style="font-size: 12px; opacity: 0.85;">1 jour</div>
                            </button>
                            <button type="submit" name="button" value="hard" class="btn btn-warning" style="padding: 1rem; display: flex; flex-direction: column; gap: 0.375rem; align-items: center;">
                                <div style="font-weight: 600; font-size: 15px;">Hard</div>
                                <div style="font-size: 12px; opacity: 0.85;">{{ nextDates.hard|date('d/m') }}</div>
                            </button>
                            <button type="submit" name="button" value="good" class="btn btn-success" style="padding: 1rem; display: flex; flex-direction: column; gap: 0.375rem; align-items: center;">
                                <div style="font-weight: 600; font-size: 15px;">Good</div>
                                <div style="font-size: 12px; opacity: 0.85;">{{ nextDates.good|date('d/m') }}</div>
                            </button>
                            <button type="submit" name="button" value="easy" class="btn btn-primary" style="padding: 1rem; display: flex; flex-direction: column; gap: 0.375rem; align-items: center;">
                                <div style="font-weight: 600; font-size: 15px;">Easy</div>
                                <div style="font-size: 12px; opacity: 0.85;">{{ nextDates.easy|date('d/m') }}</div>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div style="text-align: center; margin-top: 1.5rem;">
        <div style="display: inline-flex; align-items: center; gap: 1.5rem; padding: 0.75rem 1.5rem; background: #f9fafb; border-radius: 8px; font-size: 13px; color: #6b7280;">
            <span>•</span>
            <span>Facilité: {{ state.easeFactor|number_format(2) }}</span>
        </div>
        {% if isNew %}
        <div class="mt-2 text-info">Cette carte est nouvelle</div>
        {% endif %}
    </div>
</div>

{# ── Modal Définition ── #}
<div id="modal-dictionary" style="display:none; position:fixed; inset:0; z-index:1000; background:rgba(0,0,0,0.5); align-items:center; justify-content:center;">
    <div style="background:white; border-radius:16px; max-width:520px; width:90%; max-height:80vh; overflow-y:auto; box-shadow:0 25px 50px rgba(0,0,0,0.25);">
        <div style="padding:1.25rem 1.5rem; border-bottom:1px solid #f3f4f6; display:flex; justify-content:space-between; align-items:center;">
            <h3 style="margin:0; font-size:16px; font-weight:600; color:#111827;">Définition du mot</h3>
            <button onclick="closeModal('modal-dictionary')" style="background:none;border:none;cursor:pointer;padding:0.25rem;color:#6b7280;">
                <svg style="width:20px;height:20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <div style="padding:1.5rem;">
            <div style="display:flex; gap:0.5rem; margin-bottom:1rem;">
                <input id="dict-word-input" type="text" placeholder="Mot à rechercher..." value="{{ flashcard.front|slice(0,50) }}" style="flex:1; padding:0.625rem 0.875rem; border:1px solid #e5e7eb; border-radius:8px; font-size:14px; outline:none;">
                <button onclick="lookupWord()" class="btn btn-primary btn-sm">Chercher</button>
            </div>
            <div id="dict-result" style="min-height:60px;"></div>
        </div>
    </div>
</div>

{# ── Modal Traduction ── #}
<div id="modal-translate" style="display:none; position:fixed; inset:0; z-index:1000; background:rgba(0,0,0,0.5); align-items:center; justify-content:center;">
    <div style="background:white; border-radius:16px; max-width:520px; width:90%; max-height:80vh; overflow-y:auto; box-shadow:0 25px 50px rgba(0,0,0,0.25);">
        <div style="padding:1.25rem 1.5rem; border-bottom:1px solid #f3f4f6; display:flex; justify-content:space-between; align-items:center;">
            <h3 style="margin:0; font-size:16px; font-weight:600; color:#111827;">Traduction</h3>
            <button onclick="closeModal('modal-translate')" style="background:none;border:none;cursor:pointer;padding:0.25rem;color:#6b7280;">
                <svg style="width:20px;height:20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <div style="padding:1.5rem;">
            <div style="margin-bottom:1rem;">
                <label style="font-size:13px;font-weight:600;color:#374151;display:block;margin-bottom:0.375rem;">Texte à traduire</label>
                <textarea id="translate-text" rows="3" style="width:100%;padding:0.625rem 0.875rem;border:1px solid #e5e7eb;border-radius:8px;font-size:14px;outline:none;resize:vertical;box-sizing:border-box;">{{ flashcard.front }}</textarea>
            </div>
            <div style="display:flex; gap:0.5rem; margin-bottom:1rem; align-items:center;">
                <select id="translate-source" style="flex:1;padding:0.5rem;border:1px solid #e5e7eb;border-radius:8px;font-size:13px;">
                    <option value="auto">Auto-détection</option>
                    <option value="fr">Français</option>
                    <option value="en">Anglais</option>
                    <option value="ar">Arabe</option>
                    <option value="es">Espagnol</option>
                    <option value="de">Allemand</option>
                </select>
                <svg style="width:16px;height:16px;color:#6b7280;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                <select id="translate-target" style="flex:1;padding:0.5rem;border:1px solid #e5e7eb;border-radius:8px;font-size:13px;">
                    <option value="en">Anglais</option>
                    <option value="fr">Français</option>
                    <option value="ar">Arabe</option>
                    <option value="es">Espagnol</option>
                    <option value="de">Allemand</option>
                </select>
            </div>
            <button onclick="doTranslate()" class="btn btn-primary btn-sm" style="width:100%;justify-content:center;">Traduire</button>
            <div id="translate-result" style="margin-top:1rem;min-height:40px;"></div>
        </div>
    </div>
</div>

<script>
function showAnswer() {
    document.getElementById('card-front').classList.add('hidden');
    document.getElementById('card-back').classList.remove('hidden');
}

function openDictionaryModal() {
    var m = document.getElementById('modal-dictionary');
    m.style.display = 'flex';
    document.getElementById('dict-result').innerHTML = '';
}

function openTranslateModal() {
    var m = document.getElementById('modal-translate');
    m.style.display = 'flex';
    document.getElementById('translate-result').innerHTML = '';
}

function closeModal(id) {
    document.getElementById(id).style.display = 'none';
}

document.getElementById('modal-dictionary').addEventListener('click', function(e) {
    if (e.target === this) closeModal('modal-dictionary');
});
document.getElementById('modal-translate').addEventListener('click', function(e) {
    if (e.target === this) closeModal('modal-translate');
});

function lookupWord() {
    var word = document.getElementById('dict-word-input').value.trim();
    if (!word) return;
    var result = document.getElementById('dict-result');
    result.innerHTML = '<div style="color:#6b7280;font-size:14px;">Recherche en cours...</div>';
    fetch('/api/dictionary/' + encodeURIComponent(word))
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.error) {
                result.innerHTML = '<div style="color:#ef4444;font-size:14px;">' + data.error + '</div>';
                return;
            }
            var html = '<div style="margin-bottom:0.75rem;">';
            html += '<span style="font-size:20px;font-weight:700;color:#111827;">' + data.word + '</span>';
            if (data.phonetic) html += ' <span style="font-size:14px;color:#6b7280;">' + data.phonetic + '</span>';
            html += '</div>';
            if (data.definitions && data.definitions.length > 0) {
                data.definitions.forEach(function(def, i) {
                    html += '<div style="margin-bottom:0.875rem;padding-left:0.75rem;border-left:3px solid #4facfe;">';
                    if (def.partOfSpeech) html += '<div style="font-size:11px;font-weight:600;color:#4facfe;text-transform:uppercase;margin-bottom:0.25rem;">' + def.partOfSpeech + '</div>';
                    html += '<div style="font-size:14px;color:#374151;line-height:1.6;">' + def.definition + '</div>';
                    if (def.example) html += '<div style="font-size:13px;color:#6b7280;font-style:italic;margin-top:0.25rem;">"' + def.example + '"</div>';
                    html += '</div>';
                });
            }
            result.innerHTML = html;
        })
        .catch(function() {
            result.innerHTML = '<div style="color:#ef4444;font-size:14px;">Erreur réseau. Réessayez.</div>';
        });
}

function doTranslate() {
    var text = document.getElementById('translate-text').value.trim();
    var source = document.getElementById('translate-source').value;
    var target = document.getElementById('translate-target').value;
    var result = document.getElementById('translate-result');
    if (!text) return;
    result.innerHTML = '<div style="color:#6b7280;font-size:14px;">Traduction en cours...</div>';
    fetch('/api/translate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text: text, source: source, target: target })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.error) {
            result.innerHTML = '<div style="color:#ef4444;font-size:14px;">' + data.error + '</div>';
            return;
        }
        result.innerHTML = '<div style="background:#f0fdf4;border-radius:8px;padding:1rem;border-left:3px solid #10b981;">'
            + '<div style="font-size:11px;font-weight:600;color:#10b981;text-transform:uppercase;margin-bottom:0.5rem;">Traduction</div>'
            + '<div style="font-size:15px;color:#111827;line-height:1.6;">' + data.translated + '</div>'
            + '</div>';
    })
    .catch(function() {
        result.innerHTML = '<div style="color:#ef4444;font-size:14px;">Service de traduction indisponible.</div>';
    });
}
</script>
{% endblock %}
