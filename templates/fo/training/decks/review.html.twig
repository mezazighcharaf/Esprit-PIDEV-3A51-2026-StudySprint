{% extends 'layouts/fo.html.twig' %}
{% block title %}Révision - {{ deck.title }}{% endblock %}

{% block content %}
{# Header immersif gradient #}
<div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 2rem; color: white;">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <div style="display: flex; align-items: center; gap: 1rem;">
            <a href="{{ path('fo_training_decks_show', {id: deck.id}) }}" class="btn btn-ghost btn-sm" style="background: rgba(255,255,255,0.2); color: white; border: none;" onmouseover="this.style.background='rgba(255,255,255,0.3)';" onmouseout="this.style.background='rgba(255,255,255,0.2)';">
                <svg style="width: 16px; height: 16px; margin-right: 0.375rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                Quitter
            </a>
            <div style="height: 20px; width: 1px; background: rgba(255,255,255,0.3);"></div>
            <div>
                <div style="font-size: 16px; font-weight: 600;">{{ deck.title }}</div>
                <div style="font-size: 12px; opacity: 0.85;">Révision espacée SM-2</div>
            </div>
        </div>
        <div style="display: flex; align-items: center; gap: 1.5rem; font-size: 13px;">
            <div style="text-align: center;">
                <div style="font-size: 20px; font-weight: 700;">{{ state.intervalDays }}</div>
                <div style="opacity: 0.85;">jours</div>
            </div>
            <div style="text-align: center;">
                <div style="font-size: 20px; font-weight: 700;">{{ state.repetitions }}</div>
                <div style="opacity: 0.85;">répétitions</div>
            </div>
        </div>
    </div>
</div>

{% for message in app.flashes('error') %}
    <div class="alert alert-danger" style="margin-bottom: 1.5rem; border-radius: 8px;">{{ message }}</div>
{% endfor %}

<div style="max-width: 700px; margin: 0 auto;">
    <div class="card" style="border-radius: 16px; overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.1);" id="flashcard">
        <div style="padding: 3rem 2rem; text-align: center; min-height: 400px; display: flex; flex-direction: column; justify-content: center;">
            <div id="card-front">
                <div style="width: 56px; height: 56px; background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); border-radius: 14px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
                    <svg style="width: 28px; height: 28px; color: white;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div style="font-size: 14px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1.5rem;">Question</div>
                <div style="font-size: 28px; font-weight: 700; color: #111827; margin-bottom: 2.5rem; line-height: 1.4;">{{ flashcard.front }}</div>

                {% if flashcard.hint %}
                <div style="margin-bottom: 2rem;">
                    <button type="button" onclick="document.getElementById('hint').classList.toggle('hidden')" style="background: none; border: none; color: #667eea; text-decoration: underline; cursor: pointer; font-size: 14px;">
                        💡 Afficher l'indice
                    </button>
                    <div id="hint" class="hidden" style="margin-top: 1rem; padding: 1rem; background: #fef3c7; border-radius: 8px; color: #92400e; font-style: italic; font-size: 14px;">{{ flashcard.hint }}</div>
                </div>
                {% endif %}

                <button type="button" onclick="showAnswer()" class="btn btn-primary btn-lg" style="padding: 1rem 3rem; font-size: 16px;">
                    <svg style="width: 20px; height: 20px; margin-right: 0.5rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                    Voir la réponse
                </button>
            </div>

            <div id="card-back" class="hidden">
                <div style="width: 56px; height: 56px; background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); border-radius: 14px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
                    <svg style="width: 28px; height: 28px; color: white;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div style="font-size: 14px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1.5rem;">Réponse</div>
                <div style="font-size: 28px; font-weight: 700; color: #10b981; margin-bottom: 2.5rem; line-height: 1.4;">{{ flashcard.back }}</div>

                <div style="border-top: 2px solid #f3f4f6; padding-top: 2rem;">
                    <p style="color: #6b7280; margin-bottom: 1.5rem; font-size: 15px;">Comment avez-vous trouvé cette carte ?</p>

                    <form action="{{ path('fo_training_decks_review_grade', {id: deck.id}) }}" method="post">
                        <input type="hidden" name="_token" value="{{ csrf_token('grade_card_' ~ state.id) }}">
                        <input type="hidden" name="state_id" value="{{ state.id }}">

                        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem;">
                            <button type="submit" name="button" value="again" class="btn btn-danger" style="padding: 1rem; display: flex; flex-direction: column; gap: 0.375rem; align-items: center;">
                                <div style="font-weight: 600; font-size: 15px;">Again</div>
                                <div style="font-size: 12px; opacity: 0.85;">1 jour</div>
                            </button>
                            <button type="submit" name="button" value="hard" class="btn btn-warning" style="padding: 1rem; display: flex; flex-direction: column; gap: 0.375rem; align-items: center;">
                                <div style="font-weight: 600; font-size: 15px;">Hard</div>
                                <div style="font-size: 12px; opacity: 0.85;">{{ nextDates.hard|date('d/m') }}</div>
                            </button>
                            <button type="submit" name="button" value="good" class="btn btn-success" style="padding: 1rem; display: flex; flex-direction: column; gap: 0.375rem; align-items: center;">
                                <div style="font-weight: 600; font-size: 15px;">Good</div>
                                <div style="font-size: 12px; opacity: 0.85;">{{ nextDates.good|date('d/m') }}</div>
                            </button>
                            <button type="submit" name="button" value="easy" class="btn btn-primary" style="padding: 1rem; display: flex; flex-direction: column; gap: 0.375rem; align-items: center;">
                                <div style="font-weight: 600; font-size: 15px;">Easy</div>
                                <div style="font-size: 12px; opacity: 0.85;">{{ nextDates.easy|date('d/m') }}</div>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div style="text-align: center; margin-top: 1.5rem;">
        <div style="display: inline-flex; align-items: center; gap: 1.5rem; padding: 0.75rem 1.5rem; background: #f9fafb; border-radius: 8px; font-size: 13px; color: #6b7280;">
            <span>•</span>
            <span>Facilité: {{ state.easeFactor|number_format(2) }}</span>
        </div>
        {% if isNew %}
        <div class="mt-2 text-info">Cette carte est nouvelle</div>
        {% endif %}
    </div>
</div>

<script>
function showAnswer() {
    document.getElementById('card-front').classList.add('hidden');
    document.getElementById('card-back').classList.remove('hidden');
}
</script>
{% endblock %}
