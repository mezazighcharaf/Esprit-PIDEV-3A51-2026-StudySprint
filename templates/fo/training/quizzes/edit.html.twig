{% extends 'layouts/fo.html.twig' %}
{% block title %}Modifier {{ quiz.title }}{% endblock %}

{% block content %}
<div style="margin-bottom: 2rem;">
    <a href="{{ path('fo_training_quizzes_manage_my_quizzes') }}" style="color: #6b7280; text-decoration: none; font-size: 14px; display: inline-flex; align-items: center; gap: 0.25rem;">
        <svg style="width: 16px; height: 16px; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Retour à mes quiz
    </a>
</div>

<h1 style="font-size: 1.875rem; font-weight: 700; color: #1f2937; margin-bottom: 2rem;">Modifier le Quiz</h1>

<form method="post">
    <div class="card" style="margin-bottom: 1.5rem;">
        <div class="card-header">
            <h2 style="font-size: 1.25rem; font-weight: 600;">Informations du Quiz</h2>
        </div>
        <div class="card-body">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                <div>
                    <label class="form-label">Titre du quiz</label>
                    <input type="text" name="title" class="form-input" required value="{{ quiz.title }}">
                </div>
                
                <div>
                    <label class="form-label">Difficulté</label>
                    <select name="difficulty" class="form-select">
                        <option value="EASY" {{ quiz.difficulty == 'EASY' ? 'selected' : '' }}>Facile</option>
                        <option value="MEDIUM" {{ quiz.difficulty == 'MEDIUM' ? 'selected' : '' }}>Moyen</option>
                        <option value="HARD" {{ quiz.difficulty == 'HARD' ? 'selected' : '' }}>Difficile</option>
                    </select>
                </div>
            </div>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div>
                    <label class="form-label">Matière</label>
                    <select name="subject_id" class="form-select" required id="subject-select">
                        {% for subject in subjects %}
                            <option value="{{ subject.id }}" data-chapters="{{ subject.chapters|json_encode }}" {{ quiz.subject.id == subject.id ? 'selected' : '' }}>{{ subject.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                
                <div>
                    <label class="form-label">Chapitre</label>
                    <select name="chapter_id" class="form-select" id="chapter-select">
                        <option value="">-- Aucun chapitre --</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="card" style="margin-bottom: 1.5rem;">
        <div class="card-header">
            <h2 style="font-size: 1.25rem; font-weight: 600;">Questions ({{ quiz.questions|length }})</h2>
        </div>
        <div class="card-body">
            {% for question in quiz.questions %}
            <div class="card" style="margin-bottom: 1rem;">
                <div class="card-body">
                    <strong style="display: block; color: #374151; margin-bottom: 0.75rem;">Question {{ loop.index }}</strong>
                    
                    <input type="hidden" name="questions[{{ loop.index0 }}][type]" value="{{ question.type }}">
                    
                    <div style="margin-bottom: 0.75rem;">
                        <label class="form-label">Question</label>
                        <textarea name="questions[{{ loop.index0 }}][question]" class="form-textarea" rows="2" required>{{ question.question }}</textarea>
                    </div>
                    
                    {% if question.type == 'multiple_choice' %}
                    <div>
                        <label class="form-label">Options de réponse</label>
                        {% for i in 0..3 %}
                        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
                            <input type="radio" name="questions[{{ loop.parent.loop.index0 }}][correctIndex]" value="{{ i }}" {{ question.correctIndex == i ? 'checked' : '' }}>
                            <input type="text" name="questions[{{ loop.parent.loop.index0 }}][options][]" class="form-input" value="{{ question.options[i] ?? '' }}" required>
                        </div>
                        {% endfor %}
                    </div>
                    
                    {% elseif question.type == 'true_false' %}
                    <div>
                        <label class="form-label">Réponse correcte</label>
                        <div style="display: flex; gap: 1rem;">
                            <label style="display: flex; align-items: center; gap: 0.5rem;">
                                <input type="radio" name="questions[{{ loop.index0 }}][correctIndex]" value="0" {{ question.correctIndex == 0 ? 'checked' : '' }}>
                                <span>Vrai</span>
                            </label>
                            <label style="display: flex; align-items: center; gap: 0.5rem;">
                                <input type="radio" name="questions[{{ loop.index0 }}][correctIndex]" value="1" {{ question.correctIndex == 1 ? 'checked' : '' }}>
                                <span>Faux</span>
                            </label>
                        </div>
                        <input type="hidden" name="questions[{{ loop.index0 }}][options][]" value="Vrai">
                        <input type="hidden" name="questions[{{ loop.index0 }}][options][]" value="Faux">
                    </div>
                    
                    {% elseif question.type in ['short_answer', 'fill_in_blank'] %}
                    <div>
                        <label class="form-label">Réponse correcte</label>
                        <input type="text" name="questions[{{ loop.index0 }}][correctAnswer]" class="form-input" required value="{{ question.correctAnswer ?? '' }}">
                    </div>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

    <div style="display: flex; gap: 0.75rem;">
        <button type="submit" class="btn btn-primary">Enregistrer les modifications</button>
        <a href="{{ path('fo_training_quizzes_manage_my_quizzes') }}" class="btn btn-ghost">Annuler</a>
    </div>
</form>

<script>
const initialChapterId = {{ quiz.chapter ? quiz.chapter.id : 'null' }};
document.getElementById('subject-select').addEventListener('change', function() {
    const chapterSelect = document.getElementById('chapter-select');
    const selectedOption = this.options[this.selectedIndex];
    const chapters = selectedOption.dataset.chapters ? JSON.parse(selectedOption.dataset.chapters) : [];
    
    chapterSelect.innerHTML = '<option value="">-- Aucun chapitre --</option>';
    chapters.forEach(chapter => {
        const option = document.createElement('option');
        option.value = chapter.id;
        option.textContent = chapter.title;
        if (initialChapterId && chapter.id === initialChapterId) {
            option.selected = true;
        }
        chapterSelect.appendChild(option);
    });
});

document.getElementById('subject-select').dispatchEvent(new Event('change'));
</script>
{% endblock %}
