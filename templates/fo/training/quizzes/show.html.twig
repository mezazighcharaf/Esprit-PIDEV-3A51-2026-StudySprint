{% extends 'layouts/fo.html.twig' %}
{% block title %}{{ quiz.title }} - StudySprint{% endblock %}

{% block content %}
<div class="mb-4">
    <a href="{{ path('fo_training_quizzes_index') }}" class="btn btn-ghost btn-sm">&larr; Retour aux quiz</a>
</div>

{% for message in app.flashes('success') %}
    <div style="background: #f0fdf4; border: 1px solid #bbf7d0; color: #166534; padding: 1rem 1.25rem; border-radius: 10px; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.75rem;">
        <svg style="width: 20px; height: 20px; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        {{ message }}
    </div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div style="background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; padding: 1rem 1.25rem; border-radius: 10px; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.75rem;">
        <svg style="width: 20px; height: 20px; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        {{ message }}
    </div>
{% endfor %}

<div class="page-header">
    <div>
        <h1>{{ quiz.title }}</h1>
        <span class="badge badge-{{ quiz.difficulty == 'EASY' ? 'success' : (quiz.difficulty == 'MEDIUM' ? 'warning' : 'danger') }}">
            {{ quiz.difficulty }}
        </span>
    </div>
    <div class="page-actions" style="display: flex; gap: 0.75rem; align-items: center;">
        <form action="{{ path('fo_training_quizzes_start', {id: quiz.id}) }}" method="post" class="inline">
            <input type="hidden" name="_token" value="{{ csrf_token('start_quiz_' ~ quiz.id) }}">
            <button type="submit" class="btn btn-primary btn-lg">
                Commencer le quiz
            </button>
        </form>
        <button type="button" class="btn btn-ghost btn-sm" onclick="document.getElementById('qrModal').style.display='flex'" title="Partager via QR Code">
            <svg style="width: 18px; height: 18px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"/>
            </svg>
            QR Code
        </button>
    </div>
</div>

{# Average Rating Display #}
{% if avgRating is defined and avgRating %}
<div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem;">
    {% for i in 1..5 %}
    <svg style="width: 20px; height: 20px;" fill="{{ avgRating >= i ? '#f59e0b' : (avgRating >= i - 0.5 ? '#fbbf24' : '#d1d5db') }}" viewBox="0 0 24 24">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
    </svg>
    {% endfor %}
    <span style="font-size: 15px; font-weight: 600; color: #111827;">{{ avgRating }}/5</span>
    <span style="font-size: 13px; color: #6b7280;">({{ ratingCount }} avis)</span>
    {% if userRating is defined and userRating %}
    <span style="font-size: 13px; color: #6b7280; margin-left: 0.5rem;">- Votre note : {{ userRating.score }}/5</span>
    {% endif %}
</div>
{% endif %}

<div class="card mb-6">
    <div class="card-body">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
                <strong>Matière:</strong>
                <p class="text-muted">{{ quiz.subject ? quiz.subject.name : 'N/A' }}</p>
            </div>
            {% if quiz.chapter %}
            <div>
                <strong>Chapitre:</strong>
                <p class="text-muted">{{ quiz.chapter.title }}</p>
            </div>
            {% endif %}
            <div>
                <strong>Questions:</strong>
                <p class="text-muted">{{ quiz.questions|length }}</p>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h2>Questions du Quiz</h2>
    </div>
    <div class="card-body">
        {% if quiz.questions is empty %}
            <p class="text-muted">Aucune question dans ce quiz.</p>
        {% else %}
            <div class="space-y-6">
                {% for question in quiz.questions %}
                <div class="p-4 border rounded">
                    <div class="flex items-start gap-3 mb-3">
                        <span class="badge badge-primary">Q{{ loop.index }}</span>
                        <strong class="flex-1">{{ question.text ?? 'Question ' ~ loop.index }}</strong>
                    </div>
                    {% if question.choices is defined %}
                        <div class="ml-10 space-y-2">
                            {% for choice in question.choices %}
                                <div class="p-2 bg-gray-50 rounded">
                                    {{ choice.text ?? 'Choix ' ~ loop.index }}
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>

{# QR Code Modal #}
<div id="qrModal" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:1000; align-items:center; justify-content:center;" onclick="if(event.target===this)this.style.display='none'">
    <div style="background:white; border-radius:12px; padding:2rem; text-align:center; max-width:350px;">
        <h3 style="font-size:18px; font-weight:600; margin:0 0 1rem 0;">Partager ce quiz</h3>
        {% set quizUrl = url('fo_training_quizzes_show', {id: quiz.id}) %}
        <img src="https://chart.googleapis.com/chart?chs=250x250&cht=qr&chl={{ quizUrl|url_encode }}" alt="QR Code" style="width:250px; height:250px; margin:0 auto 1rem;" />
        <p style="font-size:13px; color:#6b7280; margin:0 0 1rem 0;">Scannez ce QR code pour accéder au quiz</p>
        <button type="button" class="btn btn-ghost btn-sm" onclick="document.getElementById('qrModal').style.display='none'">Fermer</button>
    </div>
</div>

{% block javascripts %}
    {{ parent() }}
    <script defer src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        if (window.MathJax && MathJax.typesetPromise) {
          MathJax.typesetPromise();
        }
      });
    </script>
{% endblock %}
{% endblock %}
