{% extends 'layouts/fo.html.twig' %}
{% block title %}Mes Quiz - StudySprint{% endblock %}

{% block content %}
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <div>
        <h1 style="font-size: 1.875rem; font-weight: 700; color: #1f2937; margin-bottom: 0.5rem;">Mes Quiz</h1>
        <p style="color: #6b7280;">Gérez vos quiz personnalisés</p>
    </div>
    <a href="{{ path('fo_training_quizzes_manage_new') }}" class="btn btn-primary">
        <svg style="width: 16px; height: 16px; margin-right: 0.25rem; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Créer un quiz
    </a>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success" style="margin-bottom: 1.5rem;">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="alert alert-danger" style="margin-bottom: 1.5rem;">{{ message }}</div>
{% endfor %}

{% if quizzes is empty %}
    <div class="card" style="text-align: center; padding: 4rem 2rem;">
        <svg style="width: 80px; height: 80px; margin: 0 auto 1.5rem; color: #d1d5db;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
        </svg>
        <h3 style="font-size: 1.25rem; font-weight: 600; color: #1f2937; margin-bottom: 0.75rem;">Aucun quiz créé</h3>
        <p style="color: #6b7280; margin-bottom: 1.5rem;">Commencez par créer votre premier quiz avec nos templates</p>
        <a href="{{ path('fo_training_quizzes_manage_new') }}" class="btn btn-primary">Créer mon premier quiz</a>
    </div>
{% else %}
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
        {% for quiz in quizzes %}
        <div class="card">
            <div class="card-body">
                <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 0.75rem;">
                    <h3 style="font-size: 1.125rem; font-weight: 600; color: #1f2937; flex: 1;">{{ quiz.title }}</h3>
                    <span class="badge badge-{{ quiz.isPublished ? 'success' : 'secondary' }}">
                        {{ quiz.isPublished ? 'Publié' : 'Brouillon' }}
                    </span>
                </div>
                
                <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1rem; padding: 0.75rem; background: #f9fafb; border-radius: 0.5rem;">
                    <div style="display: flex; align-items: center; gap: 0.5rem; font-size: 14px; color: #6b7280;">
                        <svg style="width: 16px; height: 16px; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                        <span><strong>{{ quiz.questions|length }}</strong> questions</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 0.5rem; font-size: 14px; color: #6b7280;">
                        <svg style="width: 16px; height: 16px; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                        </svg>
                        <span>{{ quiz.subject.name }}</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 0.5rem; font-size: 14px; color: #6b7280;">
                        <svg style="width: 16px; height: 16px; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                        </svg>
                        <span>{{ quiz.difficulty }}</span>
                    </div>
                </div>

                <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                    <a href="{{ path('fo_training_quizzes_manage_edit', {id: quiz.id}) }}" class="btn btn-ghost btn-sm">
                        <svg style="width: 14px; height: 14px; margin-right: 0.25rem; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                        Modifier
                    </a>
                    
                    <form method="post" action="{{ path('fo_training_quizzes_manage_toggle_publish', {id: quiz.id}) }}" style="display: inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('toggle_publish_' ~ quiz.id) }}">
                        <button type="submit" class="btn btn-{{ quiz.isPublished ? 'secondary' : 'success' }} btn-sm">
                            {{ quiz.isPublished ? 'Dépublier' : 'Publier' }}
                        </button>
                    </form>

                    <form method="post" action="{{ path('fo_training_quizzes_manage_delete', {id: quiz.id}) }}" onsubmit="return confirm('Supprimer ce quiz ?')" style="display: inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_quiz_' ~ quiz.id) }}">
                        <button type="submit" class="btn btn-ghost btn-sm" style="color: #ef4444;">
                            <svg style="width: 14px; height: 14px; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                            </svg>
                        </button>
                    </form>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
