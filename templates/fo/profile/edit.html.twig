<script>
    document.addEventListener('DOMContentLoaded', function() {
        const countrySelect = document.getElementById('profile_pays');
        const schoolSelect = document.getElementById('profile_etablissement');
        const levelSelect = document.getElementById('profile_niveau');

        if (countrySelect) {
            const initialCountry = countrySelect.value;
            const selectedSchool = schoolSelect ? schoolSelect.getAttribute('data-selected') : null;
            const selectedLevel = levelSelect ? levelSelect.getAttribute('data-selected') : null;

            if (initialCountry) {
                loadLocationData(initialCountry, selectedSchool, selectedLevel);
            }

            countrySelect.addEventListener('change', function() {
                loadLocationData(this.value);
            });
        }

        function loadLocationData(countryCode, schoolToSelect = null, levelToSelect = null) {
            if (!countryCode) {
                resetSelect(schoolSelect);
                resetSelect(levelSelect);
                return;
            }

            if (schoolSelect) {
                fetch(`/api/location/schools/${countryCode}`)
                    .then(response => response.json())
                    .then(data => {
                        updateSelect(schoolSelect, data, schoolToSelect);
                    });
            }

            if (levelSelect) {
                fetch(`/api/location/levels/${countryCode}`)
                    .then(response => response.json())
                    .then(data => {
                        updateSelect(levelSelect, data, levelToSelect);
                    });
            }
        }

        function updateSelect(selectElement, items, selectedValue) {
            if (!selectElement) return;
            selectElement.innerHTML = '';
            selectElement.disabled = false;
            
            const placeholder = document.createElement('option');
            placeholder.value = '';
            placeholder.text = 'Choisir...';
            selectElement.appendChild(placeholder);

            items.forEach(item => {
                const option = document.createElement('option');
                option.value = item;
                option.text = item;
                if (item === selectedValue) {
                    option.selected = true;
                }
                selectElement.appendChild(option);
            });
        }

        function resetSelect(selectElement) {
            if (!selectElement) return;
            selectElement.innerHTML = '<option value="">Choisir un pays d\'abord</option>';
            selectElement.disabled = true;
        }
    });
</script>
