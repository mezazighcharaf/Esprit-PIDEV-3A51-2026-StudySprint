{% extends 'layouts/fo.html.twig' %}

{% block title %}Modifier mon Profil - StudySprint{% endblock %}
{% block page_title %}Modifier mon Profil{% endblock %}

{% block content %}
{# Robust role detection #}
{% set rawRole = user.role|upper %}
{% set isStudent = ('STUDENT' in rawRole) %}
{% set isProfessor = ('PROFESSOR' in rawRole) %}

<div class="profile-v3-container animate__animated animate__fadeIn">
    {# ─── PREMIUM HERO / HEADER ─── #}
    <div class="profile-v3-hero {% if isStudent %}student-theme{% else %}professor-theme{% endif %}">
        <div class="mesh-bg-v3"></div>
        <div class="hero-content-v3">
            <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-4">
                <div class="d-flex align-items-center gap-5">
                    <div class="v3-avatar-container">
                        <div class="v3-avatar-inner">
                            {{ user.prenom|slice(0,1)|upper }}{{ user.nom|slice(0,1)|upper }}
                        </div>
                        <div class="v3-role-badge">
                            <i class="fas {% if isStudent %}fa-graduation-cap{% else %}fa-chalkboard-teacher{% endif %}"></i>
                        </div>
                    </div>
                    <div>
                        <h2 class="v3-hero-title mb-2">Configuration du Compte</h2>
                        <p class="v3-hero-subtitle mb-0">Mettez à jour vos informations pour personnaliser votre expérience StudySprint.</p>
                    </div>
                </div>
                <a href="{{ path('app_profile') }}" class="btn-glass-v3 mt-4 mt-md-0">
                    <i class="fas fa-chevron-left me-2"></i> Retour au profil
                </a>
            </div>
        </div>
    </div>

    {# ─── FORM CONTAINER ─── #}
    <div class="glass-card-v3 mt-n5">
        {{ form_start(form, {'attr': {'class': 'profile-form-v3', 'id': 'profile-form', 'novalidate': 'novalidate'}}) }}
            
            {% if not form.vars.valid %}
                <div class="v3-alert-box animate__animated animate__shakeX">
                    <div class="alert-icon"><i class="fas fa-exclamation-circle"></i></div>
                    <div class="alert-content">
                        <strong>Attention</strong>
                        <p>Certains champs nécessitent votre attention. Veuillez vérifier les erreurs ci-dessous.</p>
                    </div>
                </div>
            {% endif %}

            <div class="form-sections-v3">
                {# SECTION 1: INFORMATIONS PERSONNELLES #}
                <div class="v3-section-card">
                    <div class="section-header-v3">
                        <div class="section-badge student-accent"><i class="fas fa-id-card"></i></div>
                        <div>
                            <h3 class="section-title-v3">Identité & Contact</h3>
                            <p class="section-desc-v3">Vos informations de base visibles sur la plateforme.</p>
                        </div>
                    </div>
                    
                    <div class="row g-4 mt-2">
                        <div class="col-md-6">
                            <div class="v3-input-wrapper">
                                {{ form_label(form.prenom, 'Prénom') }}
                                <div class="input-inner-v3">
                                    <i class="far fa-user"></i>
                                    {{ form_widget(form.prenom, {'attr': {'placeholder': 'Ex: Jean'}}) }}
                                </div>
                                {{ form_errors(form.prenom) }}
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <div class="v3-input-wrapper">
                                {{ form_label(form.nom, 'Nom de famille') }}
                                <div class="input-inner-v3">
                                    <i class="far fa-user"></i>
                                    {{ form_widget(form.nom, {'attr': {'placeholder': 'Ex: Dupont'}}) }}
                                </div>
                                {{ form_errors(form.nom) }}
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="v3-input-wrapper">
                                {{ form_label(form.email, 'Adresse Email') }}
                                <div class="input-inner-v3">
                                    <i class="far fa-envelope"></i>
                                    {{ form_widget(form.email, {'attr': {'placeholder': 'nom@exemple.com'}}) }}
                                </div>
                                {{ form_errors(form.email) }}
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="v3-input-wrapper">
                                {{ form_label(form.pays, 'Pays de résidence') }}
                                <div class="input-inner-v3">
                                    <i class="fas fa-earth-africa"></i>
                                    {{ form_widget(form.pays) }}
                                </div>
                                {{ form_errors(form.pays) }}
                            </div>
                        </div>
                    </div>
                </div>

                {# SECTION 2: DONNÉES ACADÉMIQUES #}
                <div class="v3-section-card mt-5">
                    <div class="section-header-v3">
                        <div class="section-badge professor-accent">
                            <i class="fas {% if isStudent %}fa-university{% else %}fa-briefcase{% endif %}"></i>
                        </div>
                        <div>
                            <h3 class="section-title-v3">{% if isStudent %}Parcours Étudiant{% else %}Expertise Enseignante{% endif %}</h3>
                            <p class="section-desc-v3">Détails sur votre établissement et votre niveau actuel.</p>
                        </div>
                    </div>

                    <div class="row g-4 mt-2">
                        {% if isStudent %}
                            <div class="col-md-6">
                                <div class="v3-input-wrapper">
                                    {{ form_label(form.age, 'Âge') }}
                                    <div class="input-inner-v3">
                                        <i class="fas fa-calendar-day"></i>
                                        {{ form_widget(form.age) }}
                                    </div>
                                    {{ form_errors(form.age) }}
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="v3-input-wrapper">
                                    {{ form_label(form.sexe, 'Genre') }}
                                    <div class="input-inner-v3">
                                        <i class="fas fa-venus-mars"></i>
                                        {{ form_widget(form.sexe) }}
                                    </div>
                                    {{ form_errors(form.sexe) }}
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="v3-input-wrapper">
                                    {{ form_label(form.etablissement, 'Établissement') }}
                                    <div class="input-inner-v3">
                                        <i class="fas fa-school"></i>
                                        {{ form_widget(form.etablissement, {'attr': {'data-selected': user.etablissement}}) }}
                                    </div>
                                    {{ form_errors(form.etablissement) }}
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="v3-input-wrapper v3-highlight">
                                    {{ form_label(form.niveau, 'Niveau actuel') }}
                                    <div class="input-inner-v3">
                                        <i class="fas fa-layer-group"></i>
                                        {{ form_widget(form.niveau, {'attr': {'data-selected': user.niveau}}) }}
                                    </div>
                                    {{ form_errors(form.niveau) }}
                                </div>
                            </div>
                            
                            {% if form.specialite is defined %}{% do form.specialite.setRendered %}{% endif %}
                            {% if form.niveauEnseignement is defined %}{% do form.niveauEnseignement.setRendered %}{% endif %}
                            {% if form.anneesExperience is defined %}{% do form.anneesExperience.setRendered %}{% endif %}
                            {% if form.etablissementProfesseur is defined %}{% do form.etablissementProfesseur.setRendered %}{% endif %}

                        {% elseif isProfessor %}
                            <div class="col-md-6">
                                <div class="v3-input-wrapper">
                                    {{ form_label(form.specialite, 'Spécialité') }}
                                    <div class="input-inner-v3">
                                        <i class="fas fa-brain"></i>
                                        {{ form_widget(form.specialite) }}
                                    </div>
                                    {{ form_errors(form.specialite) }}
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="v3-input-wrapper">
                                    {{ form_label(form.niveauEnseignement, 'Niveau enseigné') }}
                                    <div class="input-inner-v3">
                                        <i class="fas fa-book-open"></i>
                                        {{ form_widget(form.niveauEnseignement) }}
                                    </div>
                                    {{ form_errors(form.niveauEnseignement) }}
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="v3-input-wrapper">
                                    {{ form_label(form.anneesExperience, 'Expérience (ans)') }}
                                    <div class="input-inner-v3">
                                        <i class="fas fa-history"></i>
                                        {{ form_widget(form.anneesExperience) }}
                                    </div>
                                    {{ form_errors(form.anneesExperience) }}
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="v3-input-wrapper">
                                    {{ form_label(form.etablissementProfesseur, 'Établissement') }}
                                    <div class="input-inner-v3">
                                        <i class="fas fa-building-columns"></i>
                                        {{ form_widget(form.etablissementProfesseur) }}
                                    </div>
                                    {{ form_errors(form.etablissementProfesseur) }}
                                </div>
                            </div>

                            {% if form.age is defined %}{% do form.age.setRendered %}{% endif %}
                            {% if form.sexe is defined %}{% do form.sexe.setRendered %}{% endif %}
                            {% if form.etablissement is defined %}{% do form.etablissement.setRendered %}{% endif %}
                            {% if form.niveau is defined %}{% do form.niveau.setRendered %}{% endif %}
                        {% endif %}
                    </div>
                </div>

                {# SECTION 3: SÉCURITÉ #}
                <div class="v3-section-card mt-5">
                    <div class="section-header-v3">
                        <div class="section-badge security-accent"><i class="fas fa-shield-alt"></i></div>
                        <div>
                            <h3 class="section-title-v3">Sécurité & Mot de passe</h3>
                            <p class="section-desc-v3">Modifiez votre mot de passe pour sécuriser votre compte.</p>
                        </div>
                    </div>
                    
                    <div class="mt-4">
                        <div class="v3-alert-box" style="background: #f0f9ff; border-color: #bae6fd;">
                            <div class="alert-icon"><i class="fas fa-info-circle" style="color: #0ea5e9;"></i></div>
                            <div class="alert-content">
                                <strong style="color: #0369a1;">Sécurité</strong>
                                <p style="color: #0c4a6e;">Vous allez être redirigé vers la page de récupération de mot de passe pour saisir votre email.</p>
                            </div>
                        </div>

                        <div class="text-center mt-4">
                            <a href="{{ path('app_profile_request_password_change') }}" class="btn-save-v3" style="text-decoration: none; display: inline-block; width: auto; padding: 1.2rem 3rem; background: #0f172a;">
                                <i class="fas fa-key me-2"></i> Modifier mot de passe
                            </a>
                        </div>
                    </div>
                </div>

                {# FOOTER ACTIONS #}
                <div class="v3-form-footer mt-5 pt-4 border-top">
                    <button type="submit" class="btn-save-v3">
                        <span class="btn-inner">
                            <i class="fas fa-save me-2"></i> Enregistrer les modifications
                        </span>
                    </button>
                    <p class="text-muted small mt-3 text-center mb-0">
                        <i class="fas fa-shield-alt me-1"></i> Vos modifications sont sécurisées et cryptées.
                    </p>
                </div>
            </div>

            {{ form_rest(form) }}
        {{ form_end(form, {'render_rest': false}) }}
    </div>
</div>

<style>
    :root {
        /* Calmer blue palette */
        --v3-primary: #2563eb;
        --v3-primary-dark: #1e40af;
        --v3-primary-light: #eff6ff;
        --v3-grad: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
        --v3-text-main: #0f172a;
        --v3-text-muted: #475569;
        --v3-border: #e2e8f0;
        --v3-bg-soft: #f8fafc;
        --v3-radius-lg: 32px;
        --v3-radius-md: 20px;
        --v3-shadow: 0 10px 30px -5px rgba(0,0,0,0.04);
        
        --student-accent: #2563eb;
        --professor-accent: #8b5cf6;
        --security-accent: #f59e0b;
    }

    .btn-action-v3 {
        background: var(--v3-bg-soft);
        color: var(--v3-text-main);
        border: 2px solid var(--v3-border);
        padding: 0.8rem 1.5rem;
        border-radius: 14px;
        font-weight: 600;
        transition: all 0.3s;
        cursor: pointer;
    }

    .btn-action-v3:hover {
        background: var(--security-accent);
        color: white;
        border-color: var(--security-accent);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(245, 158, 11, 0.2);
    }

    .security-accent {
        background: #fff7ed !important;
        color: #f59e0b !important;
    }

    .profile-v3-container {
        padding-bottom: 6rem; /* Increased padding */
    }

    /* ─── HERO SECTION ─── */
    .profile-v3-hero {
        position: relative;
        padding: 4rem 3rem 8rem; /* Reduced padding */
        border-radius: var(--v3-radius-lg);
        background: var(--v3-grad);
        overflow: hidden;
        color: white;
    }

    .mesh-bg-v3 {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background-image: 
            radial-gradient(at 0% 0%, rgba(255,255,255,0.1) 0, transparent 50%),
            radial-gradient(at 100% 100%, rgba(255,255,255,0.05) 0, transparent 50%);
        opacity: 0.5;
    }

    .v3-avatar-container {
        position: relative;
        width: 88px; height: 88px; /* Slightly larger */
    }

    .v3-avatar-inner {
        width: 100%; height: 100%;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(12px);
        border: 2px solid rgba(255,255,255,0.25);
        border-radius: 26px;
        display: flex; align-items: center; justify-content: center;
        font-size: 2.2rem; font-weight: 800;
        box-shadow: 0 20px 30px -12px rgba(0,0,0,0.25);
    }

    .v3-role-badge {
        position: absolute; bottom: -8px; right: -8px;
        width: 32px; height: 32px;
        background: white; color: var(--v3-primary);
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.9rem;
        box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    }

    .v3-hero-title { 
        font-weight: 800; 
        font-size: 2.5rem; 
        margin-bottom: 1.25rem; /* Increased space */
        letter-spacing: -0.03em;
        line-height: 1.2;
    }
    
    .v3-hero-subtitle { 
        color: rgba(255,255,255,0.9); 
        font-weight: 400; 
        font-size: 1.15rem;
        line-height: 1.7; /* Increased line-height */
        max-width: 600px;
    }

    .btn-glass-v3 {
        background: rgba(255,255,255,0.1);
        color: white; padding: 1rem 1.8rem;
        border-radius: 18px; border: 1px solid rgba(255,255,255,0.2);
        text-decoration: none; font-weight: 600;
        backdrop-filter: blur(10px);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        display: inline-block; /* Ensure block model */
    }
    .btn-glass-v3:hover {
        background: rgba(255,255,255,0.2);
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        color: white;
    }

    /* ─── GLASS CARD ─── */
    .glass-card-v3 {
        background: white; /* More opaque for "calm" feel */
        border-radius: var(--v3-radius-lg);
        border: 1px solid var(--v3-border);
        padding: 4.5rem; /* Increased padding */
        box-shadow: 0 30px 60px -12px rgba(15, 23, 42, 0.08);
    }

    .mt-n5 { margin-top: -6rem !important; } /* Deeper overlap */

    /* ─── SECTION CARDS ─── */
    .v3-section-card {
        background: white;
        padding: 3.5rem; /* Increased padding */
        border-radius: var(--v3-radius-md);
        border: 1px solid var(--v3-border);
        transition: all 0.3s ease;
    }
    
    .v3-section-card:hover {
        border-color: var(--v3-primary);
        box-shadow: 0 10px 40px rgba(0,0,0,0.03);
    }

    .section-header-v3 {
        display: flex; align-items: center; gap: 1.5rem;
        margin-bottom: 3rem; /* Increased margin */
    }

    .section-badge {
        width: 56px; height: 56px;
        border-radius: 16px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem;
        background: var(--v3-primary-light);
        color: var(--v3-primary);
    }

    .section-title-v3 { margin: 0; font-weight: 800; color: var(--v3-text-main); font-size: 1.4rem; }
    .section-desc-v3 { margin: 0.5rem 0 0; color: var(--v3-text-muted); font-size: 1rem; line-height: 1.6; }

    /* ─── INPUTS ─── */
    .v3-input-wrapper label {
        display: block; font-size: 0.82rem; font-weight: 600;
        color: var(--v3-text-muted); margin-bottom: 14px; /* Increased margin */
        text-transform: uppercase; letter-spacing: 0.06em;
    }

    .input-inner-v3 { position: relative; }
    .input-inner-v3 i {
        position: absolute; left: 1.4rem; top: 50%;
        transform: translateY(-50%); color: #94a3b8;
        font-size: 1.15rem; transition: all 0.3s;
    }

    .input-inner-v3 select,
    .input-inner-v3 input {
        width: 100%;
        padding: 1.1rem 1.4rem 1.1rem 3.8rem !important; /* Larger inputs */
        border-radius: 18px !important;
        border: 2px solid #f1f5f9 !important;
        background: #f8fafc !important;
        font-weight: 400 !important;
        color: var(--v3-text-main) !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        font-size: 1.05rem !important;
    }

    .input-inner-v3 input:focus,
    .input-inner-v3 select:focus {
        background: white !important;
        border-color: var(--v3-primary) !important;
        box-shadow: 0 0 0 6px rgba(37, 99, 235, 0.08) !important;
        outline: none;
    }

    .v3-input-wrapper:focus-within i { color: var(--v3-primary); transform: translateY(-50%) scale(1.1); }

    .v3-highlight input,
    .v3-highlight select {
        background: #f0f7ff !important;
        border-color: #dbeafe !important;
    }

    /* ─── SAVE BUTTON ─── */
    .v3-form-footer {
        margin-top: 5rem; /* More space */
    }

    .btn-save-v3 {
        width: 100%;
        background: var(--v3-primary-dark);
        color: white; border: none;
        padding: 1.6rem; border-radius: 20px;
        font-weight: 700; font-size: 1.15rem;
        transition: all 0.4s;
        box-shadow: 0 15px 30px rgba(30, 64, 175, 0.2);
        cursor: pointer;
        letter-spacing: 0.02em;
    }
    .btn-save-v3:hover {
        background: #1e3a8a; transform: translateY(-4px);
        box-shadow: 0 20px 40px rgba(30, 64, 175, 0.3);
    }

    /* ─── ALERTS ─── */
    .v3-alert-box {
        background: #fef2f2; border-left: 5px solid #ef4444;
        padding: 1.5rem; border-radius: 20px;
        margin-bottom: 3rem; display: flex; gap: 1.25rem;
    }
    .v3-alert-box i { color: #ef4444; font-size: 1.5rem; }
    .v3-alert-box strong { display: block; color: #991b1b; font-size: 1.1rem; margin-bottom: 0.2rem; }
    .v3-alert-box p { margin: 0; color: #b91c1c; opacity: 0.85; }

    @media (max-width: 992px) {
        .glass-card-v3 { padding: 2rem; }
        .profile-v3-hero { padding: 4rem 2rem 6rem; text-align: center; }
        .profile-v3-hero .d-flex { flex-direction: column; }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const countrySelect = document.getElementById('profile_pays');
        const schoolSelect = document.getElementById('profile_etablissement');
        const levelSelect = document.getElementById('profile_niveau');

        if (countrySelect && schoolSelect && levelSelect) {
            const initialCountry = countrySelect.value;
            const selectedSchool = schoolSelect.getAttribute('data-selected');
            const selectedLevel = levelSelect.getAttribute('data-selected');

            if (initialCountry) {
                loadLocationData(initialCountry, selectedSchool, selectedLevel);
            }

            countrySelect.addEventListener('change', function() {
                loadLocationData(this.value);
            });
        }

        function loadLocationData(countryCode, schoolToSelect = null, levelToSelect = null) {
            if (!countryCode) {
                resetSelect(schoolSelect);
                resetSelect(levelSelect);
                return;
            }

            fetch(`/api/location/schools/${countryCode}`)
                .then(response => response.json())
                .then(data => {
                    updateSelect(schoolSelect, data, schoolToSelect);
                });

            fetch(`/api/location/levels/${countryCode}`)
                .then(response => response.json())
                .then(data => {
                    updateSelect(levelSelect, data, levelToSelect);
                });
        }

        function updateSelect(selectElement, items, selectedValue) {
            if (!selectElement) return;
            selectElement.innerHTML = '';
            selectElement.disabled = false;
            
            const placeholder = document.createElement('option');
            placeholder.value = '';
            placeholder.text = 'Choisir...';
            selectElement.appendChild(placeholder);

            items.forEach(item => {
                const option = document.createElement('option');
                option.value = item;
                option.text = item;
                if (item === selectedValue) {
                    option.selected = true;
                }
                selectElement.appendChild(option);
            });
        }

        function resetSelect(selectElement) {
            if (!selectElement) return;
            selectElement.innerHTML = '<option value="">Choisir un pays d\'abord</option>';
            selectElement.disabled = true;
        }
    });
</script>
{% endblock %}
