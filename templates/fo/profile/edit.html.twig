{% extends 'layouts/fo.html.twig' %}

{% block title %}Modifier mon profil - StudySprint{% endblock %}

{% block content %}
<div style="margin-bottom: 1.5rem;">
    <a href="{{ path('fo_profile_show') }}" style="color: #6b7280; text-decoration: none; font-size: 14px; display: inline-flex; align-items: center; gap: 0.25rem;">
        <svg style="width: 16px; height: 16px; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Retour au profil
    </a>
</div>

<h1 style="font-size: 1.875rem; font-weight: 700; color: #1f2937; margin-bottom: 1.5rem;">Modifier mon profil</h1>

<div class="card">
    <div class="card-body">
        {{ form_start(form, {'attr': {'class': 'form'}}) }}

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div class="form-group">
                {{ form_label(form.fullName) }}
                {{ form_widget(form.fullName) }}
                {{ form_errors(form.fullName) }}
            </div>

            <div class="form-group">
                {{ form_label(form.avatarFile) }}
                {# Preview zone #}
                <div id="avatar-preview-wrap" style="margin-bottom: 0.75rem; display: {% if app.user.profile and app.user.profile.avatarUrl %}flex{% else %}none{% endif %}; align-items: center; gap: 1rem;">
                    <img id="avatar-preview" src="{{ app.user.profile and app.user.profile.avatarUrl ? app.user.profile.avatarUrl : '' }}" alt="Aperçu"
                         style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 3px solid #667eea; box-shadow: 0 2px 8px rgba(102,126,234,0.3);">
                    <div>
                        <div style="font-size: 13px; font-weight: 600; color: #374151;">Aperçu</div>
                        <button type="button" id="avatar-remove-preview" style="font-size: 12px; color: #ef4444; background: none; border: none; cursor: pointer; padding: 0; margin-top: 2px;">Supprimer</button>
                    </div>
                </div>
                {{ form_widget(form.avatarFile, {'attr': {'id': 'avatar-input', 'accept': 'image/jpeg,image/png,image/webp', 'style': 'display:none'}}) }}
                {# Custom file button #}
                <label for="avatar-input" id="avatar-label" style="display: inline-flex; align-items: center; gap: 0.5rem; cursor: pointer; padding: 0.5rem 1rem; border: 2px dashed #d1d5db; border-radius: 8px; color: #6b7280; font-size: 13px; transition: border-color 0.2s, color 0.2s; background: #f9fafb;"
                       onmouseover="this.style.borderColor='#667eea';this.style.color='#667eea';"
                       onmouseout="this.style.borderColor='#d1d5db';this.style.color='#6b7280';">
                    <svg style="width: 18px; height: 18px; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <span id="avatar-label-text">Choisir une image</span>
                </label>
                {{ form_errors(form.avatarFile) }}
                <div style="font-size: 12px; color: #6b7280; margin-top: 0.375rem;">JPG, PNG ou WEBP — max 3 Mo</div>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1rem;">
            <div class="form-group">
                {{ form_label(form.level) }}
                {{ form_widget(form.level) }}
                {{ form_errors(form.level) }}
            </div>

            <div class="form-group">
                {{ form_label(form.specialty) }}
                {{ form_widget(form.specialty) }}
                {{ form_errors(form.specialty) }}
            </div>
        </div>

        <div class="form-group" style="margin-top: 1rem;">
            {{ form_label(form.bio) }}
            {{ form_widget(form.bio) }}
            {{ form_errors(form.bio) }}
        </div>

        <div style="display: flex; gap: 0.75rem; margin-top: 1.25rem;">
            <button type="submit" class="btn btn-primary">
                <svg style="width: 16px; height: 16px; margin-right: 0.25rem; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Enregistrer
            </button>
            <a href="{{ path('fo_profile_show') }}" class="btn btn-ghost">Annuler</a>
        </div>

        {{ form_end(form) }}
    </div>
</div>

{# ── Centre de Sécurité ── #}
<div style="margin-top: 2rem;">
    <h2 style="font-size: 1.25rem; font-weight: 700; color: #1f2937; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
        <svg style="width: 20px; height: 20px; color: #6366f1;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        Centre de Sécurité
    </h2>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        {# Password Card #}
        <div class="card" style="border: 1px solid #e5e7eb;">
            <div class="card-body" style="display: flex; align-items: center; gap: 1rem;">
                <div style="width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, #f59e0b, #d97706); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <svg style="width: 24px; height: 24px; color: white;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
                    </svg>
                </div>
                <div style="flex: 1;">
                    <div style="font-weight: 600; color: #1f2937; font-size: 0.95rem;">Mot de passe</div>
                    <div style="font-size: 0.8rem; color: #6b7280;">Sécurisez votre compte</div>
                </div>
                <a href="{{ path('app_forgot_password') }}" class="btn btn-secondary btn-sm">Changer</a>
            </div>
        </div>

        {# Face ID Card #}
        <div class="card" style="border: 1px solid #e5e7eb;">
            <div class="card-body" style="display: flex; align-items: center; gap: 1rem;">
                <div style="width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, #6366f1, #8b5cf6); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <svg style="width: 24px; height: 24px; color: white;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0H5a2 2 0 01-2-2v-4m6 6h10a2 2 0 002-2v-4"/>
                        <circle cx="12" cy="11" r="3"/>
                    </svg>
                </div>
                <div style="flex: 1;">
                    <div style="font-weight: 600; color: #1f2937; font-size: 0.95rem;">Face ID (Biométrie)</div>
                    {% if app.user.faceDescriptor %}
                        <div style="font-size: 0.8rem; color: #16a34a; display: flex; align-items: center; gap: 4px;">
                            <span style="width: 6px; height: 6px; border-radius: 50%; background: #16a34a; display: inline-block;"></span>
                            Configuré
                        </div>
                    {% else %}
                        <div style="font-size: 0.8rem; color: #9ca3af; display: flex; align-items: center; gap: 4px;">
                            <span style="width: 6px; height: 6px; border-radius: 50%; background: #9ca3af; display: inline-block;"></span>
                            Non configuré
                        </div>
                    {% endif %}
                </div>
                <a href="{{ path('face_enroll_page') }}" class="btn btn-sm" style="background: linear-gradient(135deg, #6366f1, #8b5cf6); color: white; border: none;">
                    {{ app.user.faceDescriptor ? 'Reconfigurer' : 'Configurer' }}
                </a>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    var input    = document.getElementById('avatar-input');
    var preview  = document.getElementById('avatar-preview');
    var wrap     = document.getElementById('avatar-preview-wrap');
    var labelTxt = document.getElementById('avatar-label-text');
    var removeBtn= document.getElementById('avatar-remove-preview');

    if (!input) return;

    input.addEventListener('change', function () {
        var file = this.files[0];
        if (!file) return;
        if (file.size > 3 * 1024 * 1024) {
            alert('Image trop lourde (max 3 Mo).');
            this.value = '';
            return;
        }
        var reader = new FileReader();
        reader.onload = function (e) {
            preview.src = e.target.result;
            wrap.style.display = 'flex';
            labelTxt.textContent = file.name.length > 24 ? file.name.slice(0, 22) + '…' : file.name;
        };
        reader.readAsDataURL(file);
    });

    if (removeBtn) {
        removeBtn.addEventListener('click', function () {
            input.value = '';
            preview.src = '';
            wrap.style.display = 'none';
            labelTxt.textContent = 'Choisir une image';
        });
    }
})();
</script>
{% endblock %}
