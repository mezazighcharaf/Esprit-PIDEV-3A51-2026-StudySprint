{% extends 'layouts/fo.html.twig' %}
{% block title %}Classement - StudySprint{% endblock %}

{% block content %}
<div style="margin-bottom: 2rem;">
    <h1 style="font-size: 24px; font-weight: 700; color: #111827; margin: 0 0 0.5rem 0;">Classement</h1>
    <p style="font-size: 14px; color: #6b7280; margin: 0;">Les meilleurs étudiants de la plateforme</p>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
    {# Top by Quiz Passed #}
    <div class="card" style="border-radius: 12px; overflow: hidden;">
        <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 1.25rem 1.5rem;">
            <h2 style="font-size: 18px; font-weight: 600; color: white; margin: 0;">Plus de Quiz Réussis</h2>
        </div>
        <div style="padding: 1rem;">
            {% if topByPassed is empty %}
                <p style="text-align: center; color: #6b7280; padding: 2rem;">Aucune donnée disponible</p>
            {% else %}
                {% for entry in topByPassed %}
                <div style="display: flex; align-items: center; gap: 1rem; padding: 0.75rem; border-radius: 8px; {{ loop.index <= 3 ? 'background: #f9fafb;' : '' }} margin-bottom: 0.5rem;">
                    <div style="width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; {{ loop.index == 1 ? 'background: #fef3c7; color: #92400e;' : (loop.index == 2 ? 'background: #f3f4f6; color: #374151;' : (loop.index == 3 ? 'background: #fed7aa; color: #9a3412;' : 'background: #f9fafb; color: #6b7280;')) }}">
                        {{ loop.index }}
                    </div>
                    <div style="flex: 1;">
                        {% set name = (entry.prenom ?? '') ~ ' ' ~ (entry.nom ?? '') %}
                        <div style="font-size: 14px; font-weight: 600; color: #111827;">{{ name|trim ?: entry.email }}</div>
                        <div style="font-size: 12px; color: #6b7280;">{{ entry.email }}</div>
                    </div>
                    <div style="text-align: right;">
                        <div style="font-size: 16px; font-weight: 700; color: #667eea;">{{ entry.quizCount }}</div>
                        <div style="font-size: 11px; color: #6b7280;">quiz réussis</div>
                    </div>
                </div>
                {% endfor %}
            {% endif %}
        </div>
    </div>

    {# Top by Average Score #}
    <div class="card" style="border-radius: 12px; overflow: hidden;">
        <div style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); padding: 1.25rem 1.5rem;">
            <h2 style="font-size: 18px; font-weight: 600; color: white; margin: 0;">Meilleure Moyenne</h2>
        </div>
        <div style="padding: 1rem;">
            {% if topByScore is empty %}
                <p style="text-align: center; color: #6b7280; padding: 2rem;">Minimum 3 quiz requis</p>
            {% else %}
                {% for entry in topByScore %}
                <div style="display: flex; align-items: center; gap: 1rem; padding: 0.75rem; border-radius: 8px; {{ loop.index <= 3 ? 'background: #f9fafb;' : '' }} margin-bottom: 0.5rem;">
                    <div style="width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; {{ loop.index == 1 ? 'background: #fef3c7; color: #92400e;' : (loop.index == 2 ? 'background: #f3f4f6; color: #374151;' : (loop.index == 3 ? 'background: #fed7aa; color: #9a3412;' : 'background: #f9fafb; color: #6b7280;')) }}">
                        {{ loop.index }}
                    </div>
                    <div style="flex: 1;">
                        {% set name = (entry.prenom ?? '') ~ ' ' ~ (entry.nom ?? '') %}
                        <div style="font-size: 14px; font-weight: 600; color: #111827;">{{ name|trim ?: entry.email }}</div>
                        <div style="font-size: 12px; color: #6b7280;">{{ entry.quizCount }} quiz</div>
                    </div>
                    <div style="text-align: right;">
                        <div style="font-size: 16px; font-weight: 700; color: #10b981;">{{ entry.avgScore|number_format(1) }}%</div>
                        <div style="font-size: 11px; color: #6b7280;">moyenne</div>
                    </div>
                </div>
                {% endfor %}
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
