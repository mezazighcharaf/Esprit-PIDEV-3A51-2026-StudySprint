{% extends 'layouts/fo.html.twig' %}
{% block title %}{{ subject.name }} - StudySprint{% endblock %}

{% block stylesheets %}
<style>@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}</style>
{% endblock %}

{% block content %}
{# Breadcrumb #}
<div style="margin-bottom: 1.5rem;">
    <a href="{{ path('fo_subjects_index') }}" class="btn btn-ghost btn-sm">
        <svg style="width: 16px; height: 16px; margin-right: 0.375rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Retour aux matières
    </a>
</div>

{# Flash messages #}
{% for message in app.flashes('success') %}
    <div class="alert alert-success" style="margin-bottom: 1.5rem; border-radius: 8px;">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="alert alert-danger" style="margin-bottom: 1.5rem; border-radius: 8px;">{{ message }}</div>
{% endfor %}

{# Header gradient moderne #}
<div style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); border-radius: 12px; padding: 2rem; margin-bottom: 2rem; color: white; position: relative; overflow: hidden;">
    <div style="position: absolute; top: -30px; right: -30px; width: 200px; height: 200px; background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%); border-radius: 50%;"></div>
    
    <div style="position: relative; z-index: 1;">
        <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 1rem;">
            <div style="flex: 1;">
                <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
                    {% if subject.code %}
                    <span style="background: rgba(255,255,255,0.25); padding: 0.25rem 0.75rem; border-radius: 6px; font-size: 12px; font-weight: 600; backdrop-filter: blur(10px);">{{ subject.code }}</span>
                    {% endif %}
                    <span style="font-size: 13px; opacity: 0.9;">par {{ subject.createdBy.fullName }} {{ include('components/_teacher_badge.html.twig', {user: subject.createdBy}) }}</span>
                </div>
                <h1 style="font-size: 28px; font-weight: 700; margin: 0 0 0.625rem 0;">{{ subject.name }}</h1>
                {% if subject.description %}
                <p style="font-size: 15px; opacity: 0.9; margin: 0; line-height: 1.5;">{{ subject.description }}</p>
                {% endif %}
            </div>
            <div style="display: flex; gap: 0.625rem; margin-left: 1rem;">
                <a href="{{ path('fo_subjects_edit', {id: subject.id}) }}" class="btn btn-ghost btn-sm" style="background: rgba(255,255,255,0.2); color: white; border: none;" onmouseover="this.style.background='rgba(255,255,255,0.3)';" onmouseout="this.style.background='rgba(255,255,255,0.2)';">
                    <svg style="width: 16px; height: 16px; margin-right: 0.375rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                    Modifier
                </a>
                <form action="{{ path('fo_subjects_delete', {id: subject.id}) }}" method="post" onsubmit="return confirm('Supprimer cette matière et tous ses chapitres ?')" style="display: inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_subject_' ~ subject.id) }}">
                    <button type="submit" class="btn btn-danger btn-sm" style="background: rgba(239, 68, 68, 0.9); border: none;" onmouseover="this.style.background='rgba(220, 38, 38, 1)';" onmouseout="this.style.background='rgba(239, 68, 68, 0.9)';">
                        <svg style="width: 16px; height: 16px; margin-right: 0.375rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                        </svg>
                        Supprimer
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

{# Section Wikipedia #}
{% if wikipediaSummary and wikipediaSummary.extract %}
<div class="card" style="border-radius: 12px; margin-bottom: 2rem; border-left: 4px solid #4facfe; overflow: hidden;">
    <div style="padding: 1.25rem 1.5rem; background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%); border-bottom: 1px solid #bae6fd; display: flex; align-items: center; gap: 0.75rem;">
        <svg style="width: 20px; height: 20px; color: #0284c7; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
        <h3 style="font-size: 16px; font-weight: 600; color: #0369a1; margin: 0;">En savoir plus — Wikipedia</h3>
    </div>
    <div style="padding: 1.25rem 1.5rem; display: flex; gap: 1.25rem; align-items: flex-start;">
        {% if wikipediaSummary.thumbnail %}
        <img src="{{ wikipediaSummary.thumbnail }}" alt="{{ wikipediaSummary.title }}" style="width: 100px; height: 100px; object-fit: cover; border-radius: 8px; flex-shrink: 0; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
        {% endif %}
        <div style="flex: 1; min-width: 0;">
            <p style="color: #374151; font-size: 14px; line-height: 1.7; margin: 0 0 1rem 0;">{{ wikipediaSummary.extract|slice(0, 400) }}{% if wikipediaSummary.extract|length > 400 %}…{% endif %}</p>
            {% if wikipediaSummary.url %}
            <a href="{{ wikipediaSummary.url }}" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 0.375rem; color: #0284c7; font-size: 13px; font-weight: 500; text-decoration: none;" onmouseover="this.style.textDecoration='underline';" onmouseout="this.style.textDecoration='none';">
                <svg style="width: 14px; height: 14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
                Lire l'article complet sur Wikipedia
            </a>
            {% endif %}
        </div>
    </div>
</div>
{% endif %}

{# ─── Barre outils linguistiques ─── #}
<div style="display: flex; gap: 0.75rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
    <button type="button" id="btn-dict" onclick="openSubjectDict()" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem; border-radius: 8px; border: 1.5px solid #4facfe; background: #f0f9ff; color: #0284c7; font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.15s;" onmouseover="this.style.background='#e0f2fe'" onmouseout="this.style.background='#f0f9ff'">
        <svg style="width: 16px; height: 16px; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
        Définition (EN)
    </button>
    <button type="button" id="btn-translate" onclick="openSubjectTranslate()" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem; border-radius: 8px; border: 1.5px solid #10b981; background: #ecfdf5; color: #059669; font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.15s;" onmouseover="this.style.background='#d1fae5'" onmouseout="this.style.background='#ecfdf5'">
        <svg style="width: 16px; height: 16px; flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/>
        </svg>
        Traduire
    </button>
</div>

{# Modal Définition #}
<div id="modal-dict-subject" style="display:none; position:fixed; inset:0; z-index:1000; align-items:center; justify-content:center;">
    <div onclick="closeDictModal()" style="position:absolute; inset:0; background:rgba(0,0,0,0.5); backdrop-filter:blur(4px);"></div>
    <div style="position:relative; background:white; border-radius:16px; padding:2rem; width:90%; max-width:520px; max-height:80vh; overflow-y:auto; box-shadow:0 25px 50px rgba(0,0,0,0.25);">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.25rem;">
            <h3 style="margin:0; font-size:18px; font-weight:700; color:#111827;">Définition du mot</h3>
            <button onclick="closeDictModal()" style="background:none; border:none; cursor:pointer; color:#6b7280; font-size:22px; line-height:1;">&times;</button>
        </div>
        <div style="display:flex; gap:0.5rem; margin-bottom:1rem;">
            <input type="text" id="dict-subject-input" placeholder="Entrez un mot en anglais…" value="{{ subject.name }}"
                   style="flex:1; padding:0.625rem 0.875rem; border:1.5px solid #d1d5db; border-radius:8px; font-size:14px; outline:none;"
                   onfocus="this.style.borderColor='#4facfe'" onblur="this.style.borderColor='#d1d5db'"
                   onkeydown="if(event.key==='Enter') lookupSubjectWord()">
            <button onclick="lookupSubjectWord()" style="padding:0.625rem 1rem; background:#4facfe; color:white; border:none; border-radius:8px; font-weight:600; cursor:pointer; font-size:14px; white-space:nowrap;">
                Chercher
            </button>
        </div>
        <div id="dict-subject-result" style="min-height:60px;"></div>
    </div>
</div>

{# Modal Traduction #}
<div id="modal-translate-subject" style="display:none; position:fixed; inset:0; z-index:1000; align-items:center; justify-content:center;">
    <div onclick="closeTranslateModal()" style="position:absolute; inset:0; background:rgba(0,0,0,0.5); backdrop-filter:blur(4px);"></div>
    <div style="position:relative; background:white; border-radius:16px; padding:2rem; width:90%; max-width:520px; max-height:80vh; overflow-y:auto; box-shadow:0 25px 50px rgba(0,0,0,0.25);">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.25rem;">
            <h3 style="margin:0; font-size:18px; font-weight:700; color:#111827;">Traduction</h3>
            <button onclick="closeTranslateModal()" style="background:none; border:none; cursor:pointer; color:#6b7280; font-size:22px; line-height:1;">&times;</button>
        </div>
        <textarea id="translate-subject-input" rows="4" placeholder="Texte à traduire…" style="width:100%; padding:0.75rem; border:1.5px solid #d1d5db; border-radius:8px; font-size:14px; resize:vertical; margin-bottom:0.75rem; box-sizing:border-box; outline:none;" onfocus="this.style.borderColor='#10b981'" onblur="this.style.borderColor='#d1d5db'">{{ subject.name }}{% if subject.description %} — {{ subject.description }}{% endif %}</textarea>
        <div style="display:flex; gap:0.5rem; margin-bottom:1rem; flex-wrap:wrap;">
            <select id="translate-subject-src" style="flex:1; padding:0.5rem; border:1.5px solid #d1d5db; border-radius:8px; font-size:13px;">
                <option value="fr">Français</option>
                <option value="en">Anglais</option>
                <option value="ar">Arabe</option>
                <option value="es">Espagnol</option>
                <option value="de">Allemand</option>
            </select>
            <span style="align-self:center; color:#9ca3af; font-size:18px;">→</span>
            <select id="translate-subject-tgt" style="flex:1; padding:0.5rem; border:1.5px solid #d1d5db; border-radius:8px; font-size:13px;">
                <option value="en">Anglais</option>
                <option value="fr">Français</option>
                <option value="ar">Arabe</option>
                <option value="es">Espagnol</option>
                <option value="de">Allemand</option>
            </select>
            <button onclick="doSubjectTranslate()" style="padding:0.5rem 1.25rem; background:#10b981; color:white; border:none; border-radius:8px; font-weight:600; cursor:pointer; font-size:14px;">
                Traduire
            </button>
        </div>
        <div id="translate-subject-result" style="min-height:40px;"></div>
    </div>
</div>

{# Section Chapitres #}
<div class="card" style="border-radius: 12px; overflow: hidden;">
    <div style="background: linear-gradient(135deg, #f9fafb 0%, #ffffff 100%); padding: 1.25rem 1.5rem; border-bottom: 2px solid #f3f4f6;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <h2 style="font-size: 18px; font-weight: 600; color: #111827; margin: 0;">Chapitres ({{ chapters|length }})</h2>
            <a href="{{ path('fo_subjects_chapter_new', {subjectId: subject.id}) }}" class="btn btn-primary btn-sm">
                <svg style="width: 16px; height: 16px; margin-right: 0.375rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                Ajouter un chapitre
            </a>
        </div>
    </div>
    
    <div style="padding: 1.5rem;">
        {% if chapters is empty %}
            <div style="text-align: center; padding: 3rem 1rem;">
                <svg style="width: 64px; height: 64px; color: #d1d5db; margin: 0 auto 1rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                <p style="color: #6b7280; margin: 0 0 1.5rem 0;">Aucun chapitre pour cette matière</p>
                <a href="{{ path('fo_subjects_chapter_new', {subjectId: subject.id}) }}" class="btn btn-primary">
                    Créer le premier chapitre
                </a>
            </div>
        {% else %}
            <div style="display: flex; flex-direction: column; gap: 1rem;">
                {% for chapter in chapters %}
                <div class="card" style="border-radius: 10px; border-left: 4px solid #4facfe; transition: all 0.2s;" onmouseover="this.style.transform='translateX(4px)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,0.08)';" onmouseout="this.style.transform=''; this.style.boxShadow='';">
                    <div style="padding: 1.25rem; display: flex; justify-content: space-between; align-items: start;">
                        <div style="flex: 1;">
                            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.625rem;">
                                <div style="width: 36px; height: 36px; background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 13px; flex-shrink: 0;">
                                    {{ chapter.orderNo }}
                                </div>
                                <strong style="color: #111827; font-size: 16px;">{{ chapter.title }}</strong>
                            </div>
                            {% if chapter.summary %}
                                <p style="color: #6b7280; font-size: 14px; margin: 0 0 0 48px; line-height: 1.5;">{{ chapter.summary }}</p>
                        {% endif %}
                    </div>
                    <div style="display: flex; gap: 0.5rem; flex-shrink: 0;">
                        <a href="{{ path('fo_subjects_chapter_edit', {subjectId: subject.id, chapterId: chapter.id}) }}" class="btn btn-ghost btn-sm" style="padding: 0.5rem;" title="Modifier">
                            <svg style="width: 16px; height: 16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                            </svg>
                        </a>
                        <form action="{{ path('fo_subjects_chapter_delete', {subjectId: subject.id, chapterId: chapter.id}) }}" 
                              method="post" 
                              onsubmit="return confirm('Supprimer ce chapitre ?')"
                              style="display: inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_chapter_' ~ chapter.id) }}">
                            <button type="submit" style="padding: 0.25rem; background: none; border: none; cursor: pointer; font-size: 16px;" title="Supprimer">
                                🗑️
                            </button>
                        </form>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
function openSubjectDict() {
    var m = document.getElementById('modal-dict-subject');
    m.style.display = 'flex';
    setTimeout(function() { document.getElementById('dict-subject-input').focus(); }, 50);
}
function closeDictModal() {
    document.getElementById('modal-dict-subject').style.display = 'none';
}
function openSubjectTranslate() {
    document.getElementById('modal-translate-subject').style.display = 'flex';
}
function closeTranslateModal() {
    document.getElementById('modal-translate-subject').style.display = 'none';
}
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') { closeDictModal(); closeTranslateModal(); }
});

var AI_SPINNER = '<div style="text-align:center;padding:1.25rem;color:#6b7280;font-size:13px;display:flex;align-items:center;justify-content:center;gap:0.5rem;"><svg style="width:16px;height:16px;animation:spin 1s linear infinite;" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg> IA en cours…</div>';

function lookupSubjectWord() {
    var word = document.getElementById('dict-subject-input').value.trim();
    if (!word) return;
    var result = document.getElementById('dict-subject-result');
    result.innerHTML = AI_SPINNER;
    fetch('/api/dictionary/' + encodeURIComponent(word))
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.error) {
                result.innerHTML = '<div style="padding:1rem;background:#fef2f2;border-radius:8px;color:#b91c1c;font-size:13px;">' + data.error + ' <button onclick="lookupSubjectWord()" style="background:none;border:none;cursor:pointer;color:#2563eb;text-decoration:underline;font-size:13px;">Réessayer</button></div>';
                return;
            }
            var html = '<div style="border:1px solid #e5e7eb;border-radius:10px;overflow:hidden;">';
            html += '<div style="padding:0.875rem 1rem;background:#f0f9ff;border-bottom:1px solid #bae6fd;display:flex;align-items:center;gap:0.5rem;">';
            html += '<span style="font-size:16px;font-weight:700;color:#0284c7;">' + (data.word || word) + '</span>';
            html += '<span style="font-size:10px;background:#dbeafe;color:#1d4ed8;padding:0.15rem 0.5rem;border-radius:50px;font-weight:600;">IA</span>';
            html += '</div>';
            if (data.definition) {
                html += '<div style="padding:0.875rem 1rem;">';
                html += '<div style="font-size:14px;color:#1f2937;line-height:1.6;">' + data.definition + '</div>';
                if (data.example) html += '<div style="font-size:12px;color:#6b7280;margin-top:0.5rem;font-style:italic;border-left:3px solid #e5e7eb;padding-left:0.5rem;">' + data.example + '</div>';
                html += '</div>';
            }
            html += '</div>';
            result.innerHTML = html;
        })
        .catch(function() {
            result.innerHTML = '<div style="padding:1rem;background:#fef2f2;border-radius:8px;color:#b91c1c;font-size:13px;">Erreur réseau. <button onclick="lookupSubjectWord()" style="background:none;border:none;cursor:pointer;color:#2563eb;text-decoration:underline;font-size:13px;">Réessayer</button></div>';
        });
}

function doSubjectTranslate() {
    var text   = document.getElementById('translate-subject-input').value.trim();
    var source = document.getElementById('translate-subject-src').value;
    var target = document.getElementById('translate-subject-tgt').value;
    var result = document.getElementById('translate-subject-result');
    if (!text) return;
    result.innerHTML = AI_SPINNER;
    fetch('/api/translate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text: text, source: source, target: target })
    })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.error) {
                result.innerHTML = '<div style="padding:1rem;background:#fef2f2;border-radius:8px;color:#b91c1c;font-size:13px;">' + data.error + ' <button onclick="doSubjectTranslate()" style="background:none;border:none;cursor:pointer;color:#2563eb;text-decoration:underline;font-size:13px;">Réessayer</button></div>';
                return;
            }
            result.innerHTML = '<div style="padding:1rem;background:#ecfdf5;border-radius:10px;border:1px solid #a7f3d0;">'
                + '<div style="font-size:11px;font-weight:700;text-transform:uppercase;color:#059669;margin-bottom:0.5rem;letter-spacing:0.05em;display:flex;align-items:center;gap:0.4rem;">Traduction <span style="font-size:10px;background:#d1fae5;color:#065f46;padding:0.1rem 0.4rem;border-radius:50px;">IA</span></div>'
                + '<div style="font-size:15px;color:#1f2937;line-height:1.6;">' + (data.translated || '') + '</div>'
                + '</div>';
        })
        .catch(function() {
            result.innerHTML = '<div style="padding:1rem;background:#fef2f2;border-radius:8px;color:#b91c1c;font-size:13px;">Erreur réseau. <button onclick="doSubjectTranslate()" style="background:none;border:none;cursor:pointer;color:#2563eb;text-decoration:underline;font-size:13px;">Réessayer</button></div>';
        });
}
</script>
{% endblock %}
