{% extends 'layouts/fo.html.twig' %}

{% block page_title %}{{ group.name }}{% endblock %}

{% block content %}
<div class="group-detail-container">
    {# ─── GROUP HEADER ─── #}
    <div class="group-detail-header">
        <div class="group-detail-header-content">
            <div class="group-detail-avatar">{{ group.initials }}</div>
            <div class="group-detail-info">
                <h1 class="group-detail-title">{{ group.name }}</h1>
                <p class="group-detail-description">{{ group.description }}</p>
                <div class="group-detail-meta">
                    <span class="badge badge-neutral">{{ group.members|length }} membres</span>
                    <span class="text-sm text-muted">Créé il y a 2 mois</span>
                </div>
            </div>
        </div>
        <a href="{{ path('app_groups') }}" class="btn btn-ghost btn-sm">← Retour aux groupes</a>
    </div>

    <div class="group-detail-layout">
        {# ─── MAIN CONTENT (POSTS) ─── #}
        <main class="group-detail-main">
            {# NEW POST FORM #}
            <div class="forum-new-post" data-post-form>
                <div class="forum-new-post-header">
                    <div class="avatar avatar-sm avatar-initials">{{ user.initials }}</div>
                    <input type="text" class="form-input" placeholder="Partager une question ou une idée..." data-post-form-trigger style="cursor: pointer;">
                </div>

                {# POST TYPE SELECTOR #}
                <div class="forum-post-types" data-post-types style="display: none; margin-top: var(--space-3); padding-top: var(--space-3); border-top: 1px solid var(--border-color);">
                    <button class="forum-post-type-btn active" data-type="text" type="button" title="Texte">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                        </svg>
                        <span>Texte</span>
                    </button>
                    <button class="forum-post-type-btn" data-type="file" type="button" title="Fichier">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                            <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/>
                            <polyline points="13 2 13 9 20 9"/>
                            <line x1="12" y1="12" x2="12" y2="18"/>
                            <line x1="9" y1="15" x2="15" y2="15"/>
                        </svg>
                        <span>Fichier</span>
                    </button>
                    <button class="forum-post-type-btn" data-type="link" type="button" title="Lien">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                        </svg>
                        <span>Lien</span>
                    </button>
                </div>

                {# TEXT POST FORM #}
                <form class="forum-post-input-form" data-post-input-form="text" style="display: none; margin-top: var(--space-3);">
                    <textarea class="form-input" placeholder="Quelle est votre question ou idée?" rows="4" style="resize: vertical;"></textarea>
                    <div class="forum-form-actions">
                        <button type="button" class="btn btn-ghost btn-sm" data-post-cancel>Annuler</button>
                        <button type="submit" class="btn btn-primary btn-sm">Publier</button>
                    </div>
                </form>

                {# FILE POST FORM #}
                <form class="forum-post-input-form" data-post-input-form="file" style="display: none; margin-top: var(--space-3);">
                    <div class="forum-file-upload">
                        <input type="file" id="forum-file-input" multiple style="display: none;">
                        <button type="button" class="btn btn-secondary btn-sm" data-file-trigger>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                                <polyline points="17 8 12 3 7 8"/>
                                <line x1="12" y1="3" x2="12" y2="15"/>
                            </svg>
                            <span>Choisir des fichiers</span>
                        </button>
                        <div class="forum-file-list" data-file-list></div>
                    </div>
                    <textarea class="form-input" placeholder="Ajouter une description..." rows="3" style="margin-top: var(--space-2); resize: vertical;"></textarea>
                    <div class="forum-form-actions">
                        <button type="button" class="btn btn-ghost btn-sm" data-post-cancel>Annuler</button>
                        <button type="submit" class="btn btn-primary btn-sm">Publier</button>
                    </div>
                </form>

                {# LINK POST FORM #}
                <form class="forum-post-input-form" data-post-input-form="link" style="display: none; margin-top: var(--space-3);">
                    <input type="url" class="form-input" placeholder="https://exemple.com" style="margin-bottom: var(--space-2);">
                    <textarea class="form-input" placeholder="Ajouter un commentaire..." rows="3" style="resize: vertical;"></textarea>
                    <div class="forum-form-actions">
                        <button type="button" class="btn btn-ghost btn-sm" data-post-cancel>Annuler</button>
                        <button type="submit" class="btn btn-primary btn-sm">Publier</button>
                    </div>
                </form>
            </div>

            {# POSTS LIST #}
            <div class="forum-posts">
                {% for post in posts %}
                <article class="forum-post">
                    {# POST HEADER #}
                    <div class="forum-post-header">
                        <div class="forum-post-author">
                            <div class="avatar avatar-sm avatar-initials">{{ post.author_initials }}</div>
                            <div class="forum-post-author-info">
                                <div class="forum-post-author-name">
                                    {{ post.author }}
                                    {% if post.author_role == 'admin' %}
                                    <span class="badge badge-primary" style="font-size: 0.65rem;">Admin</span>
                                    {% endif %}
                                </div>
                                <div class="text-xs text-muted">{{ post.created_at }}</div>
                            </div>
                        </div>
                        <button class="btn btn-ghost btn-icon btn-xs" title="Plus d'options" type="button">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                                <circle cx="12" cy="12" r="1"/>
                                <circle cx="12" cy="5" r="1"/>
                                <circle cx="12" cy="19" r="1"/>
                            </svg>
                        </button>
                    </div>

                    <div class="forum-post-content">
                        {{ post.content }}
                    </div>

                    <div class="forum-post-rating">
                        <span class="text-sm text-muted">Note:</span>
                        {% for i in 1..5 %}
                            <button class="forum-star {% if i <= post.rating %}active{% endif %}" title="Note {{ i }} étoile" type="button">
                                <svg viewBox="0 0 24 24" fill="{% if i <= post.rating %}currentColor{% else %}none{% endif %}" stroke="currentColor" stroke-width="2" width="16" height="16">
                                    <polygon points="12 2 15.09 10.26 23.77 10.36 17.13 16.52 19.09 25.63 12 19.5 4.91 25.63 6.87 16.52 0.23 10.36 8.91 10.26"/>
                                </svg>
                            </button>
                        {% endfor %}
                    </div>

                    <div class="forum-post-footer">
                        <button class="forum-post-action" type="button" data-comments-btn data-post-id="{{ post.id }}">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                            </svg>
                            <span class="comments-count">{{ post.comments_count }}</span>
                            <span>Commentaires</span>
                        </button>
                        <button class="forum-post-action" type="button" data-like-btn data-post-id="{{ post.id }}" data-liked="false">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" class="like-icon">
                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                            </svg>
                            <span class="likes-count">{{ post.likes }}</span>
                            <span>J'aime</span>
                        </button>
                    </div>

                    {# POST COMMENTS SECTION AT BOTTOM #}
                    <div class="forum-post-comments-section" data-post-comments="{{ post.id }}" style="margin-top: var(--space-4); padding-top: var(--space-4); border-top: 1px solid var(--border-color);">
                        <div class="comments-mini-list"></div>
                        <button class="text-xs text-muted" style="background: none; border: none; cursor: pointer; padding: 0; margin-top: var(--space-2);" data-view-all-comments="{{ post.id }}">
                            Voir tous les commentaires ({{ post.comments_count }})
                        </button>
                    </div>
                </article>
                {% endfor %}
            </div>
        </main>

        {# ─── SIDEBAR ─── #}
        <aside class="group-detail-sidebar">
            {# MEMBERS WIDGET #}
            <div class="sidebar-widget">
                <h3 class="sidebar-widget-title">Membres ({{ group.members|length }})</h3>
                <div class="members-list">
                    {% for member in group.members %}
                    <div class="members-list-item">
                        <div class="avatar avatar-sm avatar-initials">{{ member.initials }}</div>
                        <div class="members-list-info">
                            <div class="text-sm font-medium">{{ member.name }}</div>
                            <div class="text-xs text-muted">
                                {% if member.role == 'admin' %}
                                    Admin
                                {% elseif member.role == 'moderator' %}
                                    Modo
                                {% else %}
                                    Membre
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>

            {# INFO WIDGET #}
            <div class="sidebar-widget">
                <h3 class="sidebar-widget-title">Informations</h3>
                <div class="sidebar-widget-content">
                    <div class="info-row">
                        <span class="info-label">Matière:</span>
                        <span class="info-value">{{ group.subject }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Type:</span>
                        <span class="info-value">Privé</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Créé:</span>
                        <span class="info-value">Il y a 2 mois</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Posts:</span>
                        <span class="info-value">{{ posts|length }}</span>
                    </div>
                </div>
            </div>

            {# RULES WIDGET #}
            <div class="sidebar-widget">
                <h3 class="sidebar-widget-title">Règles du groupe</h3>
                <ul class="sidebar-rules">
                    <li>Soyez respectueux envers les autres membres</li>
                    <li>Pas de spam ou de contenu promotionnel</li>
                    <li>Posez des questions claires et précises</li>
                    <li>Aidez les autres membres quand vous pouvez</li>
                </ul>
            </div>
        </aside>
    </div>
</div>

{# ─── COMMENTS DRAWER ─── #}
<div class="drawer" data-comments-drawer style="display: none;">
    <div class="drawer-content">
        <div class="drawer-header">
            <h3>Commentaires</h3>
            <button class="btn btn-ghost btn-icon" data-comments-close type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>

        <div class="drawer-body">
            <div class="comments-list" data-comments-list></div>
        </div>

        <div class="drawer-footer">
            <div class="new-comment-form">
                <div class="new-comment-input">
                    <div class="avatar avatar-sm avatar-initials">{{ user.initials }}</div>
                    <input type="text" class="form-input" placeholder="Ajouter un commentaire..." data-new-comment-input>
                </div>
                <button class="btn btn-primary btn-sm" data-post-comment type="button" style="margin-top: var(--space-2); width: 100%;">Publier</button>
            </div>
        </div>
    </div>
</div>

{# ─── SHARE MODAL ─── #}
<div class="modal-backdrop" data-share-modal-backdrop style="display: none;"></div>
<div class="modal" data-share-modal style="display: none;">
    <div class="modal-header">
        <h3>Partager ce post</h3>
        <button class="btn btn-ghost btn-icon" data-share-close type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
    </div>

    <div class="modal-body">
        <div class="share-options">
            <button class="share-option" data-share-copy type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                    <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/>
                    <rect x="8" y="2" width="8" height="4" rx="1" ry="1"/>
                </svg>
                <div>
                    <div class="share-option-title">Copier le lien</div>
                    <div class="share-option-desc">Copier dans le presse-papiers</div>
                </div>
            </button>

            <button class="share-option" data-share-facebook type="button">
                <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                <div>
                    <div class="share-option-title">Facebook</div>
                    <div class="share-option-desc">Partager sur Facebook</div>
                </div>
            </button>

            <button class="share-option" data-share-twitter type="button">
                <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                    <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                </svg>
                <div>
                    <div class="share-option-title">Twitter</div>
                    <div class="share-option-desc">Partager sur Twitter</div>
                </div>
            </button>
        </div>
    </div>
</div>

<style>
.group-detail-container {
    max-width: 1400px;
    margin: 0 auto;
}

.group-detail-header {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    padding: var(--space-5);
    margin-bottom: var(--space-6);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
}

.group-detail-header-content {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    flex: 1;
}

.group-detail-avatar {
    width: 64px;
    height: 64px;
    border-radius: var(--border-radius);
    background: var(--color-secondary-light);
    color: var(--color-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    flex-shrink: 0;
}

.group-detail-title {
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    color: var(--color-gray-900);
    margin: 0 0 var(--space-1) 0;
}

.group-detail-description {
    color: var(--color-gray-600);
    margin: 0 0 var(--space-3) 0;
    font-size: var(--text-sm);
}

.group-detail-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
}

.group-detail-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--space-6);
}

/* ─── FORUM POSTS ─── */
.forum-new-post {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    padding: var(--space-4);
    margin-bottom: var(--space-4);
}

.forum-new-post-header {
    display: flex;
    gap: var(--space-3);
    align-items: center;
}

.forum-new-post-header input {
    flex: 1;
    cursor: pointer;
}

.forum-new-post-header input:focus {
    background: var(--bg-hover);
}

/* ─── POST TYPE SELECTOR ─── */
.forum-post-types {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
}

.forum-post-type-btn {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    background: var(--bg-hover);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-sm);
    color: var(--color-gray-600);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    cursor: pointer;
    transition: all var(--transition-fast);
}

.forum-post-type-btn:hover {
    background: var(--bg-secondary);
    border-color: var(--color-primary-light);
    color: var(--color-primary);
}

.forum-post-type-btn.active {
    background: var(--color-primary-light);
    border-color: var(--color-primary);
    color: var(--color-primary);
}

.forum-post-type-btn svg {
    stroke: currentColor;
}

/* ─── POST INPUT FORMS ─── */
.forum-post-input-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
}

.forum-file-upload {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
}

.forum-file-upload button {
    justify-content: center;
}

.forum-file-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
}

.forum-file-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-2);
    background: var(--bg-hover);
    border-radius: var(--border-radius-sm);
    font-size: var(--text-sm);
}

.forum-file-item-name {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    flex: 1;
}

.forum-file-item-remove {
    background: none;
    border: none;
    color: var(--color-danger);
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
}

.forum-form-actions {
    display: flex;
    gap: var(--space-2);
    justify-content: flex-end;
    margin-top: var(--space-2);
}

.forum-posts {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
}

.forum-post {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    padding: var(--space-4);
    transition: all var(--transition-base);
}

.forum-post:hover {
    border-color: var(--color-primary-light);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.forum-post-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-3);
}

.forum-post-author {
    display: flex;
    align-items: center;
    gap: var(--space-2);
}

.forum-post-author-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.forum-post-author-name {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-weight: var(--font-semibold);
    color: var(--color-gray-900);
}

.forum-post-content {
    color: var(--color-gray-700);
    line-height: 1.6;
    margin-bottom: var(--space-3);
}

.forum-post-rating {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--border-color);
}

.forum-star {
    background: none;
    border: none;
    color: var(--color-gray-300);
    cursor: pointer;
    transition: all var(--transition-fast);
    padding: 0;
    display: flex;
    align-items: center;
}

.forum-star:hover,
.forum-star.active {
    color: var(--color-warning);
}

.forum-post-footer {
    display: flex;
    gap: var(--space-4);
}

.forum-post-action {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    background: none;
    border: none;
    color: var(--color-gray-600);
    cursor: pointer;
    font-size: var(--text-sm);
    transition: all var(--transition-fast);
    padding: var(--space-1) 0;
}

.forum-post-action:hover {
    color: var(--color-primary);
}

/* ─── SIDEBAR ─── */
.group-detail-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
}

.sidebar-widget {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    padding: var(--space-4);
}

.sidebar-widget-title {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-gray-900);
    margin: 0 0 var(--space-3) 0;
}

.members-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
}

.members-list-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2);
    border-radius: var(--border-radius-sm);
    transition: all var(--transition-fast);
}

.members-list-item:hover {
    background: var(--bg-hover);
}

.members-list-info {
    flex: 1;
    min-width: 0;
}

.sidebar-widget-content {
    display: flex;
    flex-direction: column;
