{% extends 'layouts/fo.html.twig' %}

{% block page_title %}{{ group.name }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
{% endblock %}

{% block content %}
<div class="group-detail-container" data-group-id="{{ group.id }}">
    {# ─── GROUP HEADER ─── #}
    <a href="{{ path('app_groups') }}" class="btn btn-ghost btn-sm" style="margin-bottom: var(--space-4); display: inline-flex; align-items: center; gap: var(--space-1); white-space: nowrap;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" style="flex-shrink: 0;">
            <path d="M15 19l-7-7 7-7"/>
        </svg>
        Retour aux groupes
    </a>

    <div class="group-detail-header">
        <div class="group-detail-header-content">
            <div class="group-detail-avatar">{{ group.initials }}</div>
            <div class="group-detail-info">
                <h1 class="group-detail-title">{{ group.name }}</h1>
                <p class="group-detail-description">{{ group.description }}</p>
                <div class="group-detail-meta">
                    <span class="badge badge-neutral">{{ group.subject }}</span>
                    <span class="text-sm text-muted">Créé le {{ group.created_at }}</span>
                </div>
            </div>
        </div>
        <div style="display: flex; gap: var(--space-2); align-items: center;">
            {# Bouton Inviter : groupe privé uniquement #}
            {% if is_member and can_invite and group.privacy == 'private' %}
                <button class="btn btn-secondary btn-sm"
                        data-modal-open="invite-members-modal">
                    <svg viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        width="18"
                        height="18">
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                    Inviter
                </button>
            {% endif %}

            {# Bouton Rejoindre : groupe public uniquement #}
            {% if not is_member and group.privacy == 'public' %}
                <form action="{{ path('app_group_join_public', {id: group.id}) }}"
                    method="post"
                    style="display:inline;">
                    <input type="hidden"
                        name="_token"
                        value="{{ csrf_token('join-group-' ~ group.id) }}">
                    <button type="submit"
                            class="btn btn-primary btn-sm">
                        Rejoindre le groupe
                    </button>
                </form>
            {% endif %}

            {% if can_edit %}
            <a href="{{ path('app_group_edit', {'id': group.id}) }}" class="btn btn-secondary btn-sm" title="Modifier le groupe">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
                Paramètres
            </a>
            {% endif %}
            
            {% if can_delete %}
            <button type="button" class="btn btn-danger btn-sm leave-group-btn" data-group-id="{{ group.id }}" data-group-name="{{ group.name }}" data-action="delete" data-csrf="{{ csrf_token('delete-group-' ~ group.id) }}" title="Supprimer le groupe">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                    <polyline points="3 6 5 6 21 6"/>
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                    <line x1="10" y1="11" x2="10" y2="17"/>
                    <line x1="14" y1="11" x2="14" y2="17"/>
                </svg>
                Supprimer
            </button>
            {% endif %}
            
            {% if is_member and not can_delete %}
            <button type="button" class="btn btn-danger btn-sm leave-group-btn" data-group-id="{{ group.id }}" data-group-name="{{ group.name }}" data-action="leave" data-csrf="{{ csrf_token('leave-group-' ~ group.id) }}" title="Quitter le groupe">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                    <polyline points="16 17 21 12 16 7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                Quitter
            </button>
            {% endif %}
        </div>
    </div>

    <div class="group-detail-layout">
        {# ─── MAIN CONTENT (POSTS) ─── #}
        <main class="group-detail-main">
            {# NEW POST FORM #}
            {{ include('fo/fragments/_new_post_form.html.twig') }}

            {# POSTS TOOLBAR #}
            {% if posts|length > 0 %}
            <div class="fo-posts-toolbar">
                <span style="font-size: 0.8rem; color: var(--color-gray-500);">Trier par :</span>
                <div class="fo-sort-options">
                    <a href="#" class="fo-sort-btn {{ current_sort == 'date' ? 'active' : '' }}" data-sort="date">Récent</a>
                    <a href="#" class="fo-sort-btn {{ current_sort == 'likes' ? 'active' : '' }}" data-sort="likes">J'aimes</a>
                    <a href="#" class="fo-sort-btn {{ current_sort == 'comments' ? 'active' : '' }}" data-sort="comments">Commentaires</a>
                    <a href="#" class="fo-sort-btn {{ current_sort == 'rating' ? 'active' : '' }}" data-sort="rating">Notes</a>
                </div>
            </div>
            {% endif %}

            {# POSTS LIST #}
            <div class="fo-posts-list" id="posts-container">
                {{ include('fo/fragments/_posts_list.html.twig') }}
            </div>
        </main>

        {# ─── SIDEBAR ─── #}
        {{ include('fo/fragments/_sidebar.html.twig') }}
    </div>
</div>

{# ─── COMMENTS DRAWER ─── #}
<div class="drawer" data-comments-drawer>
    <div class="drawer-content">
        <div class="drawer-header">
            <h3>Commentaires</h3>
            <button class="btn btn-ghost btn-icon" data-comments-close type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>

        <div class="drawer-body">
            <div class="comments-list" data-comments-list></div>
        </div>

        <div class="drawer-footer">
            <div class="new-comment-form">
                <div class="new-comment-input">
                    <div class="avatar avatar-sm avatar-initials">{{ user.initials }}</div>
                    <input type="text" class="form-input" placeholder="Ajouter un commentaire..." data-new-comment-input>
                </div>
                <button class="btn btn-primary btn-sm" data-post-comment type="button" style="margin-top: var(--space-2); width: 100%;">Publier</button>
            </div>
        </div>
    </div>
</div>

{# ─── SHARE MODAL ─── #}
<div class="modal-backdrop" data-share-modal-backdrop></div>
<div class="modal" id="share-modal" data-share-modal>
    <div class="modal-header">
        <h3>Partager ce post</h3>
        <button class="btn btn-ghost btn-icon" data-share-close type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
    </div>

    <div class="modal-body">
        <div class="share-options">
            <button class="share-option" data-share-copy type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                    <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/>
                    <rect x="8" y="2" width="8" height="4" rx="1" ry="1"/>
                </svg>
                <div>
                    <div class="share-option-title">Copier le lien</div>
                    <div class="share-option-desc">Copier dans le presse-papiers</div>
                </div>
            </button>

            <button class="share-option" data-share-facebook type="button">
                <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                <div>
                    <div class="share-option-title">Facebook</div>
                    <div class="share-option-desc">Partager sur Facebook</div>
                </div>
            </button>

            <button class="share-option" data-share-twitter type="button">
                <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                    <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                </svg>
                <div>
                    <div class="share-option-title">Twitter</div>
                    <div class="share-option-desc">Partager sur Twitter</div>
                </div>
            </button>
        </div>
    </div>
</div>




{% endblock %}

{% block drawers %}
{% endblock %}

{% block modals %}
{# ─── CHATBOT CONFIG MODAL ─── #}
{% if is_admin is defined and is_admin %}
<div class="modal" id="chatbot-config-modal">
    <div class="modal-dialog" style="width: 90%; max-width: 520px;">
    <div class="modal-content">
    <div class="modal-header" style="border-bottom: 1px solid var(--border-color); padding: 16px 20px;">
        <h3 style="margin: 0; font-size: 1rem; display: flex; align-items: center; gap: 8px;">
            <span style="background: linear-gradient(135deg, #6366F1, #8B5CF6); width: 28px; height: 28px; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" width="16" height="16">
                    <path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1.27A7 7 0 0 1 7.27 19H6a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h1a7 7 0 0 1 7-7h1V5.73c-.6-.34-1-.99-1-1.73a2 2 0 0 1 2-2z"/>
                    <circle cx="9" cy="13" r="1"/><circle cx="15" cy="13" r="1"/>
                    <path d="M9 17h6"/>
                </svg>
            </span>
            Configuration du Chatbot
        </h3>
        <button class="btn btn-ghost btn-icon" data-modal-close type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
    </div>
    <div class="modal-body" style="padding: 20px; max-height: 65vh; overflow-y: auto;">
        <form id="chatbot-config-form">
            {# Bot Name #}
            <div class="form-group" style="margin-bottom: 16px;">
                <label class="form-label" style="font-size: 0.8rem; font-weight: 600; margin-bottom: 6px; display: block;">Nom du bot</label>
                <input type="text" name="botName" class="form-input" id="cfg-botName" value="{{ chatbot.botName|default('StudyBot') }}" placeholder="StudyBot" style="font-size: 0.85rem;">
                <div class="form-hint" style="font-size: 0.72rem; color: var(--color-gray-500); margin-top: 4px;">Le nom affiché quand le bot répond</div>
            </div>

            {# Personality #}
            <div class="form-group" style="margin-bottom: 16px;">
                <label class="form-label" style="font-size: 0.8rem; font-weight: 600; margin-bottom: 6px; display: block;">Personnalité</label>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
                    <label class="chatbot-personality-option" style="display: flex; align-items: flex-start; gap: 8px; padding: 10px; border: 2px solid var(--border-color); border-radius: 10px; cursor: pointer; transition: all 0.2s;">
                        <input type="radio" name="personality" value="tutor" {{ (chatbot.personality|default('tutor')) == 'tutor' ? 'checked' : '' }} style="margin-top: 2px;">
                        <div>
                            <div style="font-size: 0.8rem; font-weight: 600;">🎓 Tuteur</div>
                            <div style="font-size: 0.7rem; color: var(--color-gray-500);">Explique avec pédagogie</div>
                        </div>
                    </label>
                    <label class="chatbot-personality-option" style="display: flex; align-items: flex-start; gap: 8px; padding: 10px; border: 2px solid var(--border-color); border-radius: 10px; cursor: pointer; transition: all 0.2s;">
                        <input type="radio" name="personality" value="assistant" {{ (chatbot.personality|default('')) == 'assistant' ? 'checked' : '' }} style="margin-top: 2px;">
                        <div>
                            <div style="font-size: 0.8rem; font-weight: 600;">⚡ Assistant</div>
                            <div style="font-size: 0.7rem; color: var(--color-gray-500);">Réponses directes et concises</div>
                        </div>
                    </label>
                    <label class="chatbot-personality-option" style="display: flex; align-items: flex-start; gap: 8px; padding: 10px; border: 2px solid var(--border-color); border-radius: 10px; cursor: pointer; transition: all 0.2s;">
                        <input type="radio" name="personality" value="mentor" {{ (chatbot.personality|default('')) == 'mentor' ? 'checked' : '' }} style="margin-top: 2px;">
                        <div>
                            <div style="font-size: 0.8rem; font-weight: 600;">🧭 Mentor</div>
                            <div style="font-size: 0.7rem; color: var(--color-gray-500);">Guide et encourage</div>
                        </div>
                    </label>
                    <label class="chatbot-personality-option" style="display: flex; align-items: flex-start; gap: 8px; padding: 10px; border: 2px solid var(--border-color); border-radius: 10px; cursor: pointer; transition: all 0.2s;">
                        <input type="radio" name="personality" value="quiz-master" {{ (chatbot.personality|default('')) == 'quiz-master' ? 'checked' : '' }} style="margin-top: 2px;">
                        <div>
                            <div style="font-size: 0.8rem; font-weight: 600;">🧩 Quiz Master</div>
                            <div style="font-size: 0.7rem; color: var(--color-gray-500);">Teste les connaissances</div>
                        </div>
                    </label>
                </div>
            </div>

            {# Subject Context #}
            <div class="form-group" style="margin-bottom: 16px;">
                <label class="form-label" style="font-size: 0.8rem; font-weight: 600; margin-bottom: 6px; display: block;">Contexte / Matière</label>
                <input type="text" name="subjectContext" class="form-input" id="cfg-subjectContext" value="{{ chatbot.subjectContext|default(group.subject)|default('') }}" placeholder="ex: Mathématiques L2, Programmation Python..." style="font-size: 0.85rem;">
                <div class="form-hint" style="font-size: 0.72rem; color: var(--color-gray-500); margin-top: 4px;">Aide le bot à mieux contextualiser ses réponses</div>
            </div>

            {# Trigger Mode #}
            <div class="form-group" style="margin-bottom: 16px;">
                <label class="form-label" style="font-size: 0.8rem; font-weight: 600; margin-bottom: 6px; display: block;">Mode de déclenchement</label>
                <select name="triggerMode" class="form-select" id="cfg-triggerMode" style="font-size: 0.85rem;">
                    <option value="auto-detect" {{ (chatbot.triggerMode|default('auto-detect')) == 'auto-detect' ? 'selected' : '' }}>Automatique (détecte les questions)</option>
                    <option value="mention" {{ (chatbot.triggerMode|default('')) == 'mention' ? 'selected' : '' }}>Par mention (mots-clés)</option>
                    <option value="keyword" {{ (chatbot.triggerMode|default('')) == 'keyword' ? 'selected' : '' }}>Par mot-clé uniquement</option>
                </select>
                <div class="form-hint" style="font-size: 0.72rem; color: var(--color-gray-500); margin-top: 4px;">
                    <strong>Auto</strong> : répond aux questions détectées &bull; <strong>Mention/Mot-clé</strong> : répond quand un mot-clé est utilisé
                </div>
            </div>

            {# Trigger Keywords (shown when mention or keyword mode) #}
            <div class="form-group" id="cfg-keywords-group" style="margin-bottom: 16px; display: {{ (chatbot.triggerMode|default('auto-detect')) in ['mention', 'keyword'] ? 'block' : 'none' }};">
                <label class="form-label" style="font-size: 0.8rem; font-weight: 600; margin-bottom: 6px; display: block;">Mots-clés de déclenchement</label>
                <input type="text" name="triggerKeywords" class="form-input" id="cfg-triggerKeywords" value="{{ chatbot.triggerKeywords|default(['@bot', '@studybot'])|join(', ') }}" placeholder="@bot, @studybot, aide-moi" style="font-size: 0.85rem;">
                <div class="form-hint" style="font-size: 0.72rem; color: var(--color-gray-500); margin-top: 4px;">Séparez les mots-clés par des virgules</div>
            </div>

            {# Language #}
            <div class="form-group" style="margin-bottom: 16px;">
                <label class="form-label" style="font-size: 0.8rem; font-weight: 600; margin-bottom: 6px; display: block;">Langue des réponses</label>
                <div class="cfg-language-grid" id="cfg-language-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px;">
                    {% set languages = [
                        {code: 'fr', flag: 'fr', label: 'Français'},
                        {code: 'en', flag: 'gb', label: 'English'},
                        {code: 'es', flag: 'es', label: 'Español'},
                        {code: 'de', flag: 'de', label: 'Deutsch'},
                        {code: 'ar', flag: 'sa', label: 'العربية'},
                        {code: 'it', flag: 'it', label: 'Italiano'},
                        {code: 'pt', flag: 'pt', label: 'Português'},
                        {code: 'tr', flag: 'tr', label: 'Türkçe'},
                        {code: 'zh', flag: 'cn', label: '中文'},
                    ] %}
                    {% for lang in languages %}
                        <label class="cfg-lang-option" style="display: flex; align-items: center; gap: 6px; padding: 6px 8px; border: 1.5px solid {{ (chatbot.language|default('fr')) == lang.code ? '#6366F1' : 'var(--border-color, #e5e7eb)' }}; border-radius: 8px; cursor: pointer; font-size: 0.8rem; background: {{ (chatbot.language|default('fr')) == lang.code ? 'rgba(99,102,241,0.06)' : 'transparent' }}; transition: all 0.15s ease;">
                            <input type="radio" name="language" value="{{ lang.code }}" {{ (chatbot.language|default('fr')) == lang.code ? 'checked' : '' }} style="display: none;">
                            <span class="fi fi-{{ lang.flag }}" style="font-size: 16px; flex-shrink: 0;"></span>
                            <span style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{ lang.label }}</span>
                        </label>
                    {% endfor %}
                </div>
                <input type="hidden" id="cfg-language" value="{{ chatbot.language|default('fr') }}">
            </div>

            {# Max Response Length #}
            <div class="form-group" style="margin-bottom: 16px;">
                <label class="form-label" style="font-size: 0.8rem; font-weight: 600; margin-bottom: 6px; display: flex; align-items: center; justify-content: space-between;">
                    Longueur max des réponses
                    <span style="font-weight: 400; color: var(--color-gray-500);" id="cfg-maxLen-display">{{ chatbot.maxResponseLength|default(800) }} car.</span>
                </label>
                <input type="range" name="maxResponseLength" id="cfg-maxResponseLength" min="200" max="2000" step="100" value="{{ chatbot.maxResponseLength|default(800) }}" style="width: 100%; accent-color: #6366F1;">
            </div>
        </form>
    </div>
    <div class="modal-footer" style="padding: 12px 20px; border-top: 1px solid var(--border-color); display: flex; justify-content: flex-end; gap: 8px;">
        <button class="btn btn-secondary btn-sm" data-modal-close type="button">Annuler</button>
        <button class="btn btn-sm" id="chatbot-config-save" type="button" style="background: linear-gradient(135deg, #6366F1, #8B5CF6); color: white; border: none;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M20 6L9 17l-5-5"/></svg>
            Sauvegarder
        </button>
    </div>
    </div>{# /modal-content #}
    </div>{# /modal-dialog #}
</div>{# /modal #}
{% endif %}

<div class="modal" id="invite-members-modal">
    <div class="modal-dialog" style="width: 90%; max-width: 500px;">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title">Inviter des membres - {{ group.name }}</h2>
                <button class="modal-close" data-modal-close aria-label="Fermer">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"/>
                        <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>
            <div class="modal-body">
                <form id="invite-form-{{ group.id }}" action="{{ path('app_group_invite', {id: group.id}) }}" method="post">
                    <input type="hidden" name="_token" value="{{ csrf_token('invite-members-' ~ group.id) }}">
                    <div class="form-group">
                        <label class="form-label required">Adresses emails</label>
                        <textarea name="emails" class="form-textarea" placeholder="marie@example.com&#10;thomas@example.com&#10;julie@example.com" rows="4" required></textarea>
                        <div class="form-hint">Entrez les adresses separees par des retours a la ligne.</div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Role</label>
                        <select name="role" class="form-select">
                            <option value="member">Membre</option>
                            <option value="moderator">Moderateur</option>
                        </select>
                        <div class="form-hint">Les modérateurs peuvent gérer les autres membres.</div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-modal-close>Annuler</button>
                <button type="submit" form="invite-form-{{ group.id }}" class="btn btn-primary">Envoyer les invitations</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script src="{{ asset('assets/js/translate.js') }}"></script>
    
    {# CSRF Tokens for Post Actions #}
    <meta name="csrf-token-create-post-{{ group.id }}" content="{{ csrf_token('create-post-' ~ group.id) }}">
    
    {% for post in posts %}
    <meta name="csrf-token-like-post-{{ post.id }}" content="{{ csrf_token('like-post-' ~ post.id) }}">
    <meta name="csrf-token-rate-post-{{ post.id }}" content="{{ csrf_token('rate-post-' ~ post.id) }}">
    <meta name="csrf-token-comment-post-{{ post.id }}" content="{{ csrf_token('comment-post-' ~ post.id) }}">
    <meta name="csrf-token-delete-post-{{ post.id }}" content="{{ csrf_token('delete-post-' ~ post.id) }}">
    {% endfor %}
{% endblock %}
