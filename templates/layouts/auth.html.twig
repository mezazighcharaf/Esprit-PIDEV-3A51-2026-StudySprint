{% extends 'layouts/base.html.twig' %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('assets/css/bo.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/forms.css') }}">
    <style>
        .auth-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: var(--bg-subtle, #f5f7fa);
            padding: 2rem;
        }
        .auth-card {
            width: 100%;
            max-width: 600px;
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            padding: 2.5rem;
        }
        .auth-logo {
            display: flex;
            justify-content: center;
            margin-bottom: 2rem;
        }
        .auth-title {
            text-align: center;
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--text-primary, #1e293b);
            margin-bottom: 2rem;
        }
        .form-group {
            margin-bottom: 1.5rem;
        }
        .role-selector-wrapper {
            background: var(--bg-surface-hover, #f8fafc);
            padding: 1.5rem;
            border-radius: 8px;
            margin-bottom: 2rem;
            border: 1px solid var(--border-color, #e2e8f0);
        }
        .role-title {
            font-size: 0.95rem;
            font-weight: 500;
            margin-bottom: 1rem;
            color: var(--text-secondary, #64748b);
            text-align: center;
        }
        .role-options {
            display: flex;
            gap: 1rem;
            justify-content: center;
        }
        /* Custom radio buttons to look like buttons/cards */
        .role-option input[type="radio"] {
            display: none;
        }
        .role-option label {
            display: block;
            padding: 0.75rem 1.5rem;
            background: white;
            border: 2px solid var(--border-color, #e2e8f0);
            border-radius: 6px;
            cursor: pointer;
            font-weight: 500;
            transition: all 0.2s;
        }
        .role-option input[type="radio"]:checked + label {
            border-color: var(--color-primary, #2563eb);
            color: var(--color-primary, #2563eb);
            background: var(--color-primary-light, #eff6ff);
        }
        
        /* Error messages are now handled by forms.css and custom_theme.html.twig */
    </style>
{% endblock %}

{% block body %}
<div class="auth-container">
    <div class="auth-card">
        <div class="auth-logo">
            {{ include('components/_logo.html.twig', { size: 'lg', show_text: true }) }}
        </div>
        
        {# Display Flash Messages #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'error' ? 'danger' : label }} mb-4" style="padding: 1rem; border-radius: 8px;">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}
        
        {% block content %}{% endblock %}
    </div>
</div>
{% endblock %}
