{# AI Feedback Component - Include after any AI generation result #}
{# Props: aiLogId (int|null) #}
{% if aiLogId %}
<div class="ai-feedback-widget" data-log-id="{{ aiLogId }}" style="display: inline-flex; align-items: center; gap: 0.5rem; margin-top: 0.5rem; padding: 0.5rem 0.75rem; background: #f9fafb; border-radius: 8px; border: 1px solid #e5e7eb;">
    <span style="font-size: 12px; color: #6b7280;">Utile ?</span>
    <div class="ai-feedback-stars" style="display: flex; gap: 2px;">
        {% for i in 1..5 %}
        <button type="button" class="ai-fb-star" data-rating="{{ i }}" style="background: none; border: none; cursor: pointer; padding: 2px; transition: transform 0.15s;" title="{{ i }}/5">
            <svg viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="2" width="18" height="18" style="transition: all 0.15s;">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
        </button>
        {% endfor %}
    </div>
    <span class="ai-fb-msg" style="font-size: 11px; color: #10b981; display: none;">Merci !</span>
</div>
{% endif %}
