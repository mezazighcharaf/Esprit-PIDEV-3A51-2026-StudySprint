{#
  ROLE BADGE COMPONENT
  Displays consistent role badges with appropriate styling and icons
  
  Usage:
  {{ _self.role_badge('admin') }}
  {{ _self.role_badge(groupMember.role) }}
#}

{% macro role_badge(role, size = 'md', showIcon = true) %}
    {# Map roles to display data #}
    {% set roleConfig = {
        'admin': {
            label: 'Admin',
            class: 'badge-admin',
            icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L7 7v5h10V7l-5-5z"/></svg>'|raw,
            color: 'primary'
        },
        'moderator': {
            label: 'Modérateur',
            class: 'badge-moderator',
            icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2c5.523 0 10 4.477 10 10s-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2z"/><path d="M12 7v5l3.5 2"/></svg>'|raw,
            color: 'warning'
        },
        'member': {
            label: 'Membre',
            class: 'badge-member',
            icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>'|raw,
            color: 'success'
        }
    } %}

    {% if role in roleConfig %}
        {% set config = roleConfig[role] %}
        <span class="role-badge role-badge-{{ size }} {{ config.class }}" data-role="{{ role }}" role="status">
            {% if showIcon and size != 'xs' %}
                <span class="role-badge-icon">{{ config.icon }}</span>
            {% endif %}
            <span class="role-badge-label">{{ config.label }}</span>
        </span>
    {% else %}
        <span class="role-badge role-badge-{{ size }}" data-role="unknown" role="status">
            <span class="role-badge-label">{{ role|capitalize }}</span>
        </span>
    {% endif %}
{% endmacro %}

{% macro role_list_vertical(members, hideOwnRole = false, currentUser = null) %}
    {# Display grouped list of members by role #}
    {% set adminMembers = members|filter(m => m.role.name == 'ROLE_ADMIN') %}
    {% set moderatorMembers = members|filter(m => m.role.name == 'ROLE_MODERATOR') %}
    {% set regularMembers = members|filter(m => m.role.name == 'ROLE_MEMBER') %}

    <div class="role-list-container">
        {% if adminMembers|length > 0 %}
            <div class="role-list-section">
                <h3 class="role-list-heading">Administrateurs ({{ adminMembers|length }})</h3>
                <ul class="role-list">
                    {% for member in adminMembers %}
                        <li class="role-list-item">
                            {{ _self._member_item(member, currentUser) }}
                        </li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        {% if moderatorMembers|length > 0 %}
            <div class="role-list-section">
                <h3 class="role-list-heading">Modérateurs ({{ moderatorMembers|length }})</h3>
                <ul class="role-list">
                    {% for member in moderatorMembers %}
                        <li class="role-list-item">
                            {{ _self._member_item(member, currentUser) }}
                        </li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        {% if regularMembers|length > 0 %}
            <div class="role-list-section">
                <h3 class="role-list-heading">Membres ({{ regularMembers|length }})</h3>
                <ul class="role-list">
                    {% for member in regularMembers %}
                        <li class="role-list-item">
                            {{ _self._member_item(member, currentUser) }}
                        </li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}
    </div>
{% endmacro %}

{% macro _member_item(member, currentUser) %}
    <div class="role-member-item">
        <div class="role-member-avatar">
            {% if member.user.profilePicture %}
                <img src="{{ member.user.profilePicture }}" alt="{{ member.user.name }}" />
            {% else %}
                <div class="avatar-placeholder" style="background-color: var(--color-{{ member.user.name|avatar_color }})">
                    {{ member.user.name|initials }}
                </div>
            {% endif %}
        </div>
        <div class="role-member-info">
            <div class="role-member-name">
                {{ member.user.name }}
                {% if currentUser and member.user.id == currentUser.id %}
                    <span class="role-member-badge">(Vous)</span>
                {% endif %}
            </div>
            <div class="role-member-role">
                {{ _self.role_badge(member.role.value, 'xs', false) }}
            </div>
        </div>
    </div>
{% endmacro %}

<style>
  .role-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--border-radius);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    white-space: nowrap;
  }

  .role-badge-sm {
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-xs);
  }

  .role-badge-xs {
    padding: 2px var(--space-1);
    font-size: 10px;
  }

  .role-badge-lg {
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-sm);
  }

  .role-badge-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .role-badge-icon svg {
    width: 100%;
    height: 100%;
  }

  .role-badge-label {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  /* Admin Badge Styling */
  .role-badge-admin {
    background-color: rgba(59, 130, 246, 0.1);
    color: var(--color-primary);
    border: 1px solid rgba(59, 130, 246, 0.3);
  }

  .role-badge-admin .role-badge-icon {
    color: var(--color-primary);
  }

  /* Moderator Badge Styling */
  .role-badge-moderator {
    background-color: rgba(245, 158, 11, 0.1);
    color: var(--color-warning);
    border: 1px solid rgba(245, 158, 11, 0.3);
  }

  .role-badge-moderator .role-badge-icon {
    color: var(--color-warning);
  }

  /* Member Badge Styling */
  .role-badge-member {
    background-color: rgba(16, 185, 129, 0.1);
    color: var(--color-success);
    border: 1px solid rgba(16, 185, 129, 0.3);
  }

  .role-badge-member .role-badge-icon {
    color: var(--color-success);
  }

  /* Member List Styles */
  .role-list-container {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .role-list-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .role-list-heading {
    margin: 0;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-text-secondary);
  }

  .role-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .role-list-item {
    margin: 0;
    padding: 0;
  }

  .role-member-item {
    display: flex;
    gap: var(--space-3);
    padding: var(--space-3);
    background: var(--bg-secondary);
    border-radius: var(--border-radius);
    align-items: center;
  }

  .role-member-avatar {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--bg-primary);
  }

  .role-member-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .avatar-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: white;
    font-weight: 600;
    font-size: 14px;
  }

  .role-member-info {
    flex: 1;
    min-width: 0;
  }

  .role-member-name {
    margin: 0;
    font-weight: 600;
    color: var(--color-text);
    font-size: var(--text-sm);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .role-member-badge {
    font-weight: 500;
    color: var(--color-text-secondary);
    font-size: 12px;
  }

  .role-member-role {
    margin-top: var(--space-1);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .role-badge-lg {
      padding: var(--space-2) var(--space-3);
      font-size: var(--text-xs);
    }

    .role-member-item {
      padding: var(--space-2);
    }
  }
</style>
