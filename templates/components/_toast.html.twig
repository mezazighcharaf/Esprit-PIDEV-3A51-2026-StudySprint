{#
  Toast Component (for server-side rendering)
  Usage:
  {{ include('components/_toast.html.twig', {
      type: 'success', // success | error | warning | info
      title: 'Succes',
      message: 'Action effectuee avec succes.'
  }) }}

  Note: For dynamic toasts, use the JS API:
  window.StudySprint.Toast.success('Titre', 'Message');
#}

<div class="toast toast-{{ type|default('info') }}">
    <span class="toast-icon">
        {% if type == 'success' %}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
        {% elseif type == 'error' %}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="15" y1="9" x2="9" y2="15"/>
            <line x1="9" y1="9" x2="15" y2="15"/>
        </svg>
        {% elseif type == 'warning' %}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/>
            <line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        {% else %}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="16" x2="12" y2="12"/>
            <line x1="12" y1="8" x2="12.01" y2="8"/>
        </svg>
        {% endif %}
    </span>
    <div class="toast-content">
        {% if title %}<div class="toast-title">{{ title }}</div>{% endif %}
        {% if message %}<div class="toast-message">{{ message }}</div>{% endif %}
    </div>
    <button class="toast-close" aria-label="Fermer">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
    </button>
</div>
