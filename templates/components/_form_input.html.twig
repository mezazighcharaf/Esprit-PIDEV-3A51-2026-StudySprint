<style>
  /* Form Group */
  .form-group {
    margin-bottom: var(--space-5);
  }

  .form-group:last-child {
    margin-bottom: 0;
  }

  /* Form Label */
  .form-label {
    display: block;
    margin-bottom: var(--space-2);
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .form-required {
    color: var(--color-error);
    margin-left: 2px;
  }

  /* Text Input */
  .form-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .form-input-with-icon .form-input {
    padding-left: var(--space-9);
  }

  .form-input-icon {
    position: absolute;
    left: var(--space-3);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    color: var(--color-text-secondary);
    pointer-events: none;
  }

  .form-input-icon svg {
    width: 100%;
    height: 100%;
  }

  .form-input,
  .form-select,
  .form-textarea {
    width: 100%;
    padding: var(--space-3);
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius);
    font-size: var(--text-sm);
    color: var(--color-text);
    font-family: inherit;
    transition: all 0.2s ease;
  }

  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }

  .form-input:disabled,
  .form-select:disabled,
  .form-textarea:disabled {
    background: var(--bg-secondary);
    color: var(--color-text-secondary);
    cursor: not-allowed;
  }

  .form-input-error,
  .form-select.form-input-error,
  .form-textarea.form-input-error {
    border-color: var(--color-error);
  }

  .form-input-error:focus,
  .form-select.form-input-error:focus,
  .form-textarea.form-input-error:focus {
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
  }

  /* Password Input */
  .form-password-wrapper {
    position: relative;
  }

  .form-password-toggle {
    position: absolute;
    right: var(--space-3);
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-secondary);
    padding: 0;
    border-radius: 4px;
    transition: all 0.2s ease;
  }

  .form-password-toggle:hover {
    color: var(--color-text);
    background: var(--bg-secondary);
  }

  .form-password-toggle svg {
    width: 20px;
    height: 20px;
  }

  .password-icon-hide {
    display: none;
  }

  .form-password-toggle[data-type="text"] .password-icon-show {
    display: none;
  }

  .form-password-toggle[data-type="text"] .password-icon-hide {
    display: block;
  }

  input::-webkit-password-reveal-button {
    display: none;
  }

  /* Textarea */
  .form-textarea-wrapper {
    position: relative;
  }

  .form-textarea {
    resize: vertical;
    min-height: 100px;
  }

  .form-textarea-counter {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 2px;
    margin-top: var(--space-2);
    font-size: 12px;
    color: var(--color-text-secondary);
  }

  .form-counter-current {
    font-weight: 600;
    color: var(--color-text);
  }

  /* Select */
  .form-select-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .form-select {
    appearance: none;
    padding-right: var(--space-9);
    cursor: pointer;
  }

  .form-select-arrow {
    position: absolute;
    right: var(--space-3);
    width: 20px;
    height: 20px;
    pointer-events: none;
    color: var(--color-text-secondary);
  }

  /* Checkbox & Radio */
  .form-checkbox-group,
  .form-radio-group {
    margin-bottom: var(--space-4);
  }

  .form-checkbox-wrapper,
  .form-radio-wrapper {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .form-checkbox,
  .form-radio {
    width: 18px;
    height: 18px;
    cursor: pointer;
    flex-shrink: 0;
    accent-color: var(--color-primary);
  }

  .form-checkbox-label,
  .form-radio-label {
    font-size: var(--text-sm);
    color: var(--color-text);
    cursor: pointer;
    user-select: none;
  }

  .form-checkbox:disabled,
  .form-radio:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  /* Error & Help Text */
  .form-error {
    margin-top: var(--space-2);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form-error-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    padding: var(--space-2);
    background-color: rgba(239, 68, 68, 0.05);
    border: 1px solid rgba(239, 68, 68, 0.2);
    border-radius: 4px;
    color: var(--color-error);
    font-size: 13px;
  }

  .form-error-icon {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    margin-top: 2px;
  }

  .form-help {
    margin-top: var(--space-2);
    font-size: 13px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .form-group {
      margin-bottom: var(--space-4);
    }

    .form-input,
    .form-select,
    .form-textarea {
      font-size: 16px;
    }
  }
</style>

<script>
  // Password visibility toggle
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.form-password-toggle').forEach(button => {
      button.addEventListener('click', function(e) {
        e.preventDefault();
        const targetId = this.dataset.target;
        const input = document.getElementById(targetId);
        
        if (input) {
          const isPassword = input.type === 'password';
          input.type = isPassword ? 'text' : 'password';
          this.dataset.type = input.type;
        }
      });
    });

    // Textarea character counter
    document.querySelectorAll('.form-textarea[maxlength]').forEach(textarea => {
      const wrapper = textarea.closest('.form-textarea-wrapper');
      const counter = wrapper?.querySelector('.form-counter-current');
      
      if (counter) {
        const updateCounter = () => {
          counter.textContent = textarea.value.length;
        };
        
        textarea.addEventListener('input', updateCounter);
        updateCounter();
      }
    });
  });
</script>
