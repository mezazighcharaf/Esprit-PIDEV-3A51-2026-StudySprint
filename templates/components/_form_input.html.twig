{#
  FORM INPUT COMPONENTS
  Centralized form input macros with consistent styling and validation display
  
  Usage:
  {{ _self.form_text_input(form.name) }}
  {{ _self.form_textarea_input(form.description) }}
  {{ _self.form_select_input(form.role) }}
  {{ _self.form_checkbox_input(form.isPrivate) }}
#}

{% macro form_text_input(field, label = null, placeholder = '', required = false, helpText = '', icon = null) %}
    <div class="form-group">
        {% if label %}
            <label for="{{ field.vars.id }}" class="form-label">
                {{ label }}
                {% if required %}
                    <span class="form-required" aria-label="Required field">*</span>
                {% endif %}
            </label>
        {% endif %}
        
        <div class="form-input-wrapper{{ icon ? ' form-input-with-icon' : '' }}">
            {% if icon %}
                <span class="form-input-icon">{{ icon|raw }}</span>
            {% endif %}
            {{ form_widget(field, {
                'attr': {
                    'class': 'form-input' ~ (field.vars.errors|length > 0 ? ' form-input-error' : ''),
                    'placeholder': placeholder,
                    'aria-describedby': (helpText or field.vars.errors|length > 0) ? field.vars.id ~ '-help' : null
                }
            }) }}
        </div>

        {% if field.vars.errors|length > 0 %}
            <div class="form-error" role="alert" id="{{ field.vars.id }}-help">
                {% for error in field.vars.errors %}
                    <div class="form-error-item">
                        <svg class="form-error-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        <span>{{ error.message }}</span>
                    </div>
                {% endfor %}
            </div>
        {% elseif helpText %}
            <div class="form-help" id="{{ field.vars.id }}-help">{{ helpText }}</div>
        {% endif %}
    </div>
{% endmacro %}

{% macro form_email_input(field, label = 'Email', placeholder = 'example@example.com', required = true, helpText = '') %}
    {{ _self.form_text_input(
        field,
        label,
        placeholder,
        required,
        helpText,
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>'
    ) }}
{% endmacro %}

{% macro form_password_input(field, label = 'Mot de passe', required = true, helpText = '') %}
    <div class="form-group">
        {% if label %}
            <label for="{{ field.vars.id }}" class="form-label">
                {{ label }}
                {% if required %}
                    <span class="form-required" aria-label="Required field">*</span>
                {% endif %}
            </label>
        {% endif %}
        
        <div class="form-input-wrapper form-password-wrapper">
            {{ form_widget(field, {
                'attr': {
                    'class': 'form-input' ~ (field.vars.errors|length > 0 ? ' form-input-error' : ''),
                    'aria-describedby': (helpText or field.vars.errors|length > 0) ? field.vars.id ~ '-help' : null
                }
            }) }}
            <button type="button" class="form-password-toggle" data-target="{{ field.vars.id }}" aria-label="Show password">
                <svg class="password-icon-show" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                    <circle cx="12" cy="12" r="3"/>
                </svg>
                <svg class="password-icon-hide" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                    <line x1="1" y1="1" x2="23" y2="23"/>
                </svg>
            </button>
        </div>

        {% if field.vars.errors|length > 0 %}
            <div class="form-error" role="alert" id="{{ field.vars.id }}-help">
                {% for error in field.vars.errors %}
                    <div class="form-error-item">
                        <svg class="form-error-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        <span>{{ error.message }}</span>
                    </div>
                {% endfor %}
            </div>
        {% elseif helpText %}
            <div class="form-help" id="{{ field.vars.id }}-help">{{ helpText }}</div>
        {% endif %}
    </div>
{% endmacro %}

{% macro form_textarea_input(field, label = null, placeholder = '', required = false, helpText = '', rows = 4, maxLength = null) %}
    <div class="form-group">
        {% if label %}
            <label for="{{ field.vars.id }}" class="form-label">
                {{ label }}
                {% if required %}
                    <span class="form-required" aria-label="Required field">*</span>
                {% endif %}
            </label>
        {% endif %}
        
        <div class="form-textarea-wrapper">
            {{ form_widget(field, {
                'attr': {
                    'class': 'form-textarea' ~ (field.vars.errors|length > 0 ? ' form-input-error' : ''),
                    'placeholder': placeholder,
                    'rows': rows,
                    'maxlength': maxLength,
                    'aria-describedby': (helpText or field.vars.errors|length > 0) ? field.vars.id ~ '-help' : null
                }
            }) }}
            {% if maxLength %}
                <div class="form-textarea-counter">
                    <span class="form-counter-current" data-target="{{ field.vars.id }}">0</span>
                    <span class="form-counter-divider">/</span>
                    <span class="form-counter-max">{{ maxLength }}</span>
                </div>
            {% endif %}
        </div>

        {% if field.vars.errors|length > 0 %}
            <div class="form-error" role="alert" id="{{ field.vars.id }}-help">
                {% for error in field.vars.errors %}
                    <div class="form-error-item">
                        <svg class="form-error-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        <span>{{ error.message }}</span>
                    </div>
                {% endfor %}
            </div>
        {% elseif helpText %}
            <div class="form-help" id="{{ field.vars.id }}-help">{{ helpText }}</div>
        {% endif %}
    </div>
{% endmacro %}

