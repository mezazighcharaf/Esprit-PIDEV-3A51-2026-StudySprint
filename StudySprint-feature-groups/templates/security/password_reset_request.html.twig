{% extends 'layouts/auth.html.twig' %}

{% block title %}Mot de passe oublié - StudySprint{% endblock %}

{% block content %}
    <h1 class="auth-title">Mot de passe oublié ?</h1>
    
    <p style="text-align: center; color: #64748b; margin-bottom: 2rem;">
        Choisissez votre méthode de récupération et nous vous enverrons un code de vérification.
    </p>

    {{ form_start(form, {'attr': {'class': 'auth-form', 'novalidate': 'novalidate'}}) }}
        <div class="alert alert-danger">
            {{ form_errors(form) }}
        </div>
        <div class="form-group mb-4">
            {{ form_label(form.method) }}
            <div class="method-selector" style="display: flex; gap: 1rem; margin-top: 0.5rem;">
                {% for child in form.method %}
                    <label class="method-option" style="flex: 1; border: 1px solid #e2e8f0; padding: 0.8rem; border-radius: 8px; cursor: pointer; text-align: center; transition: all 0.2s;">
                        {{ form_widget(child, {'attr': {'style': 'display: none;', 'class': 'method-input'}}) }}
                        <span class="method-label">{{ child.vars.label }}</span>
                    </label>
                {% endfor %}
            </div>
            {{ form_errors(form.method) }}
        </div>

        <div id="email-field" class="form-group">
            {{ form_label(form.email) }}
            {{ form_widget(form.email) }}
            {{ form_errors(form.email) }}
        </div>

        <div id="telephone-field" class="form-group" style="display: none;">
            {{ form_label(form.telephone) }}
            {{ form_widget(form.telephone) }}
            {{ form_errors(form.telephone) }}
        </div>

        <div style="margin-top: 2rem;">
            <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; padding: 0.8rem;">
                Envoyer le code
            </button>
        </div>

        <p style="text-align: center; margin-top: 1.5rem;">
            <a href="{{ path('app_login') }}" style="color: var(--color-primary); text-decoration: none; font-weight: 500;">
                Retour à la connexion
            </a>
        </p>
    {{ form_end(form) }}

    <style>
        .method-option:has(input:checked) {
            border-color: var(--color-primary) !important;
            background: rgba(79, 70, 229, 0.05);
            color: var(--color-primary);
            font-weight: 600;
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const methodInputs = document.querySelectorAll('.method-input');
            const emailField = document.getElementById('email-field');
            const telephoneField = document.getElementById('telephone-field');

            function toggleFields() {
                const selectedMethod = document.querySelector('.method-input:checked').value;
                if (selectedMethod === 'telephone') {
                    emailField.style.display = 'none';
                    telephoneField.style.display = 'block';
                } else {
                    emailField.style.display = 'block';
                    telephoneField.style.display = 'none';
                }
            }

            methodInputs.forEach(input => {
                input.addEventListener('change', toggleFields);
            });

            // Initial state
            toggleFields();
        });
    </script>
{% endblock %}
