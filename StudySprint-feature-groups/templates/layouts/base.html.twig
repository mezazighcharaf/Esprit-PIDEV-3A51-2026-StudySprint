<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}StudySprint{% endblock %}</title>

    {# ─── CSS ─── #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="{{ asset('assets/css/tokens.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/base.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/components.css') }}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    {% block stylesheets %}{% endblock %}

    {# ─── Favicon ─── #}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📚</text></svg>">
</head>
<body>
    {% block body %}{% endblock %}

    {# ─── Toast Container ─── #}
    <div class="toast-container" id="toast-container"></div>

    {# ─── JS ─── #}
    <script src="{{ asset('assets/js/ui.js') }}"></script>
    
    {# ─── Flash Messages as Toasts ─── #}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    {% if label == 'success' %}
                        StudySprint.Toast.success('Succès', '{{ message|e('js') }}');
                    {% elseif label == 'error' %}
                        StudySprint.Toast.error('Erreur', '{{ message|e('js') }}');
                    {% elseif label == 'warning' %}
                        StudySprint.Toast.warning('Attention', '{{ message|e('js') }}');
                    {% else %}
                        StudySprint.Toast.info('Info', '{{ message|e('js') }}');
                    {% endif %}
                {% endfor %}
            {% endfor %}
        });
    </script>

    {% block javascripts %}{% endblock %}
</body>
</html>
